---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI für Kanzleien & Steuerberater | MarkMade"
  description="KI qualifiziert Mandantenanfragen vor, erstellt Standardschreiben automatisch und spart täglich wertvolle Zeit. Für Anwälte und Steuerberater."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI für Kanzleien &amp; Steuerberater</p>
      <h1>Weniger Verwaltung. Mehr Zeit für Mandanten.</h1>
      <h2 class="seo-subline">KI für Kanzleien und Steuerberater – Mandantenanfragen, Dokumente und Termine automatisch bearbeiten</h2>
      <p class="hero-text">
        KI übernimmt Standardaufgaben in deiner Kanzlei – Anfragen vorqualifizieren, Termine buchen, Schreiben vorbereiten. Du konzentrierst dich auf die Beratung.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 3. USE CASES -->
  <section class="use-cases">
    <div class="uc-inner">
      <h2>Was KI für Kanzleien konkret übernimmt</h2>
      <div class="uc-grid">

        <div class="uc-punkt fade-in">
          <span class="uc-icon">💬</span>
          <div>
            <h3>Mandantenanfragen vorqualifizieren</h3>
            <p>Welches Anliegen, welche Dringlichkeit? KI filtert bevor du dran bist.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📅</span>
          <div>
            <h3>Termine automatisch buchen</h3>
            <p>Mandanten buchen direkt in deinen Kalender. Ohne Telefonat.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📄</span>
          <div>
            <h3>Standardschreiben vorbereiten</h3>
            <p>Vorlagen automatisch befüllen. Du prüfst, unterschreibst, fertig.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">✉️</span>
          <div>
            <h3>E-Mail-Antworten auf Standardfragen</h3>
            <p>Fristen, Kosten, Ablauf – KI beantwortet, du konzentrierst dich auf die Beratung.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📁</span>
          <div>
            <h3>Dokumente zusammenfassen</h3>
            <p>Lange Verträge oder Akten in Minuten auf das Wesentliche reduziert.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">⏰</span>
          <div>
            <h3>Fristenmanagement unterstützen</h3>
            <p>Automatische Erinnerungen bevor Fristen kritisch werden.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">⭐</span>
          <div>
            <h3>Mandantenfeedback automatisch einholen</h3>
            <p>Nach Abschluss automatisch um Bewertung bitten.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">🔁</span>
          <div>
            <h3>Wiedervorlagen automatisieren</h3>
            <p>Offene Vorgänge werden automatisch nachgefasst.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. ZEITRECHNER -->
  <section class="zeitrechner">
    <div class="zr-inner">
      <div class="zr-content">
        <h2>Wie viel Zeit kostet dich Verwaltung gerade wirklich?</h2>

        <div class="zr-slider-group">
          <label for="anfragen">
            Wie viele Mandantenanfragen bekommst du pro Woche?
            <span class="zr-val" id="anfragen-val">20</span>
          </label>
          <input type="range" id="anfragen" min="5" max="60" value="20" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>5</span><span>60</span></div>
        </div>

        <div class="zr-slider-group">
          <label for="minuten">
            Wie lange bearbeitest du eine Standardanfrage?
            <span class="zr-val" id="minuten-val">15 Min</span>
          </label>
          <input type="range" id="minuten" min="5" max="30" value="15" step="5" class="zr-range" />
          <div class="zr-range-labels"><span>5 Min</span><span>30 Min</span></div>
        </div>
      </div>

      <div class="zr-ergebnis">
        <div class="zr-box">
          <p class="zr-label">Stunden pro Woche</p>
          <p class="zr-woche" id="zr-woche">5</p>
          <p class="zr-label">Stunden pro Jahr</p>
          <p class="zr-jahr" id="zr-jahr">260</p>
          <p class="zr-frage" id="zr-frage">Was machst du mit 260 Stunden mehr im Jahr?</p>
          <p class="zr-hinweis">Das sind keine Versprechen. Das ist Mathematik.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. WAS KI NICHT KANN -->
  <section class="ki-nicht">
    <div class="kn-inner">
      <h2>Was KI nicht kann.</h2>
      <p class="kn-text">KI kennt nicht deine Mandanten. Nicht die Besonderheiten deiner Fälle. Nicht was einen guten Anwalt oder Steuerberater ausmacht. Sie macht erfahrene Kanzleien effizienter – aber sie ersetzt niemanden der das Handwerk beherrscht. Deshalb steckt hinter jeder MarkMade-Lösung ein Mensch der versteht wie dein Betrieb funktioniert.</p>
      <div class="kn-punkte">
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Beratung machst du</strong> – KI bereitet dich vor</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Vertrauen baust du auf</strong> – KI gibt dir mehr Zeit dafür</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Fachkenntnis kommt von dir</strong> – KI macht sie skalierbar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CHATDEMO -->
  <section class="demo-section">
    <div class="demo-inner">
      <ChatDemo
        title="So qualifiziert KI Mandantenanfragen vor"
        messages={[
          {role: 'user', text: 'Ich brauche dringend rechtliche Beratung wegen einer Kündigung.'},
          {role: 'bot', text: 'Das klingt nach einem dringenden Anliegen. Handelt es sich um eine eigene Kündigung oder die eines Mitarbeiters?'},
          {role: 'user', text: 'Ich wurde selbst gekündigt – heute erhalten.'},
          {role: 'bot', text: 'Verstanden. Bei einer fristlosen Kündigung sind die ersten Tage entscheidend. Ich reserviere Ihnen direkt einen Termin – am besten noch diese Woche?'}
        ]}
      />
    </div>
  </section>

  <!-- 4. WICHTIGER HINWEIS -->
  <section class="hinweis">
    <div class="hinweis-inner">
      <h2>KI berät nicht – sie organisiert.</h2>
      <p>Wir ersetzen keine rechtliche oder steuerliche Beratung. KI übernimmt die Verwaltung und Organisation – damit du mehr Zeit für echte Beratung hast.</p>
    </div>
  </section>

  <!-- 5. FÜR WEN DAS PASST -->
  <section class="fuer-wen">
    <div class="fuer-wen-inner">
      <h2>Für wen das passt.</h2>
      <div class="fuer-wen-grid">
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">⚖️</span>
          <p>Rechtsanwaltskanzleien</p>
        </div>
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">🧾</span>
          <p>Steuerberatungsbüros</p>
        </div>
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">📋</span>
          <p>Notariate &amp; Wirtschaftsprüfer</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <Cta />

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-telefonassistent" class="ai-karte">
          <span class="ai-icon">📞</span>
          <span class="ai-titel">KI-Telefonassistent</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-email" class="ai-karte">
          <span class="ai-icon">✉️</span>
          <span class="ai-titel">E-Mail-Automatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-fuer-kanzleien" class="ai-karte">
          <span class="ai-icon">📖</span>
          <span class="ai-titel">Ratgeber: KI für Kanzleien</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Was KI macht */
  .was-ki-macht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-macht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ki-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .ki-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .ki-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* SEO Subline */
  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  /* Use Cases */
  .use-cases {
    background: var(--surface);
    padding: 5rem 0;
  }

  .uc-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .use-cases h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .uc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .uc-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .uc-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .uc-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.35rem;
  }

  .uc-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Zeitrechner */
  .zeitrechner {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .zr-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .zr-content h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: white;
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .zr-slider-group {
    margin-bottom: 2rem;
  }

  .zr-slider-group label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.75rem;
  }

  .zr-val {
    font-weight: 700;
    font-size: 1rem;
    color: var(--primary-fixed);
  }

  .zr-range {
    width: 100%;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.2);
    outline: none;
    cursor: pointer;
  }

  .zr-range::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .zr-range-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.35rem;
  }

  .zr-ergebnis {
    display: flex;
    justify-content: center;
  }

  .zr-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    text-align: center;
    width: 100%;
  }

  .zr-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.35rem;
  }

  .zr-woche {
    font-family: 'Noto Serif', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--primary-fixed);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .zr-jahr {
    font-family: 'Noto Serif', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .zr-frage {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .zr-hinweis {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* KI nicht */
  .ki-nicht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .kn-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-nicht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .kn-text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .kn-punkte {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kn-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .kn-dash {
    font-size: 1.25rem;
    color: var(--secondary);
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .kn-punkt p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--on-surface);
  }

  /* Demo */
  .demo-section {
    background: var(--surface);
    padding: 0;
  }

  .demo-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Hinweis */
  .hinweis {
    background: var(--primary);
    padding: 5rem 0;
    text-align: center;
    color: white;
  }

  .hinweis-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hinweis h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: white;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .hinweis p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Für wen */
  .fuer-wen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .fuer-wen-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .fuer-wen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.3;
  }

  .fuer-wen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .fuer-wen-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .fw-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .fuer-wen-karte p {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--on-surface);
    line-height: 1.4;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid {
      grid-template-columns: 1fr;
    }

    .uc-grid {
      grid-template-columns: 1fr;
    }

    .zr-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .fuer-wen-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style>
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
  }

  .ai-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ai-inner h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--on-surface);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    flex: 1;
    line-height: 1.3;
  }

  .ai-arrow {
    font-size: 1rem;
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .ai-karte:hover .ai-arrow {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function updateZeitrechner() {
    const anfragen = parseInt((document.getElementById('anfragen') as HTMLInputElement).value, 10);
    const minuten = parseInt((document.getElementById('minuten') as HTMLInputElement).value, 10);

    const stunden_woche = Math.round((anfragen * minuten) / 60 * 10) / 10;
    const stunden_jahr = Math.round(stunden_woche * 52 * 10) / 10;

    (document.getElementById('anfragen-val') as HTMLElement).textContent = String(anfragen);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-woche') as HTMLElement).textContent = String(stunden_woche);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(stunden_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + stunden_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('anfragen')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>
