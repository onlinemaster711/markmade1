---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI für Unternehmen | MarkMade"
  description="KI macht Menschen effektiver – sie übernimmt die Zuarbeit damit du dich auf das Wesentliche konzentrieren kannst. Für kleine und mittelständische Unternehmen."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI für kleine &amp; mittelständische Unternehmen</p>
      <h1>KI macht Menschen effektiver. Nicht überflüssig.</h1>
      <p class="hero-text">
        KI übernimmt die Zuarbeit – Anfragen beantworten, Termine buchen, Texte erstellen, Prozesse automatisieren. Du konzentrierst dich auf das was wirklich zählt: dein Handwerk, deine Kunden, dein Betrieb.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. WAS KI ÜBERNIMMT -->
  <section class="was-ki">
    <div class="was-ki-inner">
      <p class="section-eyebrow">Was KI für dich erledigt</p>
      <h2>Die Zuarbeit die täglich Zeit kostet.</h2>
      <p class="section-text">KI übernimmt die wiederkehrenden Aufgaben – damit du mehr Zeit für das hast was wirklich wichtig ist.</p>
      <div class="ki-grid">

        <a href="/ki-telefonassistent" class="ki-karte fade-in">
          <span class="ki-icon">📞</span>
          <h3>Anrufe &amp; Anfragen</h3>
          <p>Telefonassistent nimmt Anrufe entgegen, beantwortet Fragen und bucht Termine – rund um die Uhr.</p>
        </a>

        <a href="/ki-email" class="ki-karte fade-in">
          <span class="ki-icon">✉️</span>
          <h3>E-Mail-Kommunikation</h3>
          <p>Standardanfragen automatisch beantworten, weiterleiten und priorisieren.</p>
        </a>

        <a href="/terminbuchung-handwerk" class="ki-karte fade-in">
          <span class="ki-icon">📅</span>
          <h3>Terminbuchung</h3>
          <p>Kunden buchen direkt in deinen Kalender – kein Hin-und-Her mehr.</p>
        </a>

        <a href="/ki-social-media" class="ki-karte fade-in">
          <span class="ki-icon">📱</span>
          <h3>Social Media</h3>
          <p>Posts, Skripte und Kampagnen – KI erstellt den Content, du genehmigst.</p>
        </a>

        <a href="/ki-automatisierung" class="ki-karte fade-in">
          <span class="ki-icon">⚙️</span>
          <h3>Prozesse automatisieren</h3>
          <p>Wiederkehrende Aufgaben die täglich Zeit kosten – KI übernimmt sie.</p>
        </a>

        <a href="/webdesign-selbststaendige" class="ki-karte fade-in">
          <span class="ki-icon">🌐</span>
          <h3>Website &amp; Chatbot</h3>
          <p>Professionelle Website mit Chatbot der Kundenfragen automatisch beantwortet.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- 3. DER WICHTIGSTE GRUNDSATZ -->
  <section class="grundsatz">
    <div class="grundsatz-inner">
      <h2>KI ersetzt keine guten Menschen. Sie macht sie besser.</h2>
      <ul class="grundsatz-liste">
        <li>Ein guter Handwerker mit KI schafft mehr als ohne – weil er weniger Zeit mit Verwaltung verbringt.</li>
        <li>Ein guter Arzt mit KI hat mehr Zeit für Patienten – weil Routineaufgaben automatisch laufen.</li>
        <li>Ein guter Makler mit KI macht mehr Abschlüsse – weil er sich auf Beratung konzentriert statt Papierkram.</li>
      </ul>
      <p class="grundsatz-abschluss"><em>KI ist dein effizientester Mitarbeiter – der nie krank wird, nie schläft und immer antwortet.</em></p>
    </div>
  </section>

  <!-- 4. BRANCHEN -->
  <section class="branchen">
    <div class="branchen-inner">
      <p class="section-eyebrow">Für wen wir arbeiten</p>
      <h2>Jede Branche profitiert anders.</h2>
      <div class="branchen-grid">

        <a href="/webdesign-handwerker" class="branchen-karte fade-in">
          <span class="branchen-icon">🔧</span>
          <h3>Handwerker &amp; Betriebe</h3>
          <p>Terminbuchung, Anfragefilterung, Chatbot</p>
        </a>

        <a href="/webdesign-aerzte" class="branchen-karte fade-in">
          <span class="branchen-icon">🏥</span>
          <h3>Ärzte &amp; Praxen</h3>
          <p>Patientenkommunikation, Terminbuchung, Chatbot</p>
        </a>

        <a href="/ki-restaurant" class="branchen-karte fade-in">
          <span class="branchen-icon">🍕</span>
          <h3>Restaurants &amp; Gastronomie</h3>
          <p>Reservierungen, Speisekarten, Gästeanfragen</p>
        </a>

        <a href="/ki-immobilienmakler" class="branchen-karte fade-in">
          <span class="branchen-icon">🏠</span>
          <h3>Immobilienmakler</h3>
          <p>Exposés, Anfragen vorqualifizieren, Besichtigungen</p>
        </a>

        <a href="/ki-kanzlei" class="branchen-karte fade-in">
          <span class="branchen-icon">⚖️</span>
          <h3>Kanzleien &amp; Steuerberater</h3>
          <p>Mandantenanfragen, Termine, Standardschreiben</p>
        </a>

        <a href="/webdesign-selbststaendige" class="branchen-karte fade-in">
          <span class="branchen-icon">💼</span>
          <h3>Selbstständige &amp; Coaches</h3>
          <p>Website, Chatbot, Social Media, E-Mail</p>
        </a>

      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Was dich vielleicht noch beschäftigt.</h2>
      <div class="faq-grid">

        <div class="faq-item fade-in">
          <h3>Was kostet KI für mein Unternehmen?</h3>
          <p>Das hängt von der Lösung ab. Eine Website mit Chatbot kostet 1.000 € inkl. MwSt. – einmal bezahlt, kein Abo. Andere Lösungen besprechen wir im kostenlosen Erstgespräch.</p>
        </div>

        <div class="faq-item fade-in">
          <h3>Brauche ich technisches Wissen?</h3>
          <p>Nein. Du erzählst uns was du brauchst – wir bauen alles. Du musst nichts installieren, nichts einrichten, nichts verstehen.</p>
        </div>

        <div class="faq-item fade-in">
          <h3>Wie schnell ist das umgesetzt?</h3>
          <p>Die meisten Lösungen sind in wenigen Tagen live. Keine monatelangen Projekte, keine endlosen Meetings.</p>
        </div>

        <div class="faq-item fade-in">
          <h3>Gibt es monatliche Kosten?</h3>
          <p>Nein – das ist unser wichtigster Unterschied. Du bezahlst einmal und behältst die Lösung. Kein Abo, kein Lock-in.</p>
        </div>

        <div class="faq-item fade-in">
          <h3>Was wenn mir das Ergebnis nicht gefällt?</h3>
          <p>Du siehst alles bevor du zahlst. Entwurf zuerst – dann entscheidest du. Kein Risiko, kein Vertrag vorher.</p>
        </div>

        <div class="faq-item fade-in">
          <h3>Kann KI wirklich meinen Betrieb verstehen?</h3>
          <p>KI kennt deinen Betrieb nicht – wir schon. Wir konfigurieren jede Lösung individuell auf dich. KI ist das Werkzeug, wir sind die Handwerker.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Section shared */
  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .section-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    max-width: 54ch;
    margin-bottom: 3rem;
  }

  /* Was KI macht */
  .was-ki {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .ki-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .ki-karte:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .ki-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .ki-karte p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Grundsatz */
  .grundsatz {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .grundsatz-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grundsatz h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: white;
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .grundsatz-liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .grundsatz-liste li {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    padding-left: 1.5rem;
    position: relative;
  }

  .grundsatz-liste li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.5);
  }

  .grundsatz-abschluss {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 1.5rem;
  }

  /* Branchen */
  .branchen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .branchen-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .branchen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .branchen-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .branchen-karte:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .branchen-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .branchen-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .branchen-karte p {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--on-surface-muted);
  }

  /* FAQ */
  .faq {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .faq-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .faq h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .faq-item {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
  }

  .faq-item h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .faq-item p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .ki-grid,
    .branchen-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid,
    .branchen-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
