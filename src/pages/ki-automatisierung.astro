---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI Automatisierung für KMU – Prozesse automatisieren | MarkMade"
  description="KI automatisiert wiederkehrende Aufgaben in kleinen und mittelständischen Betrieben. Weniger Papierkram, weniger manuelle Arbeit, mehr Zeit für das Wesentliche."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI-Automatisierung für KMU</p>
      <h1>Weniger Papierkram.<br />Mehr Zeit für dein Handwerk.</h1>
      <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.0625rem; font-weight: 500; color: var(--on-surface-muted); line-height: 1.5; margin-bottom: 1.5rem;">KI-Automatisierung für KMU und Handwerksbetriebe</h2>
      <p class="hero-text">
        Wiederkehrende Aufgaben kosten täglich wertvolle Zeit. KI übernimmt was immer gleich ist – damit du dich auf das konzentrierst was wirklich wichtig ist.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. WAS AUTOMATISIERT WERDEN KANN -->
  <section class="was-ki-kann">
    <div class="was-ki-inner">
      <h2>Was KI in deinem Betrieb übernehmen kann.</h2>
      <div class="ki-grid">

        <div class="ki-karte fade-in">
          <span class="ki-icon">📧</span>
          <h3>E-Mail-Antworten</h3>
          <p>Standardanfragen automatisch beantworten – ohne dass du jeden Morgen das Postfach leeren musst.</p>
        </div>

        <div class="ki-karte fade-in">
          <span class="ki-icon">📅</span>
          <h3>Terminbuchung</h3>
          <p>Kunden buchen direkt in deinen Kalender – kein Telefonieren, kein Hin-und-Her.</p>
        </div>

        <div class="ki-karte fade-in">
          <span class="ki-icon">📄</span>
          <h3>Angebote erstellen</h3>
          <p>Vorlagen automatisch befüllen – du prüfst kurz und schickst ab. Fertig.</p>
        </div>

        <div class="ki-karte fade-in">
          <span class="ki-icon">💬</span>
          <h3>Kundenkommunikation</h3>
          <p>Chatbot beantwortet Fragen rund um die Uhr – auch abends, auch am Wochenende.</p>
        </div>

        <div class="ki-karte fade-in">
          <span class="ki-icon">📊</span>
          <h3>Auswertungen</h3>
          <p>Kennzahlen automatisch zusammenfassen – du siehst auf einen Blick wie es läuft.</p>
        </div>

        <div class="ki-karte fade-in">
          <span class="ki-icon">🔔</span>
          <h3>Erinnerungen</h3>
          <p>Kunden automatisch an Termine erinnern – weniger No-Shows, weniger Aufwand.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. WICHTIGER HINWEIS -->
  <section class="hinweis">
    <div class="hinweis-inner">
      <h2>KI automatisiert – du entscheidest.</h2>
      <p>Wir automatisieren nur was wirklich Sinn ergibt. Kein blindes Delegieren an Maschinen. Jede Lösung wird mit dir abgestimmt und kann jederzeit angepasst werden.</p>
    </div>
  </section>

  <!-- 4. FÜR WEN DAS PASST -->
  <section class="beispiele">
    <div class="beispiele-inner">
      <h2>Konkrete Beispiele aus der Praxis.</h2>
      <div class="beispiele-grid">

        <div class="beispiel-karte fade-in">
          <p class="branche">🔧 Handwerksbetrieb</p>
          <h3>Terminbuchung + Anfragefilterung</h3>
          <p>Kunden buchen direkt, unpassende Anfragen werden automatisch aussortiert. Der Handwerker sieht nur was wirklich passt.</p>
        </div>

        <div class="beispiel-karte fade-in">
          <p class="branche">🏥 Arztpraxis</p>
          <h3>Patientenkommunikation + Terminreminder</h3>
          <p>Patienten bekommen automatische Antworten auf Standardfragen und werden einen Tag vorher an ihren Termin erinnert.</p>
        </div>

        <div class="beispiel-karte fade-in">
          <p class="branche">💼 Selbstständige</p>
          <h3>E-Mail-Automatisierung + Content-Erstellung</h3>
          <p>Anfragen werden automatisch beantwortet, Social-Media-Posts werden wöchentlich von KI vorbereitet und zur Freigabe vorgelegt.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. ZEITRECHNER -->
  <section class="zeitrechner">
    <div class="zr-inner">
      <div class="zr-content">
        <h2>Wie viel Zeit kostet dich Verwaltung gerade wirklich?</h2>

        <div class="zr-slider-group">
          <label for="aufgaben">
            Wie viele wiederkehrende Aufgaben erledigst du pro Tag?
            <span class="zr-val" id="aufgaben-val">5</span>
          </label>
          <input type="range" id="aufgaben" min="1" max="20" value="5" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>1</span><span>20</span></div>
        </div>

        <div class="zr-slider-group">
          <label for="minuten">
            Wie lange dauert eine solche Aufgabe?
            <span class="zr-val" id="minuten-val">20 Min</span>
          </label>
          <input type="range" id="minuten" min="5" max="60" value="20" step="5" class="zr-range" />
          <div class="zr-range-labels"><span>5 Min</span><span>60 Min</span></div>
        </div>
      </div>

      <div class="zr-ergebnis">
        <div class="zr-box">
          <p class="zr-label">Minuten pro Tag</p>
          <p class="zr-tag" id="zr-tag">100</p>
          <p class="zr-label">Stunden pro Monat</p>
          <p class="zr-monat" id="zr-monat">33</p>
          <p class="zr-label">Stunden pro Jahr</p>
          <p class="zr-jahr" id="zr-jahr">400</p>
          <p class="zr-frage" id="zr-frage">Was machst du mit 400 Stunden mehr im Jahr?</p>
          <p class="zr-hinweis">Das sind keine Versprechen. Das ist Mathematik.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WAS KI NICHT KANN -->
  <section class="ki-nicht">
    <div class="kn-inner">
      <h2>Was KI nicht ersetzt.</h2>
      <p class="kn-text">KI kann keine Entscheidungen treffen die Erfahrung und Urteilsvermögen erfordern. Sie kann nicht einschätzen ob ein Kunde gerade verärgert ist oder ob eine Situation Fingerspitzengefühl braucht. Aber sie übernimmt was immer gleich ist – damit du dich auf das konzentrierst was wirklich deinen Einsatz erfordert.</p>
      <div class="kn-punkte">
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Entscheidungen triffst du</strong> – KI bereitet sie vor</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Kundenbeziehungen pflegst du</strong> – KI gibt dir mehr Zeit dafür</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Dein Betrieb bleibt unter deiner Kontrolle</strong> – KI wird von dir konfiguriert und kann jederzeit angepasst werden</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-telefonassistent" class="ai-karte">
          <span class="ai-icon">📞</span>
          <span class="ai-titel">KI-Telefonassistent</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-email" class="ai-karte">
          <span class="ai-icon">✉️</span>
          <span class="ai-titel">E-Mail-Automatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-fuer-unternehmen" class="ai-karte">
          <span class="ai-icon">💬</span>
          <span class="ai-titel">KI-Chatbot &amp; Übersicht</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. CTA -->
  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Was KI kann */
  .was-ki-kann {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-kann h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
    text-align: center;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .ki-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .ki-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .ki-karte p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Hinweis */
  .hinweis {
    background: var(--primary);
    padding: 5rem 0;
    text-align: center;
    color: white;
  }

  .hinweis-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hinweis h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: white;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .hinweis p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Beispiele */
  .beispiele {
    background: var(--surface);
    padding: 5rem 0;
  }

  .beispiele-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .beispiele h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
    text-align: center;
  }

  .beispiele-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .beispiel-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .branche {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
  }

  .beispiel-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .beispiel-karte p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Zeitrechner */
  .zeitrechner {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .zr-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .zeitrechner h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.875rem);
    color: white;
    margin-bottom: 2rem;
    line-height: 1.3;
  }

  .zr-slider-group {
    margin-bottom: 2rem;
  }

  .zr-slider-group label {
    display: flex;
    justify-content: space-between;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .zr-val {
    font-weight: 700;
    color: white;
  }

  .zr-range {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.25);
    outline: none;
  }

  .zr-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed, #e8ecd4);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .zr-range::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed, #e8ecd4);
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .zr-range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.375rem;
  }

  .zr-ergebnis {
    display: flex;
    justify-content: center;
  }

  .zr-box {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1.25rem;
    padding: 2rem 2.25rem;
    width: 100%;
    max-width: 320px;
  }

  .zr-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.25rem;
  }

  .zr-tag, .zr-monat, .zr-jahr {
    font-family: 'Noto Serif', serif;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .zr-frage {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--primary-fixed, #e8ecd4);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .zr-hinweis {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* Was KI nicht kann */
  .ki-nicht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .kn-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-nicht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.25;
  }

  .kn-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .kn-punkte {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .kn-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .kn-dash {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--secondary);
    flex-shrink: 0;
    line-height: 1.6;
  }

  .kn-punkt p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Auch interessant */
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .ai-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .auch-interessant h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--on-surface);
    flex: 1;
    line-height: 1.35;
  }

  .ai-arrow {
    font-size: 0.875rem;
    color: var(--secondary);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .ki-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid,
    .beispiele-grid {
      grid-template-columns: 1fr;
    }

    .zr-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .zr-box {
      max-width: 100%;
    }

    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function updateZeitrechner() {
    const aufgabenEl = document.getElementById('aufgaben') as HTMLInputElement;
    const minutenEl = document.getElementById('minuten') as HTMLInputElement;
    if (!aufgabenEl || !minutenEl) return;

    const aufgaben = parseInt(aufgabenEl.value, 10);
    const minuten = parseInt(minutenEl.value, 10);

    const min_tag = aufgaben * minuten;
    const std_monat = Math.round((min_tag * 22) / 60 * 10) / 10;
    const std_jahr = Math.round((min_tag * 260) / 60 * 10) / 10;

    (document.getElementById('aufgaben-val') as HTMLElement).textContent = String(aufgaben);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-tag') as HTMLElement).textContent = String(min_tag);
    (document.getElementById('zr-monat') as HTMLElement).textContent = String(std_monat);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(std_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + std_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('aufgaben')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>
