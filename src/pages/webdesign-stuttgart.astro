---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="Webdesign Stuttgart – professionelle Website ab 1.000 € | MarkMade"
  description="Webdesign für Stuttgarter Betriebe und Selbstständige – professionelle Website ab 1.000 € inkl. MwSt., Festpreis, Entwurf kostenlos. Kein Auftrag ohne Entwurf."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Webdesign · Stuttgart</p>
      <h1>Professionelle Website für Stuttgarter Betriebe.</h1>
      <h2 class="seo-subline">Webdesign Stuttgart – ab 1.000 € inkl. MwSt., Festpreis, Entwurf zuerst</h2>
      <p class="hero-text">
        Wir bauen Websites die klar kommunizieren wer du bist – und warum jemand genau dich kontaktieren sollte. Für Handwerker, Ärzte, Selbstständige und Dienstleister in Stuttgart und der Region.
      </p>
      <div class="hero-buttons">
        <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenlosen Entwurf sichern</a>
        <a href="#leistungen" class="btn-secondary">Leistungen ansehen</a>
      </div>
      <ul class="hero-haekchen">
        <li><span class="haekchen">✓</span> Entwurf kostenlos – kein Auftrag nötig</li>
        <li><span class="haekchen">✓</span> Festpreis – keine Überraschungen</li>
        <li><span class="haekchen">✓</span> In 1–2 Wochen online</li>
      </ul>
    </div>
  </section>

  <!-- 2. WARUM WEBSITES NICHT FUNKTIONIEREN -->
  <section class="warum">
    <div class="warum-inner">
      <h2>Warum viele Websites keine Kunden bringen.</h2>
      <p class="warum-text">Eine schöne Website die nichts erklärt bringt keine Anfragen. Die meisten Websites in Stuttgart beantworten die wichtigsten Fragen nicht: Was macht der Betrieb? Für wen? Was kostet es? Wie läuft es ab?</p>
      <div class="warum-punkte">
        <div class="warum-punkt">
          <span class="warum-icon">🎯</span>
          <div>
            <h3>Unklare Botschaft</h3>
            <p>Besucher verstehen nicht sofort was du anbietest.</p>
          </div>
        </div>
        <div class="warum-punkt">
          <span class="warum-icon">👥</span>
          <div>
            <h3>Falsche Zielgruppe</h3>
            <p>Die Website spricht alle an und erreicht niemanden.</p>
          </div>
        </div>
        <div class="warum-punkt">
          <span class="warum-icon">❓</span>
          <div>
            <h3>Offene Fragen</h3>
            <p>Preise, Ablauf, Kontakt – zu versteckt oder fehlend.</p>
          </div>
        </div>
        <div class="warum-punkt">
          <span class="warum-icon">🚫</span>
          <div>
            <h3>Kein nächster Schritt</h3>
            <p>Der Besucher weiß nicht was er tun soll.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. LEISTUNGEN -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">
      <h2>Was wir für dich bauen</h2>
      <div class="preis-grid">

        <!-- Karte 1: normal -->
        <div class="preis-karte">
          <h3 class="preis-titel">Website</h3>
          <p class="preis-preis">1.000 € inkl. MwSt. · Festpreis</p>
          <ul class="preis-liste">
            <li>Strategie &amp; Texte</li>
            <li>Design &amp; Technik</li>
            <li>Google-Optimierung</li>
            <li>Mobil &amp; schnell</li>
            <li>Entwurf zuerst – du entscheidest</li>
          </ul>
          <a href="https://calendly.com/onlinemaster711/new-meeting" class="preis-btn" target="_blank" rel="noopener noreferrer">Kostenlosen Entwurf sichern</a>
        </div>

        <!-- Karte 2: featured -->
        <div class="preis-karte preis-featured">
          <span class="preis-badge">Empfohlen</span>
          <h3 class="preis-titel">Website &amp; Chatbot</h3>
          <p class="preis-preis">1.500 € inkl. MwSt. · Festpreis</p>
          <ul class="preis-liste">
            <li>Alles aus Paket 1</li>
            <li>KI-Chatbot individuell konfiguriert</li>
            <li>Beantwortet Kundenfragen 24/7</li>
            <li>Nur passende Anfragen kommen durch</li>
            <li>Kalender-Buchung optional</li>
          </ul>
          <a href="https://calendly.com/onlinemaster711/new-meeting" class="preis-btn preis-btn-featured" target="_blank" rel="noopener noreferrer">Kostenlosen Entwurf sichern</a>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. REFERENZ -->
  <section class="referenz">
    <div class="ref-inner">
      <div class="ref-zitat-block">
        <blockquote class="ref-zitat">
          „Ich hatte vorher keine Seite die wirklich zu mir gepasst hat. Jetzt finden mich Patienten bei Google – und melden sich direkt."
        </blockquote>
        <p class="ref-name">Elke Reinke · Osteopathin · Stuttgart Degerloch</p>
        <a href="https://osteopath-stuttgart.com" class="ref-link" target="_blank" rel="noopener noreferrer">osteopath-stuttgart.com ansehen →</a>
      </div>
      <div class="ref-bild-block">
        <img src="/elke-reinke-screenshot.webp" alt="Website von Elke Reinke – Osteopathin Stuttgart" class="ref-bild" loading="lazy" width="600" height="400" />
      </div>
    </div>
  </section>

  <!-- 5. PROZESS -->
  <section class="prozess">
    <div class="prozess-inner">
      <h2>3 Schritte – du machst fast nichts.</h2>
      <div class="schritte-grid">
        <div class="schritt">
          <div class="schritt-nr">1</div>
          <h3>10 Minuten Gespräch</h3>
          <p>Du erzählst was du machst, für wen – und was dich unterscheidet.</p>
        </div>
        <div class="schritt">
          <div class="schritt-nr">2</div>
          <h3>Wir bauen deinen Entwurf</h3>
          <p>Kostenlos. Mit Texten, Struktur und Design. Kein Template.</p>
        </div>
        <div class="schritt">
          <div class="schritt-nr">3</div>
          <h3>Du entscheidest – ohne Risiko</h3>
          <p>Gefällt er dir, geht deine Seite online. Gefällt er nicht – kein Cent fällig.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/chatbot-stuttgart" class="ai-karte">
          <span class="ai-icon">💬</span>
          <span class="ai-titel">Chatbot Stuttgart</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-agentur-stuttgart" class="ai-karte">
          <span class="ai-icon">🏙️</span>
          <span class="ai-titel">KI-Agentur Stuttgart</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-fuer-selbststaendige" class="ai-karte">
          <span class="ai-icon">📖</span>
          <span class="ai-titel">Ratgeber: KI für Selbstständige</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <Cta />

  <!-- 7. FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Was dich vielleicht noch beschäftigt</h2>

      <div class="faq-item">
        <h3>Macht ihr nur Webdesign in Stuttgart?</h3>
        <p>Hauptsächlich ja – wir kennen den lokalen Markt und haben Referenzen aus Stuttgart. Wir arbeiten aber auch mit Betrieben aus der gesamten Region.</p>
      </div>

      <div class="faq-item">
        <h3>Was kostet eine Website?</h3>
        <p>Die Website kostet 1.000 € inkl. MwSt. – Festpreis, alles inklusive. Der Chatbot optional dazu für 500 €. Der Entwurf ist kostenlos.</p>
      </div>

      <div class="faq-item">
        <h3>Wie lange dauert das?</h3>
        <p>In der Regel 1–2 Wochen nach dem Erstgespräch. Kein monatelanges Projekt.</p>
      </div>

      <div class="faq-item">
        <h3>Was wenn mir der Entwurf nicht gefällt?</h3>
        <p>Dann zahlst du nichts. Kein Vertrag, keine Rechnung. Du entscheidest erst wenn du siehst was du bekommst.</p>
      </div>

      <div class="faq-item faq-item--last">
        <h3>Für welche Branchen macht ihr Websites in Stuttgart?</h3>
        <p>Handwerker, Ärzte, Selbstständige, Coaches, Restaurants, Kanzleien – jeder Betrieb der klar kommunizieren will was er anbietet.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1rem;
  }

  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: white;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  .btn-secondary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: var(--on-surface);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    border: 1.5px solid var(--outline-variant);
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .hero-haekchen {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
  }

  .hero-haekchen li {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .haekchen {
    color: #34d399;
    font-weight: 700;
  }

  /* Warum */
  .warum {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .warum-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .warum h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 1.25rem;
    line-height: 1.25;
  }

  .warum-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--on-surface-muted);
    margin-bottom: 2.5rem;
  }

  .warum-punkte {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem 2.5rem;
  }

  .warum-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .warum-icon {
    font-size: 1.625rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .warum-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.3rem;
  }

  .warum-punkt p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Leistungen / Preise */
  .leistungen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .leistungen-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .leistungen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
    text-align: center;
  }

  .preis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .preis-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1.25rem;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .preis-featured {
    background: var(--primary);
    border-color: var(--primary);
    margin-top: -24px;
    position: relative;
  }

  .preis-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--secondary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    align-self: flex-start;
  }

  .preis-titel {
    font-family: 'Noto Serif', serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0;
  }

  .preis-featured .preis-titel {
    color: white;
  }

  .preis-preis {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    margin: 0;
  }

  .preis-featured .preis-preis {
    color: rgba(255, 255, 255, 0.75);
  }

  .preis-liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .preis-liste li {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .preis-liste li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #34d399;
    font-weight: 700;
  }

  .preis-featured .preis-liste li {
    color: rgba(255, 255, 255, 0.85);
  }

  .preis-featured .preis-liste li::before {
    color: #6ee7b7;
  }

  .preis-btn {
    display: block;
    text-align: center;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.875rem;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .preis-btn:hover { opacity: 0.88; }

  .preis-btn-featured {
    background: white;
    color: var(--primary);
  }

  .preis-btn-featured:hover { opacity: 0.92; }

  /* Referenz */
  .referenz {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .ref-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .ref-zitat {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.6;
    color: var(--on-surface);
    font-style: italic;
    margin: 0 0 1.25rem;
    border: none;
    padding: 0;
  }

  .ref-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface-muted);
    margin-bottom: 1rem;
  }

  .ref-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ref-link:hover { opacity: 0.75; }

  .ref-bild {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: block;
  }

  /* Prozess */
  .prozess {
    background: var(--surface);
    padding: 5rem 0;
  }

  .prozess-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .prozess h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
    text-align: center;
  }

  .schritte-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    position: relative;
  }

  .schritte-grid::before {
    content: '';
    position: absolute;
    top: 2.5rem;
    left: calc(16.67% + 1.5rem);
    right: calc(16.67% + 1.5rem);
    height: 1px;
    background: var(--outline-variant);
  }

  .schritt {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .schritt-nr {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: white;
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(184, 0, 73, 0.25);
  }

  .schritt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .schritt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Auch interessant */
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .ai-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .auch-interessant h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .ai-karte:hover { border-color: var(--secondary); }

  .ai-icon { font-size: 1.25rem; flex-shrink: 0; }
  .ai-titel { font-size: 0.9rem; font-weight: 600; color: var(--on-surface); flex: 1; line-height: 1.35; }
  .ai-arrow { font-size: 0.875rem; color: var(--secondary); flex-shrink: 0; }

  /* FAQ */
  .faq {
    background: var(--surface-low);
    padding: 5rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .faq-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .faq h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .faq-item {
    padding: 1.75rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .faq-item--last {
    border-bottom: 1px solid var(--outline-variant);
  }

  .faq-item h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
  }

  .faq-item p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .warum-punkte {
      grid-template-columns: 1fr;
    }

    .preis-grid {
      grid-template-columns: 1fr;
    }

    .preis-featured {
      margin-top: 0;
    }

    .ref-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ref-bild-block {
      order: -1;
    }

    .schritte-grid {
      grid-template-columns: 1fr;
    }

    .schritte-grid::before {
      display: none;
    }

    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
