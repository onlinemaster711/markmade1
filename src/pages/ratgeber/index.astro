---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
---

<BaseLayout
  title="Ratgeber – KI für kleine Betriebe | MarkMade"
  description="Konkrete Ratgeber-Artikel wie kleine und mittelständische Betriebe KI sinnvoll einsetzen – für Handwerker, Ärzte, Restaurants, Kanzleien und Immobilienmakler."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Ratgeber</p>
      <h1>KI verstehen. Richtig einsetzen.</h1>
      <p class="hero-text">Keine Tool-Listen. Keine Versprechen. Konkrete Artikel die zeigen wie kleine Betriebe KI wirklich nutzen – und wo sie anfangen sollten.</p>
    </div>
  </section>

  <!-- Artikel-Grid -->
  <section class="artikel-grid-section">
    <div class="grid-inner">
      <h2>Alle Ratgeber-Artikel</h2>
      <div class="karten-grid">

        <a href="/ratgeber/ki-im-unternehmen-nutzen" class="karte">
          <p class="karte-kategorie">Einstieg</p>
          <h3>KI im Unternehmen nutzen</h3>
          <p class="karte-text">Wie du KI in deinem Betrieb wirklich nutzt – die drei Fragen die du dir zuerst stellen solltest.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-handwerker" class="karte">
          <p class="karte-kategorie">Handwerk</p>
          <h3>KI für Handwerker</h3>
          <p class="karte-text">Was KI für Handwerksbetriebe konkret übernimmt – von Terminbuchung bis Angebotserstellung.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-aerzte" class="karte">
          <p class="karte-kategorie">Gesundheit</p>
          <h3>KI für Ärzte &amp; Praxen</h3>
          <p class="karte-text">Wie Arztpraxen mit KI Patientenkommunikation automatisieren und mehr Zeit für Behandlungen gewinnen.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-restaurants" class="karte">
          <p class="karte-kategorie">Gastronomie</p>
          <h3>KI für Restaurants</h3>
          <p class="karte-text">Reservierungen, Gästekommunikation, Bewertungen – was KI für Gastronomiebetriebe übernimmt.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-kanzleien" class="karte">
          <p class="karte-kategorie">Recht &amp; Steuern</p>
          <h3>KI für Kanzleien &amp; Steuerberater</h3>
          <p class="karte-text">Mandantenanfragen vorqualifizieren, Termine buchen, Standardschreiben vorbereiten – konkret erklärt.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-immobilienmakler" class="karte">
          <p class="karte-kategorie">Immobilien</p>
          <h3>KI für Immobilienmakler</h3>
          <p class="karte-text">Exposés schneller erstellen, Interessenten vorqualifizieren, Follow-ups automatisieren.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-selbststaendige" class="karte">
          <p class="karte-kategorie">Selbstständige</p>
          <h3>KI für Selbstständige &amp; Coaches</h3>
          <p class="karte-text">Wie Selbstständige mit KI mehr schaffen – Website, Chatbot, E-Mail und Social Media auf Autopilot.</p>
          <span class="karte-link">Artikel lesen →</span>
        </a>

      </div>
    </div>
  </section>

  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--primary);
    padding: 9rem 1.5rem 5rem;
    text-align: center;
    color: white;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: white;
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    max-width: 54ch;
    margin: 0 auto;
  }

  /* Artikel-Grid */
  .artikel-grid-section {
    background: var(--surface);
    padding: 5rem 1.5rem;
  }

  .grid-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .karten-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .karte {
    display: flex;
    flex-direction: column;
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1.25rem;
    padding: 2rem 1.75rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .karte:hover {
    border-color: var(--secondary);
    transform: translateY(-2px);
  }

  .karte-kategorie {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .karte-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--on-surface-muted);
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .karte-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    transition: opacity 0.2s;
  }

  .karte:hover .karte-link {
    opacity: 0.75;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .karten-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 6.5rem;
    }

    .karten-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
