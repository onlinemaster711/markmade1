---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="Social Media mit KI | MarkMade"
  description="KI erstellt Social Media Posts, Skripte und Kampagnen für deinen Betrieb. Du genehmigst – wir liefern. Für kleine und mittelständische Unternehmen."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Social Media mit KI</p>
      <h1>Mehr Präsenz. Weniger Aufwand.</h1>
      <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.0625rem; font-weight: 500; color: var(--on-surface-muted); line-height: 1.5; margin-bottom: 1.5rem;">Social Media Inhalte mit KI erstellen</h2>
      <p class="hero-text">
        KI erstellt Posts, Skripte und Kampagnen die zu deinem Betrieb passen. Du genehmigst in Minuten was sonst Stunden dauert.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. WAS KI KONKRET MACHT -->
  <section class="was-ki-macht">
    <div class="was-ki-inner">
      <h2>Was KI konkret für dich übernimmt.</h2>
      <div class="ki-grid">
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📝</span>
          <div>
            <h3>Post-Texte</h3>
            <p>KI schreibt Beiträge für Instagram, Facebook und LinkedIn – in deiner Sprache, für deine Zielgruppe.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">🎬</span>
          <div>
            <h3>Video-Skripte</h3>
            <p>Strukturierte Skripte für Reels, TikTok und YouTube – damit du weißt was du sagen willst.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📅</span>
          <div>
            <h3>Redaktionsplan</h3>
            <p>KI plant Themen und Zeitpunkte automatisch – ein ganzer Monat auf einmal, fertig zum Posten.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">🎯</span>
          <div>
            <h3>Zielgruppen-Texte</h3>
            <p>Inhalte die genau deine Kunden ansprechen – nicht generisch, sondern auf deinen Betrieb zugeschnitten.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. ABLAUF -->
  <section class="ablauf">
    <div class="ablauf-inner">
      <h2>So funktioniert es in der Praxis.</h2>
      <div class="schritte-grid">
        <div class="schritt fade-in">
          <div class="schritt-nr">1</div>
          <h3>Du sagst was du machst</h3>
          <p>Ein kurzes Gespräch – wer du bist, wen du erreichen willst und was dir wichtig ist.</p>
        </div>
        <div class="schritt fade-in">
          <div class="schritt-nr">2</div>
          <h3>KI erstellt einen Monat Content</h3>
          <p>Posts, Skripte und Redaktionsplan – alles auf einmal, bereit zur Freigabe.</p>
        </div>
        <div class="schritt fade-in">
          <div class="schritt-nr">3</div>
          <h3>Du genehmigst, wir liefern</h3>
          <p>Wir veröffentlichen für dich oder liefern alles zur Weiterverwendung – wie du es willst.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. FÜR WEN -->
  <section class="fuer-wen">
    <div class="fuer-wen-inner">
      <h2>Für jeden der sichtbar sein will – ohne täglich Zeit zu verlieren.</h2>
      <ul class="fuer-wen-liste">
        <li><span class="haekchen">✓</span> Handwerker die Projekte zeigen wollen</li>
        <li><span class="haekchen">✓</span> Praxen die Vertrauen aufbauen wollen</li>
        <li><span class="haekchen">✓</span> Coaches die Expertise teilen wollen</li>
        <li><span class="haekchen">✓</span> Händler die Angebote bewerben wollen</li>
      </ul>
    </div>
  </section>

  <!-- 5. ZEITRECHNER -->
  <section class="zeitrechner">
    <div class="zr-inner">
      <div class="zr-content">
        <h2>Wie viel Zeit kostet dich Social Media gerade wirklich?</h2>

        <div class="zr-slider-group">
          <label for="posts">
            Wie viele Posts erstellst du pro Woche?
            <span class="zr-val" id="posts-val">4</span>
          </label>
          <input type="range" id="posts" min="1" max="14" value="4" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>1</span><span>14</span></div>
        </div>

        <div class="zr-slider-group">
          <label for="minuten">
            Wie lange brauchst du pro Post?
            <span class="zr-val" id="minuten-val">60 Min</span>
          </label>
          <input type="range" id="minuten" min="15" max="120" value="60" step="15" class="zr-range" />
          <div class="zr-range-labels"><span>15 Min</span><span>120 Min</span></div>
        </div>
      </div>

      <div class="zr-ergebnis">
        <div class="zr-box">
          <p class="zr-label">Minuten pro Woche</p>
          <p class="zr-woche" id="zr-woche">240</p>
          <p class="zr-label">Stunden pro Monat</p>
          <p class="zr-monat" id="zr-monat">16</p>
          <p class="zr-label">Stunden pro Jahr</p>
          <p class="zr-jahr" id="zr-jahr">192</p>
          <p class="zr-frage" id="zr-frage">Was machst du mit 192 Stunden mehr im Jahr?</p>
          <p class="zr-hinweis">Mit KI: unter 10 Minuten pro Post.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WAS KI NICHT KANN -->
  <section class="ki-nicht">
    <div class="kn-inner">
      <h2>Was KI nicht ersetzt.</h2>
      <p class="kn-text">KI kann keine echten Erlebnisse erfinden. Sie kann nicht deine Persönlichkeit ersetzen und kein Vertrauen aufbauen das durch echte Inhalte entsteht. Aber sie übernimmt die Produktion – damit du dich auf das konzentrierst was nur du liefern kannst: dein Wissen, deine Stimme, deine Arbeit.</p>
      <div class="kn-punkte">
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Deine Expertise kommt von dir</strong> – KI macht daraus Inhalte</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Deine Persönlichkeit ist unverwechselbar</strong> – KI passt sich deinem Stil an</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Echte Ergebnisse zeigst du</strong> – KI hilft dir sie zu kommunizieren</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-fuer-unternehmen" class="ai-karte">
          <span class="ai-icon">💬</span>
          <span class="ai-titel">KI-Chatbot &amp; Übersicht</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-automatisierung" class="ai-karte">
          <span class="ai-icon">⚙️</span>
          <span class="ai-titel">Prozessautomatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-fuer-selbststaendige" class="ai-karte">
          <span class="ai-icon">📖</span>
          <span class="ai-titel">Ratgeber: KI für Selbstständige</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Was KI macht */
  .was-ki-macht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-macht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ki-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .ki-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .ki-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Ablauf */
  .ablauf {
    background: var(--surface);
    padding: 5rem 0;
  }

  .ablauf-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ablauf h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
    text-align: center;
  }

  .schritte-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    position: relative;
  }

  .schritte-grid::before {
    content: '';
    position: absolute;
    top: 2.5rem;
    left: calc(16.67% + 1.5rem);
    right: calc(16.67% + 1.5rem);
    height: 1px;
    background: var(--outline-variant);
  }

  .schritt {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .schritt-nr {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(184, 0, 73, 0.25);
  }

  .schritt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
  }

  .schritt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Für wen */
  .fuer-wen {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .fuer-wen-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .fuer-wen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: white;
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .fuer-wen-liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
    max-width: 420px;
    margin: 0 auto;
  }

  .fuer-wen-liste li {
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .haekchen {
    color: #34d399;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Zeitrechner */
  .zeitrechner {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .zr-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .zeitrechner h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.875rem);
    color: white;
    margin-bottom: 2rem;
    line-height: 1.3;
  }

  .zr-slider-group {
    margin-bottom: 2rem;
  }

  .zr-slider-group label {
    display: flex;
    justify-content: space-between;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .zr-val {
    font-weight: 700;
    color: white;
  }

  .zr-range {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.25);
    outline: none;
  }

  .zr-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed, #e8ecd4);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .zr-range::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed, #e8ecd4);
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .zr-range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.375rem;
  }

  .zr-ergebnis {
    display: flex;
    justify-content: center;
  }

  .zr-box {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1.25rem;
    padding: 2rem 2.25rem;
    width: 100%;
    max-width: 320px;
  }

  .zr-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.25rem;
  }

  .zr-woche, .zr-monat, .zr-jahr {
    font-family: 'Noto Serif', serif;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .zr-frage {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--primary-fixed, #e8ecd4);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .zr-hinweis {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* Was KI nicht kann */
  .ki-nicht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .kn-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-nicht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.25;
  }

  .kn-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .kn-punkte {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .kn-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .kn-dash {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--secondary);
    flex-shrink: 0;
    line-height: 1.6;
  }

  .kn-punkt p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Auch interessant */
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .ai-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .auch-interessant h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--on-surface);
    flex: 1;
    line-height: 1.35;
  }

  .ai-arrow {
    font-size: 0.875rem;
    color: var(--secondary);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid {
      grid-template-columns: 1fr;
    }

    .schritte-grid {
      grid-template-columns: 1fr;
    }

    .schritte-grid::before {
      display: none;
    }

    .zr-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .zr-box {
      max-width: 100%;
    }

    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function updateZeitrechner() {
    const postsEl = document.getElementById('posts') as HTMLInputElement;
    const minutenEl = document.getElementById('minuten') as HTMLInputElement;
    if (!postsEl || !minutenEl) return;

    const posts = parseInt(postsEl.value, 10);
    const minuten = parseInt(minutenEl.value, 10);

    const min_woche = posts * minuten;
    const std_monat = Math.round((min_woche * 4) / 60 * 10) / 10;
    const std_jahr = Math.round((min_woche * 52) / 60 * 10) / 10;

    (document.getElementById('posts-val') as HTMLElement).textContent = String(posts);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-woche') as HTMLElement).textContent = String(min_woche);
    (document.getElementById('zr-monat') as HTMLElement).textContent = String(std_monat);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(std_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + std_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('posts')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>
