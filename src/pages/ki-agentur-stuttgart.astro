---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI-Agentur Stuttgart – Chatbots & Automatisierung für KMU | MarkMade"
  description="MarkMade ist deine KI-Agentur in Stuttgart. Wir bauen Chatbots, Websites und KI-Automatisierungen für kleine und mittelständische Betriebe – ab 1.000 € einmalig, kein Abo."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI-Agentur · Stuttgart</p>
      <h1>KI-Agentur Stuttgart – wir bauen was wirklich läuft.</h1>
      <h2 class="seo-subline">KI-Lösungen für kleine und mittelständische Betriebe in Stuttgart und der Region</h2>
      <p class="hero-text">
        MarkMade sitzt in Stuttgart und baut KI-Lösungen für Betriebe die Zeit sparen wollen. Chatbots, Websites, Telefonassistenten, E-Mail-Automatisierung – einmalig bezahlt, dauerhaft im Einsatz. Kein Abo, keine versteckten Kosten.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch buchen</a>
    </div>
  </section>

  <!-- 2. WARUM LOKAL -->
  <section class="warum-lokal">
    <div class="wl-inner">
      <h2>Warum eine KI-Agentur aus Stuttgart?</h2>
      <div class="wl-punkte">
        <div class="wl-punkt">
          <span class="wl-icon">📍</span>
          <div>
            <h3>Wir kennen den Markt</h3>
            <p>Stuttgart ist Mittelstand. Handwerker, Ärzte, Selbstständige, Dienstleister. Wir kennen die Branchen und bauen Lösungen die wirklich passen.</p>
          </div>
        </div>
        <div class="wl-punkt">
          <span class="wl-icon">🤝</span>
          <div>
            <h3>Persönlich erreichbar</h3>
            <p>Kein Ticket-System, kein Support-Chat. Du sprichst direkt mit uns.</p>
          </div>
        </div>
        <div class="wl-punkt">
          <span class="wl-icon">⚡</span>
          <div>
            <h3>Schnell umgesetzt</h3>
            <p>In 1–2 Wochen läuft deine erste KI-Lösung. Kein monatelanges Projekt.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. WAS WIR BAUEN -->
  <section class="was-wir-bauen">
    <div class="wwb-inner">
      <h2>Was wir für Stuttgarter Betriebe bauen</h2>
      <div class="wwb-grid">

        <a href="/ki-fuer-unternehmen" class="wwb-karte">
          <span class="wwb-icon">💬</span>
          <div>
            <h3>KI-Chatbot</h3>
            <p>Beantwortet Kundenfragen automatisch, rund um die Uhr.</p>
          </div>
        </a>

        <a href="/ki-telefonassistent" class="wwb-karte">
          <span class="wwb-icon">📞</span>
          <div>
            <h3>KI-Telefonassistent</h3>
            <p>Nimmt Anrufe an, klärt vor, bucht Termine.</p>
          </div>
        </a>

        <a href="/ki-email" class="wwb-karte">
          <span class="wwb-icon">✉️</span>
          <div>
            <h3>E-Mail-Automatisierung</h3>
            <p>Standardanfragen automatisch beantworten.</p>
          </div>
        </a>

        <a href="/webdesign-selbststaendige" class="wwb-karte">
          <span class="wwb-icon">🌐</span>
          <div>
            <h3>Website &amp; Chatbot</h3>
            <p>Professionelle Website ab 1.000 € inkl. MwSt.</p>
          </div>
        </a>

        <a href="/ki-social-media" class="wwb-karte">
          <span class="wwb-icon">📱</span>
          <div>
            <h3>Social Media mit KI</h3>
            <p>Sichtbar sein ohne täglich Zeit zu verlieren.</p>
          </div>
        </a>

        <a href="/ki-automatisierung" class="wwb-karte">
          <span class="wwb-icon">⚙️</span>
          <div>
            <h3>Prozessautomatisierung</h3>
            <p>Wiederkehrende Aufgaben laufen automatisch.</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- 4. REFERENZ -->
  <section class="referenz">
    <div class="ref-inner">
      <div class="ref-zitat-block">
        <blockquote class="ref-zitat">
          „Ich hatte vorher keine Seite die wirklich zu mir gepasst hat. Jetzt finden mich Patienten bei Google – und melden sich direkt."
        </blockquote>
        <p class="ref-name">Elke Reinke · Osteopathin · Stuttgart Degerloch</p>
        <a href="https://osteopath-stuttgart.com" class="ref-link" target="_blank" rel="noopener noreferrer">osteopath-stuttgart.com ansehen →</a>
      </div>
      <div class="ref-bild-block">
        <img src="/elke-reinke-screenshot.webp" alt="Website von Elke Reinke – Osteopathin Stuttgart" class="ref-bild" loading="lazy" width="600" height="400" />
      </div>
    </div>
  </section>

  <!-- 5. FÜR WEN -->
  <section class="fuer-wen">
    <div class="fw-inner">
      <h2>Für wen wir in Stuttgart arbeiten</h2>
      <ul class="fw-liste">
        <li><span class="fw-icon">🔧</span> Handwerker &amp; Betriebe</li>
        <li><span class="fw-icon">🏥</span> Ärzte &amp; Praxen</li>
        <li><span class="fw-icon">🍕</span> Restaurants &amp; Gastronomie</li>
        <li><span class="fw-icon">⚖️</span> Kanzleien &amp; Steuerberater</li>
        <li><span class="fw-icon">💼</span> Selbstständige &amp; Coaches</li>
      </ul>
    </div>
  </section>

  <!-- 6. CTA -->
  <Cta />

  <!-- 7. FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Was dich vielleicht noch beschäftigt</h2>

      <div class="faq-item">
        <h3>Arbeitet ihr nur in Stuttgart?</h3>
        <p>Hauptsächlich ja – aber wir arbeiten auch mit Betrieben aus der gesamten Region. Die meisten Abstimmungen laufen per Video-Call.</p>
      </div>

      <div class="faq-item">
        <h3>Was kostet eine KI-Lösung?</h3>
        <p>Eine Website mit Chatbot kostet 1.500 € inkl. MwSt. – einmalig, kein Abo. Andere Lösungen besprechen wir im kostenlosen Erstgespräch.</p>
      </div>

      <div class="faq-item">
        <h3>Wie lange dauert die Umsetzung?</h3>
        <p>In der Regel 1–2 Wochen. Kein monatelanges Projekt, keine endlosen Meetings.</p>
      </div>

      <div class="faq-item faq-item--last">
        <h3>Brauche ich technisches Wissen?</h3>
        <p>Nein. Du sagst uns was du brauchst – wir bauen alles. Du musst nichts installieren oder einrichten.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--primary);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
    color: white;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: white;
    margin-bottom: 1rem;
  }

  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.0625rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2rem;
    max-width: 58ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: white;
    color: var(--primary);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.9; }

  /* Warum lokal */
  .warum-lokal {
    background: var(--surface);
    padding: 5rem 0;
  }

  .wl-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .warum-lokal h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .wl-punkte {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .wl-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .wl-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .wl-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .wl-punkt p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Was wir bauen */
  .was-wir-bauen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .wwb-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-wir-bauen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .wwb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .wwb-karte {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .wwb-karte:hover {
    border-color: var(--secondary);
    transform: translateY(-2px);
  }

  .wwb-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .wwb-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.35rem;
  }

  .wwb-karte p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Referenz */
  .referenz {
    background: var(--surface);
    padding: 5rem 0;
  }

  .ref-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .ref-zitat {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.6;
    color: var(--on-surface);
    font-style: italic;
    margin: 0 0 1.25rem;
    border: none;
    padding: 0;
  }

  .ref-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface-muted);
    margin-bottom: 1rem;
  }

  .ref-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ref-link:hover { opacity: 0.75; }

  .ref-bild {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: block;
  }

  /* Für wen */
  .fuer-wen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .fw-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .fuer-wen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 2.5rem;
    line-height: 1.25;
  }

  .fw-liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .fw-liste li {
    font-size: 1rem;
    font-weight: 500;
    color: var(--on-surface);
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .fw-icon {
    font-size: 1.375rem;
    line-height: 1;
    flex-shrink: 0;
  }

  /* FAQ */
  .faq {
    background: var(--surface-low);
    padding: 5rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .faq-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .faq h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .faq-item {
    padding: 1.75rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .faq-item--last {
    border-bottom: 1px solid var(--outline-variant);
  }

  .faq-item h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
  }

  .faq-item p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .wwb-grid {
      grid-template-columns: 1fr;
    }

    .ref-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ref-bild-block {
      order: -1;
    }
  }
</style>
