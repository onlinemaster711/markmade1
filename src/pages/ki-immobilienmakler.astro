---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI für Immobilienmakler | MarkMade"
  description="KI erstellt Exposés automatisch, qualifiziert Anfragen vor und bucht Besichtigungstermine. Für Immobilienmakler die Zeit sparen wollen."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI für Immobilienmakler</p>
      <h1>Mehr Abschlüsse. Weniger Papierkram.</h1>
      <h2 class="seo-subline">KI für Immobilienmakler – Exposés, Anfragen und Besichtigungen automatisch bearbeiten</h2>
      <p class="hero-text">
        KI erstellt professionelle Exposés, beantwortet Interessentenanfragen automatisch und bucht Besichtigungstermine – damit du dich auf den Verkauf konzentrierst.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. WAS KI KONKRET MACHT -->
  <section class="was-ki-macht">
    <div class="was-ki-inner">
      <h2>Was KI konkret für dein Maklerbüro übernimmt.</h2>
      <div class="ki-grid">
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📄</span>
          <div>
            <h3>Exposés automatisch erstellen</h3>
            <p>Aus Eckdaten wird ein professionelles Exposé – schnell, konsistent, überzeugend.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">💬</span>
          <div>
            <h3>Anfragen vorqualifizieren</h3>
            <p>Nur ernsthafte Interessenten kommen zu dir – unpassende Anfragen werden automatisch aussortiert.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📅</span>
          <div>
            <h3>Besichtigungen buchen</h3>
            <p>Interessenten buchen direkt in deinen Kalender – ohne Telefonate, ohne Hin-und-Her.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">✉️</span>
          <div>
            <h3>Follow-up automatisieren</h3>
            <p>Nach der Besichtigung automatisch nachhaken – kein Interessent geht verloren.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. USE CASES -->
  <section class="use-cases">
    <div class="uc-inner">
      <h2>Was KI für Immobilienmakler konkret übernimmt</h2>
      <div class="uc-grid">

        <div class="uc-punkt fade-in">
          <span class="uc-icon">🏠</span>
          <div>
            <h3>Exposés automatisch schreiben</h3>
            <p>Eckdaten eingeben, KI schreibt den Text. Fertig in Minuten statt Stunden.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📸</span>
          <div>
            <h3>Objektbeschreibungen aus Fotos</h3>
            <p>Fotos hochladen, KI erkennt Merkmale und formuliert die Beschreibung.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">👨‍👩‍👧</span>
          <div>
            <h3>Zielgruppenspezifische Texte</h3>
            <p>Für Familien andere Highlights als für Kapitalanleger. Automatisch.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">💬</span>
          <div>
            <h3>Interessentenanfragen vorqualifizieren</h3>
            <p>Nur ernsthafte Käufer kommen zu dir. Den Rest filtert der Chatbot.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📅</span>
          <div>
            <h3>Besichtigungen automatisch buchen</h3>
            <p>Interessenten buchen direkt in deinen Kalender. Kein Hin-und-Her.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">✉️</span>
          <div>
            <h3>Follow-up Sequenzen</h3>
            <p>Nach der Besichtigung automatisch nachhaken. Ohne dass du dran denkst.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">⭐</span>
          <div>
            <h3>Bewertungen automatisch anfordern</h3>
            <p>Nach dem Abschluss automatisch um eine Google-Bewertung bitten.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">🪑</span>
          <div>
            <h3>Virtuelles Home Staging</h3>
            <p>Leere Räume per KI einrichten. Ohne Fotograf, ohne Innenarchitekt.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. ZEITRECHNER -->
  <section class="zeitrechner">
    <div class="zr-inner">
      <div class="zr-content">
        <h2>Wie viel Zeit verlierst du gerade für Exposés?</h2>

        <div class="zr-slider-group">
          <label for="exposees">
            Wie viele Exposés schreibst du pro Monat?
            <span class="zr-val" id="exposees-val">8</span>
          </label>
          <input type="range" id="exposees" min="1" max="30" value="8" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>1</span><span>30</span></div>
        </div>

        <div class="zr-slider-group">
          <label for="minuten">
            Wie lange brauchst du pro Exposé?
            <span class="zr-val" id="minuten-val">90 Min</span>
          </label>
          <input type="range" id="minuten" min="30" max="180" value="90" step="15" class="zr-range" />
          <div class="zr-range-labels"><span>30 Min</span><span>180 Min</span></div>
        </div>
      </div>

      <div class="zr-ergebnis">
        <div class="zr-box">
          <p class="zr-label">Stunden pro Monat</p>
          <p class="zr-monat" id="zr-monat">12</p>
          <p class="zr-label">Stunden pro Jahr</p>
          <p class="zr-jahr" id="zr-jahr">144</p>
          <p class="zr-frage" id="zr-frage">Was machst du mit 144 Stunden mehr im Jahr?</p>
          <p class="zr-hinweis">Mit KI: unter 10 Minuten pro Exposé.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. WAS KI NICHT KANN -->
  <section class="ki-nicht">
    <div class="kn-inner">
      <h2>Was KI nicht kann.</h2>
      <p class="kn-text">KI kennt nicht deinen Markt. Nicht deine Kunden. Nicht was einen guten Makler ausmacht. Sie macht erfahrene Makler besser – aber sie ersetzt niemanden der das Handwerk nicht beherrscht. Deshalb steckt hinter jeder MarkMade-Lösung ein Mensch der versteht wie dein Geschäft funktioniert.</p>
      <div class="kn-punkte">
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Verhandlungen führst du</strong> – KI bereitet dich vor</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Vertrauen baust du auf</strong> – KI gibt dir mehr Zeit dafür</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Marktkenntnis kommt von dir</strong> – KI macht sie skalierbar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CHATDEMO -->
  <section class="demo-section">
    <div class="demo-inner">
      <ChatDemo
        title="So qualifiziert KI deine Interessenten vor"
        messages={[
          {role: 'user', text: 'Ich interessiere mich für die Wohnung in Stuttgart Mitte.'},
          {role: 'bot', text: 'Sehr gerne! Die Wohnung hat 85m², 3 Zimmer und ist ab Juni verfügbar. Suchen Sie zur Miete oder zum Kauf?'},
          {role: 'user', text: 'Zum Kauf. Was ist der Preis?'},
          {role: 'bot', text: 'Der Kaufpreis beträgt 485.000 € inkl. Stellplatz. Soll ich direkt einen Besichtigungstermin für Sie reservieren?'}
        ]}
      />
    </div>
  </section>

  <!-- 4. WARUM DAS WICHTIG IST -->
  <section class="warum">
    <div class="warum-inner">
      <h2>Jede verpasste Anfrage ist ein verlorener Auftrag.</h2>
      <p class="warum-text">Interessenten suchen oft abends oder am Wochenende. Ein KI-Assistent beantwortet sofort – bevor der Interessent zur Konkurrenz geht.</p>
      <div class="punkte-grid">
        <div class="punkt fade-in">
          <span class="punkt-icon">🕐</span>
          <div>
            <h3>24/7 erreichbar</h3>
            <p>Auch nachts und am Wochenende – kein Interessent wartet vergeblich.</p>
          </div>
        </div>
        <div class="punkt fade-in">
          <span class="punkt-icon">⚡</span>
          <div>
            <h3>Sofortige Antwort</h3>
            <p>Kein Warten, kein Verlust – Interessenten bekommen sofort was sie brauchen.</p>
          </div>
        </div>
        <div class="punkt fade-in">
          <span class="punkt-icon">🎯</span>
          <div>
            <h3>Vorqualifiziert</h3>
            <p>Nur ernsthafte Käufer kommen zu dir – du verschwendest keine Zeit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <Cta />

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-telefonassistent" class="ai-karte">
          <span class="ai-icon">📞</span>
          <span class="ai-titel">KI-Telefonassistent</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-email" class="ai-karte">
          <span class="ai-icon">✉️</span>
          <span class="ai-titel">E-Mail-Automatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-fuer-immobilienmakler" class="ai-karte">
          <span class="ai-icon">📖</span>
          <span class="ai-titel">Ratgeber: KI für Immobilienmakler</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Was KI macht */
  .was-ki-macht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-macht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ki-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .ki-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .ki-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* SEO Subline */
  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  /* Use Cases */
  .use-cases {
    background: var(--surface);
    padding: 5rem 0;
  }

  .uc-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .use-cases h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .uc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .uc-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .uc-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .uc-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.35rem;
  }

  .uc-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Zeitrechner */
  .zeitrechner {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .zr-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .zr-content h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: white;
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .zr-slider-group {
    margin-bottom: 2rem;
  }

  .zr-slider-group label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.75rem;
  }

  .zr-val {
    font-weight: 700;
    font-size: 1rem;
    color: var(--primary-fixed);
  }

  .zr-range {
    width: 100%;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.2);
    outline: none;
    cursor: pointer;
  }

  .zr-range::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .zr-range-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.35rem;
  }

  .zr-ergebnis {
    display: flex;
    justify-content: center;
  }

  .zr-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    text-align: center;
    width: 100%;
  }

  .zr-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.35rem;
  }

  .zr-monat {
    font-family: 'Noto Serif', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--primary-fixed);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .zr-jahr {
    font-family: 'Noto Serif', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .zr-frage {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .zr-hinweis {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* KI nicht */
  .ki-nicht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .kn-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-nicht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .kn-text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .kn-punkte {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kn-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .kn-dash {
    font-size: 1.25rem;
    color: var(--secondary);
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .kn-punkt p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--on-surface);
  }

  /* Demo */
  .demo-section {
    background: var(--surface);
    padding: 0;
  }

  .demo-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Warum */
  .warum {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .warum-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .warum h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: white;
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }

  .warum-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    max-width: 60ch;
    margin: 0 auto 3rem;
  }

  .punkte-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: left;
  }

  .punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .punkt-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.4rem;
  }

  .punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid {
      grid-template-columns: 1fr;
    }

    .uc-grid {
      grid-template-columns: 1fr;
    }

    .zr-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .punkte-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style>
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
  }

  .ai-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ai-inner h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--on-surface);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    flex: 1;
    line-height: 1.3;
  }

  .ai-arrow {
    font-size: 1rem;
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .ai-karte:hover .ai-arrow {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function updateZeitrechner() {
    const exposees = parseInt((document.getElementById('exposees') as HTMLInputElement).value, 10);
    const minuten = parseInt((document.getElementById('minuten') as HTMLInputElement).value, 10);

    const stunden_monat = Math.round((exposees * minuten) / 60 * 10) / 10;
    const stunden_jahr = Math.round(stunden_monat * 12 * 10) / 10;

    (document.getElementById('exposees-val') as HTMLElement).textContent = String(exposees);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-monat') as HTMLElement).textContent = String(stunden_monat);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(stunden_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + stunden_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('exposees')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>
