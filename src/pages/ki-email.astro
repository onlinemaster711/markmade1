<script>
  function updateZeitrechner() {
    const emails = parseInt((document.getElementById('emails') as HTMLInputElement).value, 10);
    const minuten = parseInt((document.getElementById('minuten') as HTMLInputElement).value, 10);

    const min_tag = emails * minuten;
    const std_monat = Math.round((min_tag * 30) / 60 * 10) / 10;
    const std_jahr = Math.round((min_tag * 365) / 60 * 10) / 10;

    (document.getElementById('emails-val') as HTMLElement).textContent = String(emails);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-tag') as HTMLElement).textContent = String(min_tag);
    (document.getElementById('zr-monat') as HTMLElement).textContent = String(std_monat);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(std_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + std_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('emails')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>

<script>
  (function() {
    var divider = document.getElementById('ed-divider');
    var mail2   = document.getElementById('ed-mail-2');
    var timer: ReturnType<typeof setTimeout>;

    function runSequence() {
      // Reset
      divider?.classList.remove('ed-visible');
      mail2?.classList.remove('ed-visible');

      // Step 1: divider after 1.5s
      timer = setTimeout(function() {
        divider?.classList.add('ed-visible');

        // Step 2: mail 2 after 2.5s total
        timer = setTimeout(function() {
          mail2?.classList.add('ed-visible');

          // Step 3: loop after 6s total
          timer = setTimeout(runSequence, 6000);
        }, 1000);
      }, 1500);
    }

    runSequence();
  })();
</script>
