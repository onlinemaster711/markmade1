---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="E-Mail-Automatisierung mit KI – Anfragen automatisch beantworten | MarkMade"
  description="KI beantwortet eingehende E-Mails automatisch, priorisiert Anfragen und spart täglich wertvolle Zeit. Für kleine und mittelständische Betriebe."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">E-Mail-Automatisierung mit KI</p>
      <h1>Dein Postfach arbeitet.<br />Auch wenn du es nicht tust.</h1>
      <p class="hero-text">
        KI liest eingehende E-Mails, beantwortet Standardanfragen automatisch und leitet komplexe Fälle an dich weiter. Du sparst täglich Zeit – ohne dass Kunden es merken.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. DAS PROBLEM -->
  <section class="problem">
    <div class="problem-inner">
      <h2>Wie viele E-Mails beantwortest du täglich – immer wieder dieselben?</h2>
      <div class="pills">
        <span class="pill">Preisanfragen</span>
        <span class="pill">Terminwünsche</span>
        <span class="pill">Öffnungszeiten</span>
      </div>
      <p class="problem-text">80% der eingehenden E-Mails sind Standardfragen. KI beantwortet sie – du kümmerst dich um den Rest.</p>
    </div>
  </section>

  <!-- 3. WAS KI KONKRET MACHT -->
  <section class="was-ki-macht">
    <div class="was-ki-inner">
      <h2>Was KI konkret für dein Postfach übernimmt.</h2>
      <div class="ki-grid">
        <div class="ki-punkt fade-in">
          <span class="ki-icon">✅</span>
          <div>
            <h3>Standardanfragen beantworten</h3>
            <p>Preise, Zeiten, Ablauf – KI antwortet sofort und korrekt, rund um die Uhr.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">🔀</span>
          <div>
            <h3>Weiterleiten &amp; priorisieren</h3>
            <p>Wichtiges kommt sofort zu dir. Unwichtiges wird automatisch sortiert.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📋</span>
          <div>
            <h3>Anfragen vorqualifizieren</h3>
            <p>Nur ernsthafte Interessenten landen bei dir – kein Zeitverlust durch unpassende Anfragen.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📊</span>
          <div>
            <h3>Auswerten</h3>
            <p>Was wird am häufigsten gefragt? KI liefert dir einen Überblick damit du besser planst.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. E-MAIL DEMO -->
  <section class="email-demo-section">
    <div class="email-demo-wrap">
      <p class="email-demo-label">So funktioniert KI-E-Mail-Automatisierung</p>

      <div class="email-demo-client" id="email-demo">

        <!-- Client header -->
        <div class="email-demo-header">
          <div class="email-demo-dots">
            <span class="ed-dot ed-dot--red"></span>
            <span class="ed-dot ed-dot--yellow"></span>
            <span class="ed-dot ed-dot--green"></span>
          </div>
          <span class="email-demo-title">Posteingang</span>
          <span></span>
        </div>

        <!-- E-Mail 1: Eingehend -->
        <div class="email-demo-mail" id="ed-mail-1">
          <div class="ed-mail-meta">
            <div class="ed-mail-fields">
              <div class="ed-field"><span class="ed-field-label">Von:</span><span class="ed-field-val">kunde@beispiel.de</span></div>
              <div class="ed-field"><span class="ed-field-label">An:</span><span class="ed-field-val">info@deinbetrieb.de</span></div>
              <div class="ed-field"><span class="ed-field-label">Betreff:</span><span class="ed-field-val ed-subject">Anfrage: Termin für Inspektion</span></div>
              <div class="ed-field"><span class="ed-field-label">Datum:</span><span class="ed-field-val">Heute, 18:43 Uhr</span></div>
            </div>
            <span class="ed-badge ed-badge--incoming">KI antwortet automatisch</span>
          </div>
          <div class="ed-mail-body">
            <p>Guten Tag,</p>
            <p>ich würde gerne einen Termin für eine Standardinspektion vereinbaren. Was sind Ihre Preise und haben Sie nächste Woche Termine verfügbar?</p>
            <p>Mit freundlichen Grüßen<br />Thomas Müller</p>
          </div>
        </div>

        <!-- Trennlinie -->
        <div class="ed-divider" id="ed-divider">
          <div class="ed-divider-line"></div>
          <span class="ed-divider-text">KI erkennt die Anfrage und antwortet in Sekunden ↓</span>
          <div class="ed-divider-line"></div>
        </div>

        <!-- E-Mail 2: KI-Antwort -->
        <div class="email-demo-mail email-demo-mail--reply" id="ed-mail-2">
          <div class="ed-mail-meta">
            <div class="ed-mail-fields">
              <div class="ed-field"><span class="ed-field-label">Von:</span><span class="ed-field-val">info@deinbetrieb.de <span class="ed-ki-tag">(KI-Assistent)</span></span></div>
              <div class="ed-field"><span class="ed-field-label">An:</span><span class="ed-field-val">kunde@beispiel.de</span></div>
              <div class="ed-field"><span class="ed-field-label">Betreff:</span><span class="ed-field-val ed-subject">Re: Anfrage: Termin für Inspektion</span></div>
              <div class="ed-field"><span class="ed-field-label">Datum:</span><span class="ed-field-val">Heute, 18:43 Uhr</span></div>
            </div>
            <span class="ed-badge ed-badge--reply">Automatisch beantwortet</span>
          </div>
          <div class="ed-mail-body">
            <p>Guten Tag Herr Müller,</p>
            <p>vielen Dank für Ihre Anfrage.</p>
            <p>Eine Standardinspektion kostet bei uns 89 € inkl. MwSt. Für nächste Woche haben wir noch folgende Termine verfügbar:</p>
            <ul>
              <li>Dienstag, 15. April – 9:00 oder 14:00 Uhr</li>
              <li>Donnerstag, 17. April – 10:00 Uhr</li>
            </ul>
            <p>Sie können Ihren Wunschtermin direkt online buchen unter: <a href="https://calendly.com/onlinemaster711/new-meeting" class="ed-inline-link" target="_blank">Termin buchen →</a></p>
            <p>Bei weiteren Fragen stehe ich gerne zur Verfügung.</p>
            <p>Mit freundlichen Grüßen<br />Ihr Team von Musterbetrieb</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <Cta />

</BaseLayout>

<style is:global>
  /* ── EMAIL DEMO ── */
  .email-demo-section {
    background: var(--surface);
    padding: 4rem 0 5rem;
  }

  .email-demo-wrap {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .email-demo-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .email-demo-client {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    font-family: 'Manrope', system-ui, sans-serif;
  }

  /* Client header */
  .email-demo-header {
    background: var(--surface-low);
    padding: 0.625rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--outline-variant);
  }

  .email-demo-dots {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .ed-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .ed-dot--red    { background: #ff5f57; }
  .ed-dot--yellow { background: #ffbd2e; }
  .ed-dot--green  { background: #28c840; }

  .email-demo-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--on-surface-muted);
  }

  /* Mail */
  .email-demo-mail {
    padding: 1.5rem;
    background: white;
    border-bottom: 1px solid var(--outline-variant);
  }

  .email-demo-mail--reply {
    background: #f5f3f0;
  }

  .ed-mail-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--outline-variant);
  }

  .ed-mail-fields {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .ed-field {
    display: flex;
    gap: 0.5rem;
    font-size: 12px;
    line-height: 1.5;
  }

  .ed-field-label {
    color: var(--on-surface-muted);
    font-weight: 600;
    flex-shrink: 0;
    width: 52px;
  }

  .ed-field-val {
    color: var(--on-surface);
  }

  .ed-subject {
    font-weight: 600;
  }

  .ed-ki-tag {
    color: var(--secondary);
    font-size: 11px;
  }

  .ed-badge {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .ed-badge--incoming {
    background: rgba(63, 69, 48, 0.1);
    color: var(--primary);
  }

  .ed-badge--reply {
    background: rgba(184, 0, 73, 0.1);
    color: var(--secondary);
  }

  .ed-mail-body {
    font-size: 13.5px;
    line-height: 1.75;
    color: var(--on-surface);
  }

  .ed-mail-body p {
    margin: 0 0 0.625rem;
  }

  .ed-mail-body p:last-child {
    margin-bottom: 0;
  }

  .ed-mail-body ul {
    margin: 0 0 0.625rem 1.25rem;
    padding: 0;
  }

  .ed-mail-body li {
    margin-bottom: 0.25rem;
  }

  .ed-inline-link {
    color: var(--secondary);
    font-weight: 600;
    text-decoration: none;
  }

  .ed-inline-link:hover {
    text-decoration: underline;
  }

  /* Divider */
  .ed-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    background: white;
    border-bottom: 1px solid var(--outline-variant);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ed-divider.ed-visible {
    opacity: 1;
  }

  .ed-divider-line {
    flex: 1;
    height: 1px;
    background: var(--outline-variant);
  }

  .ed-divider-text {
    font-size: 12px;
    color: var(--on-surface-muted);
    white-space: nowrap;
    font-style: italic;
  }

  /* Mail 2 animation */
  #ed-mail-2 {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  #ed-mail-2.ed-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* Problem */
  .problem {
    background: var(--primary);
    padding: 5rem 0;
    text-align: center;
    color: white;
  }

  .problem-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .problem h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.375rem, 3vw, 2rem);
    line-height: 1.3;
    color: white;
    margin-bottom: 2rem;
  }

  .pills {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .pill {
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border-radius: 2rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .problem-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Was KI macht */
  .was-ki-macht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-macht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ki-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .ki-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .ki-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function() {
    var divider = document.getElementById('ed-divider');
    var mail2   = document.getElementById('ed-mail-2');
    var timer: ReturnType<typeof setTimeout>;

    function runSequence() {
      // Reset
      divider?.classList.remove('ed-visible');
      mail2?.classList.remove('ed-visible');

      // Step 1: divider after 1.5s
      timer = setTimeout(function() {
        divider?.classList.add('ed-visible');

        // Step 2: mail 2 after 2.5s total
        timer = setTimeout(function() {
          mail2?.classList.add('ed-visible');

          // Step 3: loop after 6s total
          timer = setTimeout(runSequence, 6000);
        }, 1000);
      }, 1500);
    }

    runSequence();
  })();
</script>
