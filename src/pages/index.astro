---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">

      <p class="eyebrow">KI-Agentur für KMU</p>
      <h1>KI übernimmt, was dich aufhält.</h1>
      <p class="subtext">
        Wir bauen KI-Lösungen die in deinem Betrieb tatsächlich Zeit sparen –
        Chatbots, Telefonassistenten, E-Mail-Automatisierung. Kein Abo. Einmal gebaut.
      </p>

      <a
        href="https://calendly.com/onlinemaster711/new-meeting"
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >Kostenloses Erstgespräch buchen</a>

      <ul class="haekchen-liste">
        <li><span class="check">✓</span> Kostenlose Erstanalyse</li>
        <li><span class="check">✓</span> Keine laufenden Kosten</li>
        <li><span class="check">✓</span> Umsetzung in 1–2 Wochen</li>
      </ul>

      <div class="use-case-cards">
        <a href="/ki-telefonassistent" class="uc-card">
          <span class="uc-icon">📞</span>
          <span class="uc-label">Telefon&shy;assistent</span>
        </a>
        <a href="/ki-email" class="uc-card">
          <span class="uc-icon">✉️</span>
          <span class="uc-label">E-Mail-Auto&shy;matisierung</span>
        </a>
        <a href="/ki-fuer-unternehmen" class="uc-card">
          <span class="uc-icon">💬</span>
          <span class="uc-label">KI-Chatbot</span>
        </a>
        <a href="/ki-automatisierung" class="uc-card">
          <span class="uc-icon">⚙️</span>
          <span class="uc-label">Prozess&shy;automatisierung</span>
        </a>
      </div>

    </div>
  </section>

  <!-- 2. LEISTUNGEN -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">
      <h2>Was wir für deinen Betrieb bauen.</h2>
      <p class="leistungen-sub">Jede Lösung wird einmalig gebaut und läuft dann selbstständig.</p>
      <div class="leistungen-grid">

        <a href="/ki-fuer-unternehmen" class="lk">
          <span class="lk-emoji">💬</span>
          <strong class="lk-titel">KI-Chatbot</strong>
          <p class="lk-text">Beantwortet Kundenfragen rund um die Uhr – auch nachts und am Wochenende.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

        <a href="/ki-telefonassistent" class="lk">
          <span class="lk-emoji">📞</span>
          <strong class="lk-titel">Telefonassistent</strong>
          <p class="lk-text">Nimmt Anrufe an, qualifiziert Anfragen vor und leitet weiter.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

        <a href="/ki-email" class="lk">
          <span class="lk-emoji">📧</span>
          <strong class="lk-titel">E-Mail-Automatisierung</strong>
          <p class="lk-text">Liest, sortiert und beantwortet eingehende E-Mails automatisch.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

        <a href="/ki-social-media" class="lk">
          <span class="lk-emoji">📱</span>
          <strong class="lk-titel">Social Media mit KI</strong>
          <p class="lk-text">Erstellt Posts, Bildunterschriften und Content-Pläne auf Knopfdruck.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

        <a href="/ki-automatisierung" class="lk">
          <span class="lk-emoji">⚙️</span>
          <strong class="lk-titel">Prozessautomatisierung</strong>
          <p class="lk-text">Wiederkehrende Aufgaben wie Angebote, Berichte und Ablage automatisieren.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

        <a href="/webdesign-selbststaendige" class="lk">
          <span class="lk-emoji">🌐</span>
          <strong class="lk-titel">KI-Website</strong>
          <p class="lk-text">Professioneller Webauftritt der Kunden überzeugt – ab 1.000 € einmalig.</p>
          <span class="lk-cta">Details<span class="lk-line"></span></span>
        </a>

      </div>
    </div>
  </section>

  <!-- 3. BRANCHEN -->
  <section class="branchen">
    <div class="branchen-inner">
      <h2 class="branchen-h2">Für welche Branchen wir bauen.</h2>
      <p class="branchen-sub">Jede Lösung wird auf die echten Abläufe deiner Branche zugeschnitten.</p>
      <div class="branchen-grid">

        <div class="branche-karte branche-dunkel">
          <div class="branche-top">
            <span class="branche-emoji">🔨</span>
            <strong class="branche-titel">Handwerksbetriebe</strong>
          </div>
          <div class="branche-links">
            <a href="/webdesign-handwerker">Website für Handwerker</a>
            <a href="/ki-handwerker">KI für Handwerker</a>
          </div>
        </div>

        <div class="branche-karte branche-hell">
          <div class="branche-top">
            <span class="branche-emoji">🏥</span>
            <strong class="branche-titel">Arztpraxen</strong>
          </div>
          <div class="branche-links">
            <a href="/webdesign-aerzte">Website für Ärzte</a>
            <a href="/ki-aerzte">KI für Ärzte &amp; Praxen</a>
          </div>
        </div>

        <div class="branche-karte branche-dunkel">
          <div class="branche-top">
            <span class="branche-emoji">🍽️</span>
            <strong class="branche-titel">Restaurants</strong>
          </div>
          <div class="branche-links">
            <a href="/ki-restaurant">KI für Restaurants</a>
          </div>
        </div>

        <div class="branche-karte branche-hell">
          <div class="branche-top">
            <span class="branche-emoji">⚖️</span>
            <strong class="branche-titel">Kanzleien</strong>
          </div>
          <div class="branche-links">
            <a href="/ki-kanzlei">KI für Kanzleien</a>
          </div>
        </div>

        <div class="branche-karte branche-dunkel">
          <div class="branche-top">
            <span class="branche-emoji">🏠</span>
            <strong class="branche-titel">Immobilienmakler</strong>
          </div>
          <div class="branche-links">
            <a href="/ki-immobilienmakler">KI für Immobilienmakler</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. BEWEIS -->
  <Beweis />

  <!-- 5. CTA -->
  <Cta />

  <!-- 6. FAQ (inline) -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Was dich vielleicht noch beschäftigt.</h2>

      <div class="faq-item">
        <h3>Was kostet das?</h3>
        <p>Die Erstanalyse ist kostenlos. Umsetzungen starten ab 500 €, je nach Umfang. Keine Monatsgebühren, keine versteckten Kosten.</p>
      </div>

      <div class="faq-item">
        <h3>Für wen ist das geeignet?</h3>
        <p>Für Betriebe mit 1–50 Mitarbeitern die Zeit sparen wollen: Handwerker, Praxen, Restaurants, Kanzleien, Makler und Selbstständige.</p>
      </div>

      <div class="faq-item faq-highlight">
        <h3>Wie schnell ist das umgesetzt?</h3>
        <p>In 1–2 Wochen. Du gibst uns 30 Minuten für das Erstgespräch – den Rest machen wir.</p>
      </div>

      <div class="faq-item">
        <h3>Ich habe keine Zeit dafür.</h3>
        <p>Das ist der Punkt. Unser Prozess kostet dich 30 Minuten. Den Rest übernehmen wir – du musst nichts installieren oder einrichten.</p>
      </div>

      <div class="faq-item">
        <h3>Was wenn mir das Ergebnis nicht gefällt?</h3>
        <p>Kein Cent fällig. Wir zeigen dir zuerst was wir bauen wollen – du entscheidest danach.</p>
      </div>

      <div class="faq-item faq-item--last">
        <h3>Wenn KI so viel kann – warum brauche ich noch jemanden?</h3>
        <p>KI macht gute Leute besser – aber sie macht niemanden gut der sich nicht auskennt. Marketing und Betriebsabläufe sind unser Handwerk. KI ist unser Werkzeug.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    background: var(--surface);
    padding: 140px 1.5rem 100px;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.15;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .subtext {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.9375rem 2rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .btn-primary:hover { opacity: 0.88; }

  .haekchen-liste {
    list-style: none;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 3rem;
  }

  .haekchen-liste li {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: var(--on-surface-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .check {
    color: var(--secondary);
    font-weight: 700;
  }

  .use-case-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .uc-card {
    background: var(--surface-low);
    border: 1px solid var(--dust);
    border-radius: 1rem;
    padding: 1.25rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--on-surface-muted);
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
    text-align: center;
    transition: border-color 0.2s, color 0.2s;
  }

  .uc-card:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .uc-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  /* ─────────────────────────────────────────
     LEISTUNGEN
  ───────────────────────────────────────── */
  .leistungen {
    background: var(--surface-low);
    padding: 128px 1.5rem;
  }

  .leistungen-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .leistungen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .leistungen-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    color: var(--on-surface-muted);
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .lk {
    background: var(--surface-lowest);
    border: 1px solid var(--dust);
    border-radius: 1rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    box-shadow: 0px 12px 32px rgba(27, 28, 26, 0.06);
    transition: transform 0.3s ease;
  }

  .lk:hover {
    transform: translateY(-8px);
  }

  .lk:hover .lk-line {
    width: 3rem;
  }

  .lk-emoji {
    font-size: 2.5rem;
    line-height: 1;
    color: var(--secondary);
    margin-bottom: 2rem;
    display: block;
  }

  .lk-titel {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1rem;
    display: block;
  }

  .lk-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .lk-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
    font-family: 'Manrope', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    margin-top: auto;
  }

  .lk-line {
    display: inline-block;
    width: 2rem;
    height: 2px;
    background: var(--secondary);
    transition: width 0.3s ease;
    flex-shrink: 0;
  }

  /* ─────────────────────────────────────────
     BRANCHEN
  ───────────────────────────────────────── */
  .branchen {
    background: var(--surface);
    padding: 128px 1.5rem;
  }

  .branchen-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .branchen-h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .branchen-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    color: var(--on-surface-muted);
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .branche-karte {
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-radius: 1rem;
    padding: 2rem;
    transition: transform 0.3s ease;
  }

  .branche-karte:hover {
    transform: translateY(-8px);
  }

  /* Dunkle Karten (1, 3, 5) */
  .branche-dunkel {
    background: var(--primary-container);
  }

  .branche-dunkel .branche-emoji {
    color: rgba(255, 255, 255, 0.95);
  }

  .branche-dunkel .branche-titel {
    color: rgba(255, 255, 255, 0.95);
  }

  .branche-dunkel .branche-links a {
    color: var(--primary-fixed);
  }

  .branche-dunkel .branche-links a:hover {
    opacity: 0.8;
  }

  /* Helle Karten (2, 4) */
  .branche-hell {
    background: var(--surface-lowest);
    border: 1px solid var(--dust);
    box-shadow: 0px 12px 32px rgba(27, 28, 26, 0.06);
    margin-top: 3rem;
  }

  .branche-hell .branche-emoji {
    color: var(--secondary);
  }

  .branche-hell .branche-titel {
    color: var(--primary);
  }

  .branche-hell .branche-links a {
    color: var(--secondary);
  }

  .branche-hell .branche-links a:hover {
    opacity: 0.8;
  }

  /* Karten-Aufbau */
  .branche-top {
    display: flex;
    flex-direction: column;
  }

  .branche-emoji {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 1.5rem;
    display: block;
  }

  .branche-titel {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0;
  }

  .branche-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1.5rem;
  }

  .branche-links a {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s;
  }

  .branche-links a::before {
    content: '→';
    font-size: 0.8rem;
  }

  /* ─────────────────────────────────────────
     FAQ
  ───────────────────────────────────────── */
  .faq {
    background: var(--surface-low);
    padding: 128px 1.5rem;
  }

  .faq-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .faq h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
  }

  /* Normales FAQ-Item: 2-spaltig */
  .faq-item {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--dust);
  }

  .faq-item--last {
    border-bottom: none;
  }

  .faq-item h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.4;
    margin: 0;
  }

  .faq-item p {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    color: var(--on-surface-muted);
    line-height: 1.8;
    margin: 0;
  }

  /* Highlight-Item (Frage 3) */
  .faq-highlight {
    display: block;
    background: var(--primary);
    border-radius: 1rem;
    padding: 2.5rem 3rem;
    margin: 0.5rem 0;
    border-bottom: none;
  }

  .faq-highlight h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.95);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .faq-highlight p {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    color: var(--primary-fixed);
    line-height: 1.8;
    margin: 0;
  }

  /* ─────────────────────────────────────────
     RESPONSIVE
  ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .branchen-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .branche-hell {
      margin-top: 0;
    }
  }

  @media (max-width: 900px) {
    .leistungen-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 100px;
      padding-bottom: 64px;
    }

    .use-case-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .branchen-grid {
      grid-template-columns: 1fr;
    }

    .branche-karte {
      min-height: auto;
    }

    .faq-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .faq-highlight {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .leistungen-grid {
      grid-template-columns: 1fr;
    }

    .lk {
      padding: 1.75rem;
    }
  }
</style>
