---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="KI für KMU – Websites, Chatbots, Automatisierung, Marketing. Praktisch umsetzbar. Einmal bezahlt."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">

      <!-- LEFT: Text -->
      <div class="hero-text-col">
        <p class="eyebrow">KI-Agentur für kleine &amp; mittelständische Betriebe</p>
        <h1>Welches Problem kostet dich täglich die meiste Zeit?</h1>
        <p class="hero-sub">
          KI übernimmt die Zuarbeit – damit du dich auf das konzentrierst was wirklich zählt. Wir helfen dir herauszufinden wo KI in deinem Betrieb wirklich Sinn ergibt.
        </p>
        <div class="problem-buttons">
          <a href="/ki-telefonassistent" class="problem-btn">
            <span class="pb-text">📞 Ich verpasse Anrufe und Anfragen</span>
            <span class="pb-arrow">→</span>
          </a>
          <a href="/ki-email" class="problem-btn">
            <span class="pb-text">✉️ Ich verbringe zu viel Zeit mit E-Mails</span>
            <span class="pb-arrow">→</span>
          </a>
          <a href="/ratgeber/ki-im-unternehmen-nutzen" class="problem-btn">
            <span class="pb-text">❓ Ich weiß nicht wo ich mit KI anfangen soll</span>
            <span class="pb-arrow">→</span>
          </a>
        </div>
        <a href="https://calendly.com/onlinemaster711/new-meeting" class="hero-direct-link" target="_blank" rel="noopener noreferrer">
          Oder direkt Gespräch buchen →
        </a>
      </div>

      <!-- RIGHT: Chat Preview -->
      <div class="hero-visual-col">
        <div class="hero-chat" id="hero-chat">
          <div class="hero-chat-header">
            <span class="hero-chat-dot">●</span>
            <span class="hero-chat-name">MarkMade KI</span>
          </div>
          <div class="hero-chat-body" id="hero-chat-body"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ZÄHLER-LEISTE -->
  <div class="counter-bar" id="counter-bar">
    <div class="counter-inner">
      <div class="counter-item">
        <span class="counter-num" data-target="847" id="cnt-0">0</span>
        <span class="counter-label">Stunden gespart</span>
      </div>
      <div class="counter-item">
        <span class="counter-num" data-target="30" id="cnt-1">0</span>
        <span class="counter-label">KI-Lösungen umgesetzt</span>
      </div>
      <div class="counter-item">
        <span class="counter-num" data-target="6" id="cnt-2">0</span>
        <span class="counter-label">Branchen bedient</span>
      </div>
    </div>
  </div>

  <!-- 2. WAS KI ÜBERNIMMT -->
  <section class="ki-liste" id="leistungen">
    <div class="ki-liste-inner">
      <p class="eyebrow-section">Was KI übernimmt</p>
      <h2>KI arbeitet. Du auch – aber das Richtige.</h2>
      <nav class="ki-zeilen">
        <a href="/ki-email" class="ki-zeile fade-in">
          <span class="kz-text">KI beantwortet deine E-Mails.</span>
          <span class="kz-arrow">→</span>
        </a>
        <a href="/ki-telefonassistent" class="ki-zeile fade-in">
          <span class="kz-text">KI nimmt deine Anrufe entgegen.</span>
          <span class="kz-arrow">→</span>
        </a>
        <a href="/terminbuchung-handwerk" class="ki-zeile fade-in">
          <span class="kz-text">KI vergibt Termine in deinen Kalender.</span>
          <span class="kz-arrow">→</span>
        </a>
        <a href="/chatbot-handwerker" class="ki-zeile fade-in">
          <span class="kz-text">KI beantwortet Kundenfragen – rund um die Uhr.</span>
          <span class="kz-arrow">→</span>
        </a>
        <a href="/ki-social-media" class="ki-zeile fade-in">
          <span class="kz-text">KI erstellt deinen Social Media Content.</span>
          <span class="kz-arrow">→</span>
        </a>
        <a href="/ki-automatisierung" class="ki-zeile fade-in">
          <span class="kz-text">KI hilft dir die richtigen Anfragen zu erkennen.</span>
          <span class="kz-arrow">→</span>
        </a>
      </nav>
    </div>
  </section>

  <!-- 4. RATGEBER -->
  <section class="ratgeber">
    <div class="ratgeber-inner">
      <p class="eyebrow-section">Kostenlose Ratgeber</p>
      <h2>Versteh zuerst. Dann entscheide.</h2>
      <p class="section-text">Kein Verkaufsgespräch. Erst verstehen wie KI in deinem Betrieb helfen kann – dann entscheiden ob du weitermachst.</p>

      <!-- Featured Artikel -->
      <a href="/ratgeber/ki-im-unternehmen-nutzen" class="ratgeber-featured fade-in">
        <div class="rf-left">
          <span class="rf-icon">📖</span>
        </div>
        <div class="rf-right">
          <span class="rf-badge">Empfohlen</span>
          <h3>Wie du erkennst welche Prozesse KI lösen kann</h3>
          <p>Die ehrliche Anleitung – nicht welche Tools du kaufen sollst, sondern wie du die richtigen Fragen stellst.</p>
          <span class="rf-cta">Artikel lesen →</span>
        </div>
      </a>

    </div>
  </section>

  <!-- 5. WARUM MARKMADE -->
  <section class="warum">
    <div class="warum-inner">
      <h2>KI macht dich besser. Nicht überflüssig.</h2>
      <div class="warum-punkte">
        <div class="warum-punkt fade-in">
          <h3>Du gibst die Zuarbeit ab.</h3>
          <p>Anfragen beantworten, Termine koordinieren, immer wieder dieselben Fragen – das übernimmt KI. Du konzentrierst dich auf das was wirklich zählt: deine Kunden, dein Handwerk, deine Expertise.</p>
        </div>
        <div class="warum-punkt fade-in">
          <h3>Du bleibst der Mensch im Mittelpunkt.</h3>
          <p>KI ersetzt nicht was dich ausmacht – die Beziehung zu deinen Kunden, dein Fachwissen, dein Urteil. Sie übernimmt die Dinge die sich wiederholen damit du mehr Zeit für die Dinge hast die wirklich Menschlichkeit brauchen.</p>
        </div>
        <div class="warum-punkt fade-in">
          <h3>Wir bauen es für dich – in wenigen Tagen.</h3>
          <p>Kein monatelanges Projekt. Kein Technik-Wissen nötig. Du erzählst uns was dich täglich Zeit kostet – wir bauen die Lösung. Schnell, konkret, auf dich zugeschnitten.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. BEWEIS -->
  <Beweis />

  <!-- 7. CTA CUSTOM -->
  <section class="cta-custom">
    <div class="cta-inner">
      <p class="cta-eyebrow">Kostenlos &amp; unverbindlich</p>
      <h2>Du hast ein konkretes Problem im Kopf?</h2>
      <p class="cta-text">15 Minuten Gespräch – wir sagen dir ehrlich ob und wie KI es lösen kann. Kein Fachjargon. Kein Verkaufsgespräch.</p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="cta-btn" target="_blank" rel="noopener noreferrer">Jetzt Gespräch buchen</a>
      <p class="cta-sub">📅 Direkt in den Kalender – kein Telefonat nötig</p>
    </div>
  </section>

  <!-- VORSPRUNG-STREIFEN -->
  <section class="vorsprung">
    <div class="vorsprung-inner">
      <p class="vorsprung-headline">Wer ohne KI arbeitet, wird durch KI ersetzt.</p>
      <p class="vorsprung-sub">Die Frage ist nicht ob KI kommt – sondern ob du sie für dich nutzt oder gegen dich arbeiten lässt.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    background: var(--surface);
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-visual-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 48ch;
  }

  .problem-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .problem-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: white;
    border: 1.5px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    text-align: left;
    transition: border-color 0.2s, color 0.2s;
    color: var(--on-surface);
  }

  .problem-btn:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .pb-text {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .pb-arrow {
    font-size: 1.125rem;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .problem-btn:hover .pb-arrow {
    opacity: 1;
  }

  .hero-direct-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-direct-link:hover {
    color: var(--secondary);
  }

  /* ── COUNTER BAR ── */
  .counter-bar {
    background: var(--primary);
    padding: 1.5rem 0;
  }

  .counter-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .counter-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  /* ── SHARED ── */
  .eyebrow-section {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
    display: block;
    text-align: center;
  }

  .section-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    text-align: center;
    max-width: 55ch;
    margin: 0 auto 3rem;
  }

  h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  /* ── KI-LISTE ── */
  .ki-liste {
    background: var(--surface);
    padding: 5rem 0;
  }

  .ki-liste-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-zeilen {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
  }

  .ki-zeile {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 0.5px solid var(--outline-variant);
    text-decoration: none;
    color: var(--on-surface);
    transition: color 0.2s;
  }

  .ki-zeile:first-child {
    border-top: 0.5px solid var(--outline-variant);
  }

  .ki-zeile:hover {
    color: var(--secondary);
  }

  .kz-text {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .kz-arrow {
    font-size: 1.25rem;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.2s, transform 0.2s;
  }

  .ki-zeile:hover .kz-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── BRANCHEN TABS ── */
  .branchen-tabs {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .branchen-tabs-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── ZEITFRESSER (kept for grid reuse) ── */
  .zeitfresser {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .zeitfresser-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .zeitfresser-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .zf-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: box-shadow 0.2s;
  }

  .zf-karte:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .zf-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--secondary);
    margin: 0;
  }

  .zf-zitat {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--on-surface);
    margin: 0;
    flex: 1;
  }

  .zf-loesung {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .zf-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .zf-link:hover {
    opacity: 0.75;
  }

  /* ── BRANCHEN (old selectors kept in case referenced elsewhere) ── */
  .branchen { background: var(--surface); padding: 5rem 0; }

  /* ── RATGEBER ── */
  .ratgeber {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .ratgeber-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ratgeber-featured {
    display: flex;
    gap: 2rem;
    align-items: center;
    background: var(--primary);
    border-radius: 1.2rem;
    padding: 2rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }

  .ratgeber-featured:hover {
    opacity: 0.92;
  }

  .rf-left {
    flex-shrink: 0;
  }

  .rf-icon {
    font-size: 3rem;
    line-height: 1;
  }

  .rf-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rf-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--secondary);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    width: fit-content;
  }

  .rf-right h3 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0;
  }

  .rf-right p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  .rf-cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.625rem;
    padding: 0.4rem 0.875rem;
    width: fit-content;
    margin-top: 0.25rem;
  }

  .ratgeber-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .rg-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    text-decoration: none;
    transition: box-shadow 0.2s;
  }

  .rg-karte:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .rg-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .rg-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0;
  }

  .rg-karte p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
    flex: 1;
    margin: 0;
  }

  .rg-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    margin-top: auto;
  }

  .ratgeber-alle {
    text-align: center;
  }

  .ratgeber-alle-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ratgeber-alle-link:hover {
    color: var(--secondary);
  }

  /* ── BRANCHEN OFFEN ── */
  .branchen-offen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .branchen-offen-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .bo-list {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
  }

  .bo-branche {
    padding: 2.5rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .bo-branche--last {
    border-bottom: 1px solid var(--outline-variant);
  }

  .bo-name {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .bo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .bo-karte {
    background: white;
    border: 0.5px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .bo-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .bo-titel {
    font-size: 15px;
    font-weight: 500;
    color: var(--on-surface);
    margin: 0;
  }

  .bo-text {
    font-size: 13px;
    line-height: 1.55;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .bo-hinweis {
    margin-top: 2rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    align-items: center;
  }

  .bo-hinweis-text {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .bo-hinweis-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .bo-hinweis-link:hover {
    opacity: 0.75;
  }

  /* ── WARUM ── */
  .warum {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .warum-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .warum h2 {
    color: white;
    margin-bottom: 3rem;
  }

  .warum-punkte {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .warum-punkt {
    border-left: 2px solid rgba(255, 255, 255, 0.2);
    padding-left: 1.5rem;
  }

  .warum-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
  }

  .warum-punkt p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* ── VORSPRUNG ── */
  .vorsprung {
    background: var(--surface-low);
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .vorsprung-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .vorsprung-headline {
    font-family: 'Noto Serif', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--primary);
    margin: 0;
  }

  .vorsprung-sub {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* ── CTA CUSTOM ── */
  .cta-custom {
    background: linear-gradient(135deg, var(--primary), var(--primary-container, #5a6040));
    padding: 6rem 0;
    text-align: center;
  }

  .cta-inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-eyebrow {
