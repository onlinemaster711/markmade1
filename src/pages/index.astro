<style is:global>
  /* ── HERO CHAT ── */
  .hero-chat {
    width: 100%;
    max-width: 360px;
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(63, 69, 48, 0.12);
    overflow: hidden;
    font-family: 'Manrope', system-ui, sans-serif;
  }

  .hero-chat-header {
    background: #3f4530;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-chat-dot {
    color: #6fdb6f;
    font-size: 0.6rem;
  }

  .hero-chat-status {
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .hero-chat-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
  }

  .hero-chat-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    min-height: 200px;
  }

  .hero-chat-msg {
    max-width: 80%;
    padding: 0.5rem 0.875rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    line-height: 1.45;
    animation: hero-chat-fadein 0.3s ease;
  }

  .hero-chat-msg--user {
    background: #f0ece4;
    color: #3f4530;
    align-self: flex-end;
    border-bottom-right-radius: 0.25rem;
  }

  .hero-chat-msg--bot {
    background: #3f4530;
    color: white;
    align-self: flex-start;
    border-bottom-left-radius: 0.25rem;
  }

  .hero-chat-typing {
    align-self: flex-start;
    background: #3f4530;
    border-radius: 1rem;
    border-bottom-left-radius: 0.25rem;
    padding: 0.5rem 0.875rem;
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .hero-chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    animation: hero-chat-bounce 1s infinite;
  }

  .hero-chat-typing span:nth-child(2) { animation-delay: 0.15s; }
  .hero-chat-typing span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes hero-chat-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  @keyframes hero-chat-fadein {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
(function() {
  var messages = [
    { role: 'user', text: 'Ich verpasse täglich Anrufe wenn ich arbeite.' },
    { role: 'bot',  text: 'Das kennen viele Betriebe. Wie viele Anrufe verpasst du ungefähr pro Tag? 📞' },
    { role: 'user', text: 'So 3 bis 5 – manchmal mehr.' },
    { role: 'bot',  text: 'Das sind pro Jahr über 1.000 potenzielle Kunden. KI kann das lösen – soll ich dir zeigen wie?' }
  ];

  var body = document.getElementById('hero-chat-body');
  if (!body) return;

  var timer;

  function clearBody() {
    while (body.firstChild) body.removeChild(body.firstChild);
  }

  function addMsg(role, text, cb) {
    if (role === 'bot') {
      var typing = document.createElement('div');
      typing.className = 'hero-chat-typing';
      typing.innerHTML = '<span></span><span></span><span></span>';
      body.appendChild(typing);
      timer = setTimeout(function() {
        body.removeChild(typing);
        var msg = document.createElement('div');
        msg.className = 'hero-chat-msg hero-chat-msg--bot';
        msg.textContent = text;
        body.appendChild(msg);
        if (cb) timer = setTimeout(cb, 1200);
      }, 1200);
    } else {
      var msg = document.createElement('div');
      msg.className = 'hero-chat-msg hero-chat-msg--user';
      msg.textContent = text;
      body.appendChild(msg);
      if (cb) timer = setTimeout(cb, 800);
    }
  }

  function runSequence(index) {
    if (index >= messages.length) {
      timer = setTimeout(function() {
        clearBody();
        runSequence(0);
      }, 4000);
      return;
    }
    var m = messages[index];
    addMsg(m.role, m.text, function() {
      runSequence(index + 1);
    });
  }

  runSequence(0);
})();
</script>

<script>
(function() {
  var bar = document.getElementById('counter-bar');
  if (!bar) return;
  var started = false;
  var counters = bar.querySelectorAll('.counter-num');

  function animateCounter(el, target, duration) {
    var start = performance.now();
    function step(now) {
      var p = Math.min((now - start) / duration, 1);
      var ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(ease * target);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !started) {
      started = true;
      counters.forEach(function(el) {
        animateCounter(el, parseInt(el.dataset.target || '0', 10), 1500);
      });
    }
  }, { threshold: 0.5 });

  observer.observe(bar);
})();
</script>
