---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Prozess from '../components/Prozess.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">

      <div class="hero-left">
        <p class="eyebrow">KI-Agentur für KMU</p>
        <h1>Welches Problem kostet dich täglich die meiste Zeit?</h1>
        <p class="subtext">
          Wir analysieren deinen Betrieb – und zeigen dir wo KI konkret Zeit spart.
          Kein Tech-Wissen nötig. Kein Abo. Einmal gebaut, dauerhaft im Einsatz.
        </p>
        <div class="hero-buttons">
          <a
            href="https://calendly.com/onlinemaster711/new-meeting"
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >Kostenloses Erstgespräch buchen</a>
          <a href="#leistungen" class="btn-ghost">Leistungen entdecken</a>
        </div>
        <ul class="haekchen-liste">
          <li><span class="check">✓</span> Kostenlose Erstanalyse</li>
          <li><span class="check">✓</span> Keine laufenden Kosten</li>
          <li><span class="check">✓</span> Umsetzung in 1–2 Wochen</li>
        </ul>
      </div>

      <div class="hero-right" aria-hidden="true"></div>

    </div>
  </section>

  <!-- 2. LEISTUNGEN -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">
      <h2>Was wir für deinen Betrieb bauen.</h2>
      <p class="leistungen-sub">Jede Lösung wird einmalig gebaut und läuft dann selbstständig.</p>
      <div class="leistungen-grid">

        <a href="/ki-fuer-unternehmen" class="lk">
          <span class="lk-emoji">💬</span>
          <strong class="lk-titel">KI-Chatbot</strong>
          <p class="lk-text">Beantwortet Kundenfragen rund um die Uhr – auch nachts und am Wochenende.</p>
          <span class="lk-arrow">→</span>
        </a>

        <a href="/ki-telefonassistent" class="lk">
          <span class="lk-emoji">📞</span>
          <strong class="lk-titel">Telefonassistent</strong>
          <p class="lk-text">Nimmt Anrufe an, qualifiziert Anfragen vor und leitet weiter.</p>
          <span class="lk-arrow">→</span>
        </a>

        <a href="/ki-email" class="lk">
          <span class="lk-emoji">📧</span>
          <strong class="lk-titel">E-Mail-Automatisierung</strong>
          <p class="lk-text">Liest, sortiert und beantwortet eingehende E-Mails automatisch.</p>
          <span class="lk-arrow">→</span>
        </a>

        <a href="/ki-social-media" class="lk">
          <span class="lk-emoji">📱</span>
          <strong class="lk-titel">Social Media mit KI</strong>
          <p class="lk-text">Erstellt Posts, Bildunterschriften und Content-Pläne auf Knopfdruck.</p>
          <span class="lk-arrow">→</span>
        </a>

        <a href="/ki-automatisierung" class="lk">
          <span class="lk-emoji">⚙️</span>
          <strong class="lk-titel">Prozessautomatisierung</strong>
          <p class="lk-text">Wiederkehrende Aufgaben wie Angebote, Berichte und Ablage automatisieren.</p>
          <span class="lk-arrow">→</span>
        </a>

        <a href="/webdesign-selbststaendige" class="lk">
          <span class="lk-emoji">🌐</span>
          <strong class="lk-titel">KI-Website</strong>
          <p class="lk-text">Professioneller Webauftritt der Kunden überzeugt – ab 1.000 € einmalig.</p>
          <span class="lk-arrow">→</span>
        </a>

      </div>
    </div>
  </section>

  <!-- 3. BRANCHEN -->
  <section class="branchen">
    <div class="branchen-inner">
      <h2 class="branchen-h2">Für welche Branchen wir bauen.</h2>
      <p class="branchen-sub">Jede Lösung wird auf die echten Abläufe deiner Branche zugeschnitten.</p>
      <div class="branchen-grid">

        <a href="/webdesign-handwerker" class="branche-karte">
          <span class="branche-emoji">🔨</span>
          <strong class="branche-titel">Handwerksbetriebe</strong>
        </a>

        <a href="/webdesign-aerzte" class="branche-karte">
          <span class="branche-emoji">🏥</span>
          <strong class="branche-titel">Arztpraxen &amp; Praxen</strong>
        </a>

        <a href="/ki-restaurant" class="branche-karte">
          <span class="branche-emoji">🍽️</span>
          <strong class="branche-titel">Restaurants &amp; Gastronomie</strong>
        </a>

        <a href="/ki-kanzlei" class="branche-karte">
          <span class="branche-emoji">⚖️</span>
          <strong class="branche-titel">Kanzleien &amp; Steuerberater</strong>
        </a>

      </div>
      <a href="/ki-fuer-unternehmen" class="branchen-mehr">
        Immobilienmakler, Coaches und weitere Branchen →
      </a>
    </div>
  </section>

  <!-- 4. BEWEIS -->
  <Beweis />

  <!-- 5. PROZESS -->
  <Prozess />

  <!-- 6. CTA -->
  <Cta />

  <!-- 7. FAQ (inline) -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Was dich vielleicht noch beschäftigt.</h2>

      <div class="faq-item">
        <h3>Was kostet das?</h3>
        <p>Die Erstanalyse ist kostenlos. Umsetzungen starten ab 500 €, je nach Umfang. Keine Monatsgebühren, keine versteckten Kosten.</p>
      </div>

      <div class="faq-item">
        <h3>Für wen ist das geeignet?</h3>
        <p>Für Betriebe mit 1–50 Mitarbeitern die Zeit sparen wollen: Handwerker, Praxen, Restaurants, Kanzleien, Makler und Selbstständige.</p>
      </div>

      <div class="faq-item">
        <h3>Wie schnell ist das umgesetzt?</h3>
        <p>In 1–2 Wochen. Du gibst uns 30 Minuten für das Erstgespräch – den Rest machen wir.</p>
      </div>

      <div class="faq-item">
        <h3>Ich habe keine Zeit dafür.</h3>
        <p>Das ist der Punkt. Unser Prozess kostet dich 30 Minuten. Den Rest übernehmen wir – du musst nichts installieren oder einrichten.</p>
      </div>

      <div class="faq-item">
        <h3>Was wenn mir das Ergebnis nicht gefällt?</h3>
        <p>Kein Cent fällig. Wir zeigen dir zuerst was wir bauen wollen – du entscheidest danach.</p>
      </div>

      <div class="faq-item">
        <h3>Wenn KI so viel kann – warum brauche ich noch jemanden?</h3>
        <p>KI macht gute Leute besser – aber sie macht niemanden gut der sich nicht auskennt. Marketing und Betriebsabläufe sind unser Handwerk. KI ist unser Werkzeug.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    background: var(--surface);
    padding: 9rem 1.5rem 6rem;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-right {
    min-height: 300px;
  }

  .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .subtext {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .btn-primary:hover { opacity: 0.88; }

  .btn-ghost {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    background: var(--primary);
    color: #fff;
  }

  .haekchen-liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 2rem;
  }

  .haekchen-liste li {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: var(--on-surface-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .check {
    color: var(--secondary);
    font-weight: 700;
  }

  /* ─────────────────────────────────────────
     LEISTUNGEN
  ───────────────────────────────────────── */
  .leistungen {
    background: var(--surface-low);
    padding: 5rem 1.5rem;
  }

  .leistungen-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .leistungen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .leistungen-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    color: var(--on-surface-muted);
    text-align: center;
    margin-bottom: 3rem;
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .lk {
    background: var(--surface-lowest);
    border: 1px solid var(--dust);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s;
  }

  .lk:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .lk-emoji {
    font-size: 1.75rem;
    line-height: 1;
  }

  .lk-titel {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--on-surface);
  }

  .lk-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: var(--on-surface-muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .lk-arrow {
    margin-top: auto;
    color: var(--secondary);
    font-size: 1rem;
    font-weight: 600;
    align-self: flex-end;
  }

  /* ─────────────────────────────────────────
     BRANCHEN
  ───────────────────────────────────────── */
  .branchen {
    background: var(--primary);
    padding: 5rem 1.5rem;
  }

  .branchen-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .branchen-h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .branchen-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
    margin-bottom: 3rem;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .branche-karte {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 1rem;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.9);
    transition: background 0.2s;
  }

  .branche-karte:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  .branche-emoji {
    font-size: 2rem;
    line-height: 1;
  }

  .branche-titel {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
  }

  .branchen-mehr {
    display: block;
    text-align: center;
    margin-top: 2rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .branchen-mehr:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  /* ─────────────────────────────────────────
     FAQ
  ───────────────────────────────────────── */
  .faq {
    background: var(--surface-low);
    padding: 5rem 1.5rem;
  }

  .faq-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .faq h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
  }

  .faq-item {
    margin-bottom: 2.5rem;
  }

  .faq-item h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
  }

  .faq-item p {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    color: var(--on-surface-muted);
    line-height: 1.7;
  }

  /* ─────────────────────────────────────────
     RESPONSIVE
  ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .leistungen-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .hero-right {
      display: none;
    }

    .branchen-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 6.5rem;
    }

    .leistungen-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
