<style is:global>
  /* ── HERO CHAT PREVIEW ── */
  .hero-chat {
    width: 100%;
    max-width: 360px;
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(63, 69, 48, 0.12);
    overflow: hidden;
    font-family: 'Manrope', system-ui, sans-serif;
  }

  .hero-chat-header {
    background: #3f4530;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
    color: white;
    font-weight: 600;
  }

  .hero-chat-dot {
    color: #34d399;
    font-size: 10px;
  }

  .hero-chat-name {
    letter-spacing: 0.01em;
  }

  .hero-chat-body {
    background: #f5f3f0;
    padding: 1rem;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* User bubble */
  .hero-chat-user {
    align-self: flex-end;
    background: #b80049;
    color: white;
    padding: 0.625rem 0.875rem;
    border-radius: 16px 16px 4px 16px;
    font-size: 13px;
    line-height: 1.5;
    max-width: 85%;
    animation: hcFadeIn 0.3s ease;
  }

  /* Bot row */
  .hero-chat-bot-row {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    max-width: 90%;
    animation: hcFadeIn 0.3s ease;
  }

  .hero-chat-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #3f4530;
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-chat-bot {
    background: white;
    color: #1b1c1a;
    padding: 0.625rem 0.875rem;
    border-radius: 16px 16px 16px 4px;
    font-size: 13px;
    line-height: 1.5;
    border: 1px solid rgba(63, 69, 48, 0.08);
  }

  /* Typing indicator */
  .hero-chat-typing {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .hero-chat-typing-bubble {
    display: flex;
    gap: 4px;
    align-items: center;
    background: white;
    padding: 0.625rem 0.875rem;
    border-radius: 16px 16px 16px 4px;
    border: 1px solid rgba(63, 69, 48, 0.08);
  }

  .hero-chat-dot-anim {
    width: 6px;
    height: 6px;
    background: rgba(63, 69, 48, 0.35);
    border-radius: 50%;
    animation: hcBounce 1.2s infinite;
  }

  .hero-chat-dot-anim:nth-child(2) { animation-delay: 0.15s; }
  .hero-chat-dot-anim:nth-child(3) { animation-delay: 0.3s; }

  @keyframes hcBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  @keyframes hcFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── COUNTER ── */
  .counter-num {
    font-family: 'Noto Serif', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    line-height: 1;
  }

  .counter-label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
  }
</style>

<script>
  // ── HERO CHAT ANIMATION ──
  (function() {
    var messages = [
      { role: 'user', text: 'Ich verpasse täglich Anrufe wenn ich arbeite.' },
      { role: 'bot',  text: 'Das kennen viele Betriebe. Wie viele Anrufe verpasst du ungefähr pro Tag? 📞' },
      { role: 'user', text: 'So 3 bis 5 – manchmal mehr.' },
      { role: 'bot',  text: 'Das sind pro Jahr über 1.000 potenzielle Kunden. KI kann das lösen – soll ich dir zeigen wie?' }
    ];

    var body = document.getElementById('hero-chat-body');
    if (!body) return;

    var idx = 0;
    var timer: ReturnType<typeof setTimeout>;

    function makeAvatar() {
      var av = document.createElement('div');
      av.className = 'hero-chat-avatar';
      av.textContent = 'M';
      return av;
    }

    function showTyping() {
      var row = document.createElement('div');
      row.className = 'hero-chat-typing';
      row.id = 'hc-typing';
      row.innerHTML = '<div class="hero-chat-avatar">M</div><div class="hero-chat-typing-bubble"><div class="hero-chat-dot-anim"></div><div class="hero-chat-dot-anim"></div><div class="hero-chat-dot-anim"></div></div>';
      body!.appendChild(row);
      body!.scrollTop = body!.scrollHeight;
    }

    function removeTyping() {
      var el = document.getElementById('hc-typing');
      if (el) el.remove();
    }

    function addMessage(msg: { role: string; text: string }) {
      if (msg.role === 'user') {
        var el = document.createElement('div');
        el.className = 'hero-chat-user';
        el.textContent = msg.text;
        body!.appendChild(el);
      } else {
        var row = document.createElement('div');
        row.className = 'hero-chat-bot-row';
        var av = document.createElement('div');
        av.className = 'hero-chat-avatar';
        av.textContent = 'M';
        var bubble = document.createElement('div');
        bubble.className = 'hero-chat-bot';
        bubble.textContent = msg.text;
        row.appendChild(av);
        row.appendChild(bubble);
        body!.appendChild(row);
      }
      body!.scrollTop = body!.scrollHeight;
    }

    function step() {
      if (idx >= messages.length) {
        // pause then reset
        timer = setTimeout(function() {
          body!.innerHTML = '';
          idx = 0;
          step();
        }, 4000);
        return;
      }

      var msg = messages[idx];
      idx++;

      if (msg.role === 'user') {
        addMessage(msg);
        timer = setTimeout(step, 1200);
      } else {
        showTyping();
        timer = setTimeout(function() {
          removeTyping();
          addMessage(msg);
          timer = setTimeout(step, 1000);
        }, 1400);
      }
    }

    step();
  })();

  // ── TABS ──
  (function() {
    var buttons = document.querySelectorAll<HTMLElement>('.ki-tabs-btn');
    var contents = document.querySelectorAll<HTMLElement>('.ki-tabs-content');

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.dataset.tab;

        // Update buttons
        buttons.forEach(function(b) { b.classList.remove('ki-tabs-active'); });
        btn.classList.add('ki-tabs-active');

        // Update content
        contents.forEach(function(c) { c.classList.add('ki-tabs-hidden'); });
        var show = document.getElementById('tab-' + target);
        if (show) show.classList.remove('ki-tabs-hidden');
      });
    });
  })();

  // ── COUNTER ANIMATION ──
  (function() {
    var counters = document.querySelectorAll<HTMLElement>('.counter-num');
    var started = false;

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function animateCounter(el: HTMLElement, target: number, duration: number) {
      var start = performance.now();
      function tick(now: number) {
        var elapsed = now - start;
        var progress = Math.min(elapsed / duration, 1);
        el.textContent = String(Math.round(easeOut(progress) * target));
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    var bar = document.getElementById('counter-bar');
    if (!bar) return;

    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !started) {
        started = true;
        counters.forEach(function(el) {
          var target = parseInt(el.dataset.target || '0', 10);
          animateCounter(el, target, 1500);
        });
      }
    }, { threshold: 0.5 });

    observer.observe(bar);
  })();
</script>
