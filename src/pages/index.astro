---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="KI für KMU – Chatbots, Telefonassistenten, E-Mail-Automatisierung, Social Media. Praktisch umsetzbar. Für Handwerker, Ärzte, Restaurants und mehr."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">

      <div class="hero-text-col">
        <p class="eyebrow">KI-Agentur für kleine &amp; mittelständische Betriebe</p>
        <h1>Welches Problem kostet dich täglich die meiste Zeit?</h1>
        <p class="hero-sub">KI übernimmt die Zuarbeit – damit du dich auf das konzentrierst was wirklich zählt. Wir helfen dir herauszufinden wo KI in deinem Betrieb wirklich Sinn ergibt.</p>
        <div class="problem-buttons">
          <a href="/ki-telefonassistent" class="problem-btn">
            <span class="pb-text">📞 Ich verpasse Anrufe und Anfragen</span>
            <span class="pb-arrow">→</span>
          </a>
          <a href="/ki-email" class="problem-btn">
            <span class="pb-text">✉️ Ich verbringe zu viel Zeit mit E-Mails</span>
            <span class="pb-arrow">→</span>
          </a>
          <a href="/ratgeber/ki-im-unternehmen-nutzen" class="problem-btn">
            <span class="pb-text">❓ Ich weiß nicht wo ich mit KI anfangen soll</span>
            <span class="pb-arrow">→</span>
          </a>
        </div>
        <a href="https://calendly.com/onlinemaster711/new-meeting" class="hero-direct-link" target="_blank" rel="noopener noreferrer">Oder direkt Gespräch buchen →</a>
      </div>

      <div class="hero-visual-col">
        <div class="hero-chat" id="hero-chat">
          <div class="hero-chat-header">
            <span class="hero-chat-dot">●</span>
            <span class="hero-chat-status">Online</span>
            <span class="hero-chat-name">MarkMade KI</span>
          </div>
          <div class="hero-chat-body" id="hero-chat-body"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- 2. COUNTER -->
  <div class="counter-bar" id="counter-bar">
    <div class="counter-inner">
      <div class="counter-item">
        <span class="counter-num" data-target="847" id="cnt-0">0</span>
        <span class="counter-label">Stunden gespart</span>
      </div>
      <div class="counter-item">
        <span class="counter-num" data-target="30" id="cnt-1">0</span>
        <span class="counter-label">KI-Lösungen umgesetzt</span>
      </div>
      <div class="counter-item">
        <span class="counter-num" data-target="6" id="cnt-2">0</span>
        <span class="counter-label">Branchen bedient</span>
      </div>
    </div>
  </div>

  <!-- 3. WAS KI ÜBERNIMMT -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">
      <p class="eyebrow-section">Was KI übernimmt</p>
      <h2>KI arbeitet. Du auch – aber das Richtige.</h2>
      <div class="leistungen-grid">
        <a href="/ki-email" class="lk">
          <span class="lk-icon">✉️</span>
          <p class="lk-text">KI beantwortet deine E-Mails.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
        <a href="/ki-telefonassistent" class="lk">
          <span class="lk-icon">📞</span>
          <p class="lk-text">KI nimmt deine Anrufe entgegen.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
        <a href="/terminbuchung-handwerk" class="lk">
          <span class="lk-icon">📅</span>
          <p class="lk-text">KI vergibt Termine in deinen Kalender.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
        <a href="/chatbot-handwerker" class="lk">
          <span class="lk-icon">💬</span>
          <p class="lk-text">KI beantwortet Kundenfragen – rund um die Uhr.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
        <a href="/ki-social-media" class="lk">
          <span class="lk-icon">📱</span>
          <p class="lk-text">KI erstellt deinen Social Media Content.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
        <a href="/ki-automatisierung" class="lk">
          <span class="lk-icon">⚙️</span>
          <p class="lk-text">KI automatisiert deine Prozesse.</p>
          <span class="lk-mehr">Mehr erfahren →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. BRANCHEN -->
  <section class="branchen" id="branchen">
    <div class="branchen-inner">
      <p class="eyebrow-section">Branchenlösungen</p>
      <h2>KI-Lösungen für deine Branche.</h2>
      <p class="section-sub">Jede Branche hat eigene Zeitfresser. Wir kennen sie – und haben konkrete KI-Lösungen.</p>
      <div class="branchen-grid">

        <div class="bk">
          <span class="bk-icon">🔧</span>
          <h3 class="bk-name">Handwerker &amp; Betriebe</h3>
          <div class="bk-pills">
            <span class="bk-pill">Chatbot</span>
            <span class="bk-pill">Terminbuchung</span>
            <span class="bk-pill">Telefonassistent</span>
          </div>
          <div class="bk-links">
            <a href="/webdesign-handwerker" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-handwerker" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

        <div class="bk">
          <span class="bk-icon">🏥</span>
          <h3 class="bk-name">Ärzte &amp; Praxen</h3>
          <div class="bk-pills">
            <span class="bk-pill">Patientenkommunikation</span>
            <span class="bk-pill">Terminbuchung</span>
          </div>
          <div class="bk-links">
            <a href="/chatbot-aerzte" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-aerzte" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

        <div class="bk">
          <span class="bk-icon">🍕</span>
          <h3 class="bk-name">Restaurants &amp; Gastronomie</h3>
          <div class="bk-pills">
            <span class="bk-pill">Reservierungen</span>
            <span class="bk-pill">Speisekarten</span>
            <span class="bk-pill">Bewertungen</span>
          </div>
          <div class="bk-links">
            <a href="/ki-restaurant" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-restaurants" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

        <div class="bk">
          <span class="bk-icon">🏠</span>
          <h3 class="bk-name">Immobilienmakler</h3>
          <div class="bk-pills">
            <span class="bk-pill">Exposés</span>
            <span class="bk-pill">Interessenten</span>
            <span class="bk-pill">Besichtigungen</span>
          </div>
          <div class="bk-links">
            <a href="/ki-immobilienmakler" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-immobilienmakler" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

        <div class="bk">
          <span class="bk-icon">⚖️</span>
          <h3 class="bk-name">Kanzleien &amp; Steuerberater</h3>
          <div class="bk-pills">
            <span class="bk-pill">Mandantenanfragen</span>
            <span class="bk-pill">Termine</span>
            <span class="bk-pill">Schreiben</span>
          </div>
          <div class="bk-links">
            <a href="/ki-kanzlei" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-kanzleien" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

        <div class="bk">
          <span class="bk-icon">💼</span>
          <h3 class="bk-name">Selbstständige &amp; Coaches</h3>
          <div class="bk-pills">
            <span class="bk-pill">Website</span>
            <span class="bk-pill">Social Media</span>
            <span class="bk-pill">E-Mails</span>
          </div>
          <div class="bk-links">
            <a href="/ki-fuer-unternehmen" class="bk-link-main">KI-Lösungen →</a>
            <a href="/ratgeber/ki-fuer-selbststaendige" class="bk-link-rat">Ratgeber lesen →</a>
          </div>
        </div>

      </div>

      <div class="branchen-hinweis">
        <p class="branchen-hinweis-text">Deine Branche nicht dabei?</p>
        <a href="https://calendly.com/onlinemaster711/new-meeting" class="branchen-hinweis-link" target="_blank" rel="noopener noreferrer">Wir entwickeln individuelle KI-Lösungen → Sprich uns an</a>
      </div>
    </div>
  </section>

  <!-- 5. RATGEBER -->
  <section class="ratgeber">
    <div class="ratgeber-inner">
      <p class="eyebrow-section">Kostenlose Ratgeber</p>
      <h2>Versteh zuerst. Dann entscheide.</h2>
      <p class="section-sub">Kein Verkaufsgespräch. Erst verstehen wie KI in deinem Betrieb helfen kann.</p>

      <a href="/ratgeber/ki-im-unternehmen-nutzen" class="rf">
        <div class="rf-left">
          <span class="rf-badge">Empfohlen</span>
          <span class="rf-icon">📖</span>
        </div>
        <div class="rf-right">
          <h3>Wie du erkennst welche Prozesse KI lösen kann</h3>
          <p>Die ehrliche Anleitung – nicht welche Tools du kaufen sollst, sondern wie du die richtigen Fragen stellst.</p>
          <span class="rf-btn">Artikel lesen →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- 6. KI MACHT DICH BESSER -->
  <section class="warum">
    <div class="warum-inner">
      <h2>KI macht dich besser.</h2>
      <div class="warum-grid">
        <div class="wp">
          <h3>Du gibst die Zuarbeit ab.</h3>
          <p>Anfragen beantworten, Termine koordinieren, immer wieder dieselben Fragen – das übernimmt KI. Du konzentrierst dich auf deine Kunden und dein Handwerk.</p>
        </div>
        <div class="wp">
          <h3>Du bleibst der Mensch im Mittelpunkt.</h3>
          <p>KI ersetzt nicht was dich ausmacht – die Beziehung zu deinen Kunden, dein Fachwissen, dein Urteil. Sie übernimmt die Dinge die sich wiederholen.</p>
        </div>
        <div class="wp">
          <h3>Wir bauen es für dich – in wenigen Tagen.</h3>
          <p>Kein monatelanges Projekt. Kein Technik-Wissen nötig. Du erzählst uns was dich täglich Zeit kostet – wir bauen die Lösung.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. BEWEIS -->
  <Beweis />

  <!-- 8. WEBDESIGN HINWEIS -->
  <section class="webdesign-hinweis">
    <div class="wh-inner">
      <p class="wh-label">Auch als vollständige Website-Lösung verfügbar:</p>
      <div class="wh-links">
        <a href="/webdesign-handwerker" class="wh-link">Webdesign für Handwerker</a>
        <a href="/webdesign-aerzte" class="wh-link">Webdesign für Ärzte</a>
        <a href="/webdesign-selbststaendige" class="wh-link">Webdesign für Selbstständige</a>
      </div>
    </div>
  </section>

  <!-- 9. CTA -->
  <section class="cta-final">
    <div class="cta-inner">
      <p class="cta-eyebrow">Kostenlos &amp; unverbindlich</p>
      <h2>Sprich mit uns über deine KI-Lösung.</h2>
      <p class="cta-text">Erzähl uns was dich täglich Zeit kostet. Wir sagen dir ehrlich was KI lösen kann – und bauen es in wenigen Tagen.</p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="cta-btn" target="_blank" rel="noopener noreferrer">Jetzt Gespräch buchen</a>
      <p class="cta-sub">📅 Direkt in den Kalender – kein Telefonat nötig</p>
    </div>
  </section>

  <!-- 10. ABSCHLUSS STREIFEN -->
  <section class="abschluss">
    <div class="abschluss-inner">
      <p class="abschluss-text">Wer ohne KI arbeitet, wird durch KI ersetzt.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    background: var(--surface);
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-visual-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 48ch;
  }

  .problem-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .problem-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: white;
    border: 1.5px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--on-surface);
    transition: border-color 0.2s, color 0.2s;
  }

  .problem-btn:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .pb-text {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .pb-arrow {
    font-size: 1.125rem;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .problem-btn:hover .pb-arrow {
    opacity: 1;
  }

  .hero-direct-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-direct-link:hover {
    color: var(--secondary);
  }

  /* ── COUNTER ── */
  .counter-bar {
    background: var(--primary);
    padding: 1.5rem 0;
  }

  .counter-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .counter-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .counter-num {
    font-family: 'Noto Serif', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    line-height: 1;
  }

  .counter-label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
  }

  /* ── SHARED ── */
  .eyebrow-section {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
    display: block;
    text-align: center;
  }

  h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .section-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    text-align: center;
    max-width: 55ch;
    margin: 0 auto 3rem;
  }

  /* ── LEISTUNGEN ── */
  .leistungen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .leistungen-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .leistungen-inner h2 {
    margin-bottom: 2.5rem;
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .lk {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .lk:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: var(--primary);
  }

  .lk-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .lk-text {
    font-family: 'Noto Serif', serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--on-surface);
    line-height: 1.4;
    margin: 0;
    flex: 1;
  }

  .lk-mehr {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--secondary);
    margin-top: 0.5rem;
  }

  /* ── BRANCHEN ── */
  .branchen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .branchen-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .bk {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .bk:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: var(--primary);
  }

  .bk-icon {
    font-size: 1.8rem;
    line-height: 1;
  }

  .bk-name {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0;
    line-height: 1.3;
  }

  .bk-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .bk-pill {
    font-size: 0.75rem;
    color: var(--on-surface-muted);
    border: 1px solid var(--outline-variant);
    border-radius: 2rem;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .bk-links {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--outline-variant);
  }

  .bk-link-main {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--on-surface);
    text-decoration: none;
    transition: color 0.2s;
  }

  .bk-link-main:hover {
    color: var(--primary);
  }

  .bk-link-rat {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .bk-link-rat:hover {
    opacity: 0.75;
  }

  .branchen-hinweis {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .branchen-hinweis-text {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .branchen-hinweis-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .branchen-hinweis-link:hover {
    opacity: 0.75;
  }

  /* ── RATGEBER ── */
  .ratgeber {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .ratgeber-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .rf {
    display: flex;
    gap: 2rem;
    align-items: center;
    background: var(--primary);
    border-radius: 1.2rem;
    padding: 2rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .rf:hover {
    opacity: 0.92;
  }

  .rf-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .rf-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--secondary);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .rf-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .rf-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .rf-right h3 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0;
  }

  .rf-right p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  .rf-btn {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.625rem;
    padding: 0.4rem 0.875rem;
    width: fit-content;
    margin-top: 0.25rem;
  }

