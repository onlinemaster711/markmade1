    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .sec-effektivitaet .section-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--secondary);
  }

