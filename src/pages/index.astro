---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="KI für KMU – Websites, Chatbots, Automatisierung, Marketing. Praktisch umsetzbar. Einmal bezahlt."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI-Agentur für kleine &amp; mittelständische Betriebe</p>
      <h1>Welches Problem kostet dich täglich die meiste Zeit?</h1>
      <p class="hero-text">
        KI übernimmt die Zuarbeit – damit du dich auf das konzentrierst was wirklich zählt. Wir helfen dir herauszufinden wo KI in deinem Betrieb wirklich Sinn ergibt.
      </p>
      <div class="problem-buttons">
        <a href="/ki-telefonassistent" class="problem-btn">
          <span class="pb-text">📞 Ich verpasse Anrufe und Anfragen</span>
          <span class="pb-arrow">→</span>
        </a>
        <a href="/ki-email" class="problem-btn">
          <span class="pb-text">✉️ Ich verbringe zu viel Zeit mit E-Mails</span>
          <span class="pb-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-im-unternehmen-nutzen" class="problem-btn">
          <span class="pb-text">❓ Ich weiß nicht wo ich mit KI anfangen soll</span>
          <span class="pb-arrow">→</span>
        </a>
      </div>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="hero-direct-link" target="_blank" rel="noopener noreferrer">
        Oder direkt Gespräch buchen →
      </a>
    </div>
  </section>

  <!-- 2. ZEITFRESSER -->
  <section class="zeitfresser" id="leistungen">
    <div class="zeitfresser-inner">
      <p class="eyebrow-section">Häufige Zeitfresser</p>
      <h2>Erkennst du dich wieder?</h2>
      <p class="section-text">Das sind die Probleme die wir täglich von Unternehmern hören – und die KI lösen kann.</p>
      <div class="zeitfresser-grid">

        <div class="zf-karte fade-in">
          <p class="zf-label">Verpasste Anrufe</p>
          <p class="zf-zitat">"Ich bin auf der Baustelle und verpasse ständig Anrufe."</p>
          <p class="zf-loesung">KI-Telefonassistent nimmt Anrufe 24/7 entgegen.</p>
          <a href="/ki-telefonassistent" class="zf-link">Lösung ansehen →</a>
        </div>

        <div class="zf-karte fade-in">
          <p class="zf-label">E-Mail-Flut</p>
          <p class="zf-zitat">"Ich beantworte täglich dieselben E-Mails immer wieder."</p>
          <p class="zf-loesung">KI beantwortet Standardanfragen automatisch.</p>
          <a href="/ki-email" class="zf-link">Lösung ansehen →</a>
        </div>

        <div class="zf-karte fade-in">
          <p class="zf-label">Kundenfragen</p>
          <p class="zf-zitat">"Kunden stellen immer dieselben Fragen – Preise, Ablauf, Zeiten."</p>
          <p class="zf-loesung">KI-Chatbot beantwortet das rund um die Uhr.</p>
          <a href="/chatbot-handwerker" class="zf-link">Lösung ansehen →</a>
        </div>

        <div class="zf-karte fade-in">
          <p class="zf-label">Terminbuchung</p>
          <p class="zf-zitat">"Terminvereinbarungen kosten mich jeden Tag wertvolle Zeit."</p>
          <p class="zf-loesung">Kunden buchen direkt online – ohne Telefonat.</p>
          <a href="/terminbuchung-handwerk" class="zf-link">Lösung ansehen →</a>
        </div>

        <div class="zf-karte fade-in">
          <p class="zf-label">Social Media</p>
          <p class="zf-zitat">"Ich weiß ich sollte präsenter sein – aber ich hab keine Zeit."</p>
          <p class="zf-loesung">KI erstellt Content, du genehmigst in Minuten.</p>
          <a href="/ki-social-media" class="zf-link">Lösung ansehen →</a>
        </div>

        <div class="zf-karte fade-in">
          <p class="zf-label">Wo anfangen?</p>
          <p class="zf-zitat">"Ich höre überall von KI – aber weiß nicht was für mich passt."</p>
          <p class="zf-loesung">Unser Ratgeber zeigt dir wie du vorgehst.</p>
          <a href="/ratgeber/ki-im-unternehmen-nutzen" class="zf-link">Ratgeber lesen →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. BRANCHEN -->
  <section class="branchen" id="branchen">
    <div class="branchen-inner">
      <p class="eyebrow-section">Branchenlösungen</p>
      <h2>Deine Branche hat eigene Herausforderungen.</h2>
      <p class="section-text">Wir kennen die typischen Zeitfresser in deiner Branche – und haben konkrete Lösungen.</p>
      <div class="branchen-grid">

        <div class="branchen-karte fade-in">
          <span class="b-icon">🔧</span>
          <h3>Handwerker &amp; Betriebe</h3>
          <div class="pills">
            <span class="pill">Verpasste Anrufe</span>
            <span class="pill">Terminbuchung</span>
            <span class="pill">Kundenfragen</span>
          </div>
          <a href="/webdesign-handwerker" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-handwerker" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

        <div class="branchen-karte fade-in">
          <span class="b-icon">🏥</span>
          <h3>Ärzte &amp; Praxen</h3>
          <div class="pills">
            <span class="pill">Patientenanfragen</span>
            <span class="pill">Terminbuchung</span>
            <span class="pill">Öffnungszeiten</span>
          </div>
          <a href="/webdesign-aerzte" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-aerzte" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

        <div class="branchen-karte fade-in">
          <span class="b-icon">🍕</span>
          <h3>Restaurants &amp; Gastronomie</h3>
          <div class="pills">
            <span class="pill">Reservierungen</span>
            <span class="pill">Speisekarten</span>
            <span class="pill">Gästeanfragen</span>
          </div>
          <a href="/ki-restaurant" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-restaurants" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

        <div class="branchen-karte fade-in">
          <span class="b-icon">🏠</span>
          <h3>Immobilienmakler</h3>
          <div class="pills">
            <span class="pill">Exposés</span>
            <span class="pill">Interessenten</span>
            <span class="pill">Besichtigungen</span>
          </div>
          <a href="/ki-immobilienmakler" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-immobilienmakler" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

        <div class="branchen-karte fade-in">
          <span class="b-icon">⚖️</span>
          <h3>Kanzleien &amp; Steuerberater</h3>
          <div class="pills">
            <span class="pill">Mandantenanfragen</span>
            <span class="pill">Termine</span>
            <span class="pill">Schreiben</span>
          </div>
          <a href="/ki-kanzlei" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-kanzleien" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

        <div class="branchen-karte fade-in">
          <span class="b-icon">💼</span>
          <h3>Selbstständige &amp; Coaches</h3>
          <div class="pills">
            <span class="pill">Website</span>
            <span class="pill">Social Media</span>
            <span class="pill">E-Mails</span>
          </div>
          <a href="/webdesign-selbststaendige" class="b-link-main">Zur Branchenseite →</a>
          <a href="/ratgeber/ki-fuer-selbststaendige" class="b-link-ratgeber">Ratgeber lesen →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. RATGEBER -->
  <section class="ratgeber">
    <div class="ratgeber-inner">
      <p class="eyebrow-section">Kostenlose Ratgeber</p>
      <h2>Versteh zuerst. Dann entscheide.</h2>
      <p class="section-text">Kein Verkaufsgespräch. Erst verstehen wie KI in deinem Betrieb helfen kann – dann entscheiden ob du weitermachst.</p>

      <!-- Featured Artikel -->
      <a href="/ratgeber/ki-im-unternehmen-nutzen" class="ratgeber-featured fade-in">
        <div class="rf-left">
          <span class="rf-icon">📖</span>
        </div>
        <div class="rf-right">
          <span class="rf-badge">Empfohlen</span>
          <h3>Wie du erkennst welche Prozesse KI lösen kann</h3>
          <p>Die ehrliche Anleitung – nicht welche Tools du kaufen sollst, sondern wie du die richtigen Fragen stellst.</p>
          <span class="rf-cta">Artikel lesen →</span>
        </div>
      </a>

      <!-- Kleinere Karten -->
      <div class="ratgeber-grid">

        <a href="/ratgeber/ki-fuer-handwerker" class="rg-karte fade-in">
          <span class="rg-icon">🔧</span>
          <h3>KI für Handwerker</h3>
          <p>Konkrete Beispiele wie Handwerksbetriebe täglich Zeit sparen.</p>
          <span class="rg-link">Lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-aerzte" class="rg-karte fade-in">
          <span class="rg-icon">🏥</span>
          <h3>KI für Ärzte &amp; Praxen</h3>
          <p>Wie Praxen Patientenkommunikation automatisieren.</p>
          <span class="rg-link">Lesen →</span>
        </a>

        <a href="/ratgeber/ki-fuer-restaurants" class="rg-karte fade-in">
          <span class="rg-icon">🍕</span>
          <h3>KI für Restaurants</h3>
          <p>Reservierungen, Speisekarten und Gästekommunikation.</p>
          <span class="rg-link">Lesen →</span>
        </a>

      </div>

      <div class="ratgeber-alle">
        <a href="/ki-fuer-unternehmen" class="ratgeber-alle-link">Alle Ratgeber &amp; Branchenlösungen →</a>
      </div>

    </div>
  </section>

  <!-- 5. WARUM MARKMADE -->
  <section class="warum">
    <div class="warum-inner">
      <h2>KI die für dich arbeitet – nicht gegen dich.</h2>
      <div class="warum-grid">
        <div class="warum-punkt">
          <span class="warum-icon">💰</span>
          <h3>Einmal bezahlt – kein Abo</h3>
          <p>Keine monatlichen Lizenzkosten. Du bezahlst einmal und behältst die Lösung.</p>
        </div>
        <div class="warum-punkt">
          <span class="warum-icon">🎯</span>
          <h3>Für KMU gemacht</h3>
          <p>Keine Enterprise-Lösungen die niemand versteht. Alles ist auf kleine Betriebe zugeschnitten.</p>
        </div>
        <div class="warum-punkt">
          <span class="warum-icon">⚡</span>
          <h3>Umsetzbar in Tagen</h3>
          <p>Keine monatelangen Projekte. Die meisten Lösungen sind in wenigen Tagen live.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. BEWEIS -->
  <Beweis />

  <!-- 7. CTA CUSTOM -->
  <section class="cta-custom">
    <div class="cta-inner">
      <p class="cta-eyebrow">Kostenlos &amp; unverbindlich</p>
      <h2>Du hast ein konkretes Problem im Kopf?</h2>
      <p class="cta-text">15 Minuten Gespräch – wir sagen dir ehrlich ob und wie KI es lösen kann. Kein Fachjargon. Kein Verkaufsgespräch.</p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="cta-btn" target="_blank" rel="noopener noreferrer">Jetzt Gespräch buchen</a>
      <p class="cta-sub">📅 Direkt in den Kalender – kein Telefonat nötig</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2.5rem;
    max-width: 52ch;
  }

  .problem-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 520px;
    margin-bottom: 1.5rem;
  }

  .problem-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: white;
    border: 1.5px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    text-align: left;
    transition: border-color 0.2s, color 0.2s;
    color: var(--on-surface);
  }

  .problem-btn:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .pb-text {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .pb-arrow {
    font-size: 1.125rem;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .problem-btn:hover .pb-arrow {
    opacity: 1;
  }

  .hero-direct-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-direct-link:hover {
    color: var(--secondary);
  }

  /* ── SHARED ── */
  .eyebrow-section {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
    display: block;
    text-align: center;
  }

  .section-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    text-align: center;
    max-width: 55ch;
    margin: 0 auto 3rem;
  }

  h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  /* ── ZEITFRESSER ── */
  .zeitfresser {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .zeitfresser-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .zeitfresser-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .zf-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: box-shadow 0.2s;
  }

  .zf-karte:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .zf-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--secondary);
    margin: 0;
  }

  .zf-zitat {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--on-surface);
    margin: 0;
    flex: 1;
  }

  .zf-loesung {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .zf-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .zf-link:hover {
    opacity: 0.75;
  }

  /* ── BRANCHEN ── */
  .branchen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .branchen-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .branchen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .branchen-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s;
  }

  .branchen-karte:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .b-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .branchen-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pill {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 100px;
    padding: 0.2rem 0.6rem;
    white-space: nowrap;
  }

  .b-link-main {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface);
    text-decoration: none;
    margin-top: auto;
    transition: color 0.2s;
  }

  .b-link-main:hover {
    color: var(--secondary);
  }

  .b-link-ratgeber {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .b-link-ratgeber:hover {
    opacity: 0.75;
  }

  /* ── RATGEBER ── */
  .ratgeber {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .ratgeber-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ratgeber-featured {
    display: flex;
    gap: 2rem;
    align-items: center;
    background: var(--primary);
    border-radius: 1.2rem;
    padding: 2rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }

  .ratgeber-featured:hover {
    opacity: 0.92;
  }

  .rf-left {
    flex-shrink: 0;
  }

  .rf-icon {
    font-size: 3rem;
    line-height: 1;
  }

  .rf-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rf-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--secondary);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    width: fit-content;
  }

  .rf-right h3 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0;
  }

  .rf-right p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  .rf-cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.625rem;
    padding: 0.4rem 0.875rem;
    width: fit-content;
    margin-top: 0.25rem;
  }

  .ratgeber-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .rg-karte {
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    text-decoration: none;
    transition: box-shadow 0.2s;
  }

  .rg-karte:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .rg-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .rg-karte h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0;
  }

  .rg-karte p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
    flex: 1;
    margin: 0;
  }

  .rg-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--secondary);
    margin-top: auto;
  }

  .ratgeber-alle {
    text-align: center;
  }

  .ratgeber-alle-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ratgeber-alle-link:hover {
    color: var(--secondary);
  }

  /* ── WARUM ── */
  .warum {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .warum-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

