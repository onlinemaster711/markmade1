---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="MarkMade – KI-Agentur für kleine und mittelständische Betriebe"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- ══════════════════════════════════════
       SEKTION 1 — HERO
  ══════════════════════════════════════ -->
  <section class="hero">

    <!-- Subtiler Hintergrund-Gradient -->
    <div class="hero-bg" aria-hidden="true"></div>

    <div class="hero-inner">
      <div class="hero-grid">

        <!-- Linke Spalte (8/12) -->
        <div class="hero-left">

          <!-- Pill Badge -->
          <span class="hero-pill">KI-Agentur für KMU · Einmal gebaut. Dauerhaft im Einsatz.</span>

          <!-- H1 -->
          <h1>
            KI übernimmt,<br>
            <em>was dich aufhält.</em>
          </h1>

          <!-- Subtitle -->
          <p class="subtitle">Damit du dich um das kümmern kannst, was wirklich wichtig ist.</p>

          <!-- Subtext -->
          <p class="subtext">
            Wir bauen KI-Lösungen die in deinem Betrieb tatsächlich Zeit sparen –
            Chatbots, Telefonassistenten, E-Mail-Automatisierung. Kein Abo. Einmal gebaut.
          </p>

          <!-- Buttons -->
          <div class="hero-buttons">
            <a
              href="https://calendly.com/onlinemaster711/new-meeting"
              class="btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >Kostenloses Erstgespräch buchen <span>→</span></a>
            <a href="#leistungen" class="btn-ghost">Leistungen entdecken</a>
          </div>

          <!-- Häkchen -->
          <ul class="haekchen-liste">
            <li><span class="check">✓</span> Kostenlose Erstanalyse</li>
            <li><span class="check">✓</span> Keine laufenden Kosten</li>
            <li><span class="check">✓</span> Umsetzung in 1–2 Wochen</li>
          </ul>

        </div>

        <!-- Rechte Spalte (4/12) -->
        <div class="hero-right">
          <div class="hero-image-placeholder">
            <div class="hero-badge">
              <span>100%</span>
              <p>Maßarbeit</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Use-Case Cards -->
      <div class="use-case-cards">

        <a href="/ki-telefonassistent" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">📞</span></div>
          <strong class="uc-titel">Telefonassistent</strong>
          <p class="uc-text">Nimmt Anrufe an und qualifiziert Anfragen vor.</p>
        </a>

        <a href="/ki-email" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">📧</span></div>
          <strong class="uc-titel">E-Mail-Automatisierung</strong>
          <p class="uc-text">Liest, sortiert und beantwortet E-Mails automatisch.</p>
        </a>

        <a href="/ki-fuer-unternehmen" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">💬</span></div>
          <strong class="uc-titel">KI-Chatbot</strong>
          <p class="uc-text">Beantwortet Kundenfragen rund um die Uhr.</p>
        </a>

        <a href="/ki-automatisierung" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">⚙️</span></div>
          <strong class="uc-titel">Prozessautomatisierung</strong>
          <p class="uc-text">Wiederkehrende Aufgaben automatisch erledigen.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 2 — LEISTUNGEN
  ══════════════════════════════════════ -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">

      <div class="leistungen-header">
        <div>
          <span class="eyebrow-lk">Expertise</span>
          <h2>Was wir für deinen Betrieb bauen.</h2>
        </div>
        <div class="leistungen-watermark" aria-hidden="true">SERVICES</div>
      </div>

      <div class="leistungen-grid-wrapper">
        <div class="leistungen-grid">

          <a href="/ki-fuer-unternehmen" class="lk">
            <span class="lk-icon">💬</span>
            <h3>KI-Chatbot</h3>
            <p class="lk-text">Beantwortet Kundenfragen rund um die Uhr – auch nachts und am Wochenende.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-telefonassistent" class="lk">
            <span class="lk-icon">📞</span>
            <h3>Telefonassistent</h3>
            <p class="lk-text">Nimmt Anrufe an, qualifiziert Anfragen vor und leitet weiter.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-email" class="lk">
            <span class="lk-icon">📧</span>
            <h3>E-Mail-Automatisierung</h3>
            <p class="lk-text">Liest, sortiert und beantwortet eingehende E-Mails automatisch.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">📱</span>
            <h3>Social Media mit KI</h3>
            <p class="lk-text">Erstellt Posts, Bildunterschriften und Content-Pläne auf Knopfdruck.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-automatisierung" class="lk">
            <span class="lk-icon">⚙️</span>
            <h3>Prozessautomatisierung</h3>
            <p class="lk-text">Wiederkehrende Aufgaben wie Angebote, Berichte und Ablage automatisieren.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/webdesign-selbststaendige" class="lk">
            <span class="lk-icon">🌐</span>
            <h3>KI-Website</h3>
            <p class="lk-text">Professioneller Webauftritt der Kunden überzeugt – ab 1.000 € einmalig.</p>
            <div class="lk-line"></div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 3 — BRANCHEN
  ══════════════════════════════════════ -->
  <section class="branchen">
    <div class="branchen-inner">

      <h2 class="branchen-h2">Für welche Branchen wir bauen.</h2>
      <p class="branchen-subtitle">Branchen mit <span>Substanz</span></p>
      <div class="branchen-divider"></div>

      <div class="branchen-grid">

        <div class="branche-karte branche-handwerk">
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Handwerksbetriebe</h3>
            <a href="/webdesign-handwerker">Website für Handwerker</a>
            <a href="/ki-handwerker">KI für Handwerker</a>
          </div>
        </div>

        <div class="branche-karte branche-aerzte">
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Arztpraxen</h3>
            <a href="/webdesign-aerzte">Website für Ärzte</a>
            <a href="/ki-aerzte">KI für Ärzte &amp; Praxen</a>
          </div>
        </div>

        <div class="branche-karte branche-restaurants">
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Restaurants</h3>
            <a href="/ki-restaurant">KI für Restaurants</a>
          </div>
        </div>

        <div class="branche-karte branche-kanzleien">
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Kanzleien</h3>
            <a href="/ki-kanzlei">KI für Kanzleien</a>
          </div>
        </div>

        <div class="branche-karte branche-immobilien">
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Immobilienmakler</h3>
            <a href="/ki-immobilienmakler">KI für Immobilienmakler</a>
          </div>
        </div>

      </div>

      <a href="/ki-fuer-unternehmen" class="branchen-mehr">
        Coaches, Selbstständige und weitere Branchen →
      </a>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 4 — BEWEIS
  ══════════════════════════════════════ -->
  <Beweis />

  <!-- ══════════════════════════════════════
       SEKTION 5 — CTA
  ══════════════════════════════════════ -->
  <Cta />

  <!-- ══════════════════════════════════════
       SEKTION 6 — FAQ
  ══════════════════════════════════════ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Häufige Fragen</h2>

      <div class="faq-item">
        <h3>Was kostet das?</h3>
        <p>Die Erstanalyse ist kostenlos. Umsetzungen starten ab 500 €, je nach Umfang. Keine Monatsgebühren, keine versteckten Kosten.</p>
      </div>

      <div class="faq-item">
        <h3>Für wen ist das geeignet?</h3>
        <p>Für Betriebe mit 1–50 Mitarbeitern die Zeit sparen wollen: Handwerker, Praxen, Restaurants, Kanzleien, Makler und Selbstständige.</p>
      </div>

      <div class="faq-item faq-highlight">
        <h3>Wie schnell ist das umgesetzt?</h3>
        <p>In 1–2 Wochen. Du gibst uns 30 Minuten für das Erstgespräch – den Rest machen wir.</p>
      </div>

      <div class="faq-item">
        <h3>Ich habe keine Zeit dafür.</h3>
        <p>Das ist der Punkt. Unser Prozess kostet dich 30 Minuten. Den Rest übernehmen wir – du musst nichts installieren oder einrichten.</p>
      </div>

      <div class="faq-item">
        <h3>Was wenn mir das Ergebnis nicht gefällt?</h3>
        <p>Kein Cent fällig. Wir zeigen dir zuerst was wir bauen wollen – du entscheidest danach.</p>
      </div>

      <div class="faq-item faq-item--last">
        <h3>Wenn KI so viel kann – warum brauche ich noch jemanden?</h3>
        <p>KI macht gute Leute besser – aber sie macht niemanden gut der sich nicht auskennt. Marketing und Betriebsabläufe sind unser Handwerk. KI ist unser Werkzeug.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    background: var(--surface);
    padding: 160px 24px 120px;
    position: relative;
    overflow: hidden;
  }

  /* Subtiler radialer Hintergrund */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 70% 30%, rgba(223, 230, 201, 0.35) 0%, transparent 55%),
      radial-gradient(circle at 20% 80%, rgba(255, 178, 190, 0.12) 0%, transparent 45%);
  }

  .hero-inner {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .hero-left {
    grid-column: span 8;
  }

  .hero-right {
    grid-column: span 4;
    position: relative;
  }

  /* Pill Badge */
  .hero-pill {
    display: inline-block;
    margin-bottom: 1.5rem;
    padding: 6px 16px;
    border-radius: 99px;
    border: 1px solid var(--dust);
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
  }

  /* H1 */
  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  h1 em {
    color: var(--secondary);
    font-style: italic;
  }

  /* Subtitle */
  .subtitle {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--on-surface-muted);
    margin-bottom: 1rem;
  }

  /* Subtext */
  .subtext {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--on-surface-muted);
    line-height: 1.7;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 0.375rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--primary-container);
  }

  .btn-ghost {
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--dust);
    padding: 1rem 2rem;
    border-radius: 0.375rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    background: var(--surface-low);
  }

  /* Häkchen */
  .haekchen-liste {
    list-style: none;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .haekchen-liste li {
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    color: var(--on-surface-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .check {
    color: var(--secondary);
    font-weight: 700;
  }

  /* Rechte Spalte — Bild-Platzhalter */
  .hero-image-placeholder {
    aspect-ratio: 4 / 5;
    background: var(--surface-low);
    border-radius: 0.5rem;
    position: relative;
  }

  .hero-badge {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    background: var(--secondary);
    padding: 1.5rem 2rem;
    box-shadow: 0 20px 40px rgba(184, 0, 73, 0.2);
    border-radius: 0.25rem;
  }

  .hero-badge span {
    font-family: 'Noto Serif', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    display: block;
    margin-bottom: 4px;
  }

  .hero-badge p {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* Use-Case Cards */
  .use-case-cards {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .uc-card {
    background: transparent;
    border: 1px solid var(--dust);
    border-radius: 0.375rem;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .uc-card:hover {
    border-color: var(--secondary);
    transform: translateY(-4px);
  }

  .uc-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface-low);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .uc-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .uc-titel {
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface);
    display: block;
  }

  .uc-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  /* ─────────────────────────────────────────
     LEISTUNGEN
  ───────────────────────────────────────── */
  .leistungen {
    background: var(--surface-low);
    padding: 128px 24px;
  }

  .leistungen-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .leistungen-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 2rem;
  }

  .eyebrow-lk {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  .leistungen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--primary);
    margin: 0;
  }

  .leistungen-watermark {
    font-family: 'Manrope', sans-serif;
    font-size: 4rem;
    font-weight: 700;
    color: var(--on-surface);
    opacity: 0.05;
    letter-spacing: -0.02em;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1;
    user-select: none;
  }

  /* Grid-Wrapper schafft 1px-Linien via gap auf dust-Hintergrund */
  .leistungen-grid-wrapper {
    background: var(--dust);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(27, 28, 26, 0.06);
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  /* Service-Karte */
  .lk {
    background: var(--surface-lowest);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: background 0.5s ease;
  }

  .lk:hover {
    background: var(--primary);
  }

  .lk-icon {
    font-size: 2rem;
    color: var(--secondary);
    margin-bottom: 2rem;
    display: block;
    transition: color 0.5s ease;
  }

  .lk:hover .lk-icon {
    color: var(--primary-fixed);
  }

  .lk h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    color: var(--primary);
    margin-bottom: 1rem;
    font-weight: 700;
    transition: color 0.5s ease;
  }

  .lk:hover h3 {
    color: #fff;
  }

  .lk-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--on-surface-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    flex-grow: 1;
    transition: color 0.5s ease;
  }

  .lk:hover .lk-text {
    color: var(--primary-fixed);
  }

  .lk-line {
    height: 2px;
    width: 3rem;
    background: var(--secondary);
    margin-top: auto;
    transition: width 0.5s ease, background 0.5s ease;
  }

  .lk:hover .lk-line {
    width: 100%;
    background: var(--primary-fixed);
  }

  /* ─────────────────────────────────────────
     BRANCHEN
  ───────────────────────────────────────── */
  .branchen {
    background: var(--surface);
    padding: 128px 24px;
  }

  .branchen-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .branchen-h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--on-surface);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .branchen-subtitle {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--on-surface-muted);
    text-align: center;
  }

  .branchen-subtitle span {
    color: var(--secondary);
  }

  .branchen-divider {
    width: 6rem;
    height: 2px;
    background: var(--primary);
    margin: 1.5rem auto 4rem;
  }

  /* Branchen-Grid: 5 Spalten, erste Karte doppelt so breit */
  .branchen-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 1rem;
    height: 600px;
  }

  /* Einzelne Karte */
  .branche-karte {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    cursor: default;
  }

  .branche-handwerk  { background: linear-gradient(135deg, #3f4530 0%, #565d46 100%); }
  .branche-aerzte    { background: linear-gradient(135deg, #4a5568 0%, #2d3748 100%); }
  .branche-restaurants { background: linear-gradient(135deg, #742a2a 0%, #9b2c2c 100%); }
  .branche-kanzleien { background: linear-gradient(135deg, #1a365d 0%, #2a4365 100%); }
  .branche-immobilien { background: linear-gradient(135deg, #22543d 0%, #276749 100%); }

  /* Overlay */
  .branche-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      transparent 100%
    );
    transition: background 0.3s ease;
  }

  .branche-karte:hover .branche-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      transparent 100%
    );
  }

  /* Inhalt absolut unten links */
  .branche-inhalt {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    z-index: 1;
  }

  .branche-inhalt h3 {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    color: #fff;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  /* Erste Karte (Handwerker) — größerer H3 */
  .branche-handwerk .branche-inhalt h3 {
    font-size: 2rem;
  }

  /* Karten 2–5 — kleinerer H3 */
  .branche-aerzte .branche-inhalt h3,
  .branche-restaurants .branche-inhalt h3,
  .branche-kanzleien .branche-inhalt h3,
  .branche-immobilien .branche-inhalt h3 {
    font-size: 1.5rem;
  }

  .branche-inhalt a {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
