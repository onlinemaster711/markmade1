---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cta from '../components/Cta.astro';
import WasKiMacht from '../components/WasKiMacht.astro';
---

<BaseLayout
  title="KI-Agentur für KMU – Chatbots & Automatisierung | MarkMade"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- ══════════════════════════════════════
       SEKTION 1 — HERO
  ══════════════════════════════════════ -->
  <Hero
    eyebrow="KI Agentur · Stuttgart"
    heading="KI macht dich besser."
    subtext="Eine Person mit KI schlägt ein Team ohne."
    primaryCtaText="Kostenloses Erstgespräch buchen"
    primaryCtaHref="https://calendly.com/onlinemaster711/new-meeting"
  />

  <!-- ══════════════════════════════════════
       SEKTION 2 — WAS KI HEUTE SCHON MACHT
  ══════════════════════════════════════ -->
  <WasKiMacht />

  <!-- ══════════════════════════════════════
       SEKTION 3 — WIE WIR ARBEITEN
  ══════════════════════════════════════ -->
  <section class="section sec-arbeitsweise">
    <div class="section-inner">
      <div class="section-eyebrow"><span>03 — Wie wir arbeiten</span></div>
      <h2 class="section-headline">Keine Software. Kein Abo. Keine Überraschungen.</h2>

      <div class="arbeitsweise-statement">
        <p>Du sagst uns wie du arbeitest.</p>
        <p>Wir bauen die KI die das übernimmt.</p>
        <p>Einmal bezahlt. Dauerhaft im Einsatz.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 4 — FAQ
  ══════════════════════════════════════ -->
  <section class="section sec-faq" id="faq">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow"><span>04 — Häufige Fragen</span></div>
        <h2 class="section-headline">Häufige Fragen</h2>
      </div>

      <div class="faq-liste">
        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">01</span>
            <span class="faq-titel">Was kann man alles mit KI bearbeiten?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Telefon. E-Mails. Angebote. Social Media. Kundenanfragen. Termine. Dokumente. Grob gesagt: Alles was sich wiederholt. Was du nicht mehr selbst machen willst, kann KI übernehmen — wenn sie richtig eingerichtet ist.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">02</span>
            <span class="faq-titel">Wie hilft mir das tatsächlich in meinem Alltag?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Du hast Freitag Abend nicht mehr 40 offene Mails. Du schreibst keine Angebote mehr in 2 Stunden. Du nimmst nicht mehr jedes Telefonat an. Du machst die Arbeit für die man dich bezahlt — den Rest macht KI.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">03</span>
            <span class="faq-titel">Ich bin kein Technik-Experte — geht das trotzdem?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Genau dafür gibt's uns. Du musst KI nicht verstehen. Du musst nur wissen wie du arbeitest. Den Rest übersetzen wir.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">04</span>
            <span class="faq-titel">Wie läuft die Wartung? Was wenn sich was ändert?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Wir bleiben dran. Wenn sich bei dir was ändert — neue Leistung, andere Preise, neuer Mitarbeiter — passen wir die KI an. Das ist kein Zusatzservice, das gehört dazu.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">05</span>
            <span class="faq-titel">Was unterscheidet euch von anderen KI-Anbietern?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Andere verkaufen dir Software. Wir verkaufen dir keine Software — wir optimieren deine Prozesse. Und wir verschwinden nicht nach der Einrichtung.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-frage">
            <span class="faq-nummer">06</span>
            <span class="faq-titel">Was passiert wenn ich jetzt nichts tue?</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-antwort">
            <p>Deine Konkurrenz wird schneller. In einem Jahr schafft sie in einer Woche was du in fünf brauchst. Wer nicht mitzieht, verliert den Anschluss — nicht dramatisch, aber unumkehrbar.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 5 — CTA
  ══════════════════════════════════════ -->
  <Cta />

</BaseLayout>

<style>
  /* Hero wird durch Hero.astro Component gerendert (scoped styles dort) */

  /* ─────────────────────────────────────────
     FAQ — Editorial Akkordeon
  ───────────────────────────────────────── */
  .sec-faq {
    background: var(--surface-low);
    padding: 6rem 2rem;
  }

  .sec-faq .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .sec-faq .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .sec-faq .section-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
  }

  .sec-faq .section-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--secondary);
  }

  .sec-faq .section-headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--on-surface);
    margin: 1rem 0 0 0;
    letter-spacing: -0.01em;
  }

  /* FAQ-Liste */
  .faq-liste {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid var(--dust);
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--dust);
  }

  .faq-frage {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1.5rem 0;
    cursor: pointer;
    list-style: none;
  }
  .faq-frage::-webkit-details-marker { display: none; }

  .faq-nummer {
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    letter-spacing: 0.05em;
    min-width: 2rem;
  }

  .faq-titel {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--on-surface);
    line-height: 1.3;
  }

  .faq-icon {
    font-family: 'Manrope', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    transition: transform 0.3s ease;
    line-height: 1;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-antwort {
    padding: 0 0 1.5rem calc(2rem + 1.5rem);
  }

  .faq-antwort p {
    font-family: 'Manrope', sans-serif;
    font-size: 1.3125rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    line-height: 1.6;
    margin: 0;
    max-width: 680px;
  }

  @media (max-width: 760px) {
    .sec-faq { padding: 4rem 1.25rem; }
    .sec-faq .section-header { margin-bottom: 3rem; }

    .faq-frage {
      grid-template-columns: 1fr auto;
      gap: 1rem;
      padding: 1.25rem 0;
    }
    .faq-nummer {
      display: none;
    }
    .faq-titel {
      font-size: 1.5rem;
    }
    .faq-antwort {
      padding: 0 0 1.25rem 0;
    }
  }

  /* ─────────────────────────────────────────
     ARBEITSWEISE — Wie wir arbeiten
  ───────────────────────────────────────── */
  .sec-arbeitsweise {
    background: var(--surface-low);
    padding: 6rem 2rem;
  }

  .sec-arbeitsweise .section-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .sec-arbeitsweise .section-headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--on-surface);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 1rem 0 4rem 0;
    text-wrap: balance;
  }

  .arbeitsweise-statement {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .arbeitsweise-statement p {
    font-family: 'Manrope', sans-serif;
    font-size: 1.3125rem;
    font-weight: 500;
    color: var(--on-surface);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 760px) {
    .sec-arbeitsweise { padding: 4rem 1.5rem; }
    .sec-arbeitsweise .section-headline { margin-bottom: 3rem; }
  }
</style>

<script>
  // Auf Desktop: alle FAQ-Items beim Laden öffnen
  // Auf Mobile: alle geschlossen lassen (Akkordeon-Verhalten)
  if (window.matchMedia('(min-width: 761px)').matches) {
    document.querySelectorAll('.faq-item').forEach(item => {
      item.setAttribute('open', '');
    });
  }
</script>
