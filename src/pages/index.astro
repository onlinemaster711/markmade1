---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beweis from '../components/Beweis.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI-Agentur für KMU – Chatbots & Automatisierung | MarkMade"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- ══════════════════════════════════════
       SEKTION 1 — HERO
  ══════════════════════════════════════ -->
  <section class="hero">

    <!-- Subtiler Hintergrund-Gradient -->
    <div class="hero-bg" aria-hidden="true"></div>

    <div class="hero-inner">
      <div class="hero-grid">

        <!-- Linke Spalte (8/12) -->
        <div class="hero-left">

          <!-- H1 -->
          <h1>
            KI macht dich <em>besser.</em>
          </h1>

          <!-- Subtitle -->
          <p class="subtitle">Eine Person mit KI schlägt ein Team ohne. Wir zeigen dir wie.</p>

          <!-- Subtext -->
          <p class="subtext">
            Wir bauen KI-Lösungen für kleine und mittelständische Betriebe —
            Standard oder individuell, exakt auf deinen Betrieb zugeschnitten.
          </p>

          <!-- Buttons -->
          <div class="hero-buttons">
            <a
              href="https://calendly.com/onlinemaster711/new-meeting"
              class="btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >Kostenloses Erstgespräch buchen <span>→</span></a>
            <a href="#leistungen" class="btn-ghost">Leistungen entdecken</a>
          </div>

        </div>

        <!-- Rechte Spalte (4/12) -->
        <div class="hero-right">
          <img
            src="/hero-main.webp"
            alt="KI-Agentur MarkMade – KI-Lösungen für kleine Betriebe"
            width="800"
            height="1000"
            style="width:100%; height:100%; object-fit:cover; border-radius:0.5rem; display:block;"
          />
        </div>

      </div>

    </div>
  </section>

  <!-- Use-Case Karten — direkt nach Hero -->
  <section class="use-case-section">
    <div class="use-case-inner">
      <div class="use-case-cards">

        <a href="/ki-telefonassistent" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">📞</span></div>
          <strong class="uc-titel">Du gehst nie mehr ans Telefon.</strong>
          <p class="uc-text">KI nimmt an, qualifiziert vor und schickt dir nur was wirklich wichtig ist.</p>
        </a>

        <a href="/ki-email" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">📧</span></div>
          <strong class="uc-titel">Dein Postfach arbeitet alleine.</strong>
          <p class="uc-text">KI liest, sortiert und antwortet. Du siehst nur was deine Aufmerksamkeit braucht.</p>
        </a>

        <a href="/ki-fuer-unternehmen" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">💬</span></div>
          <strong class="uc-titel">Kunden bekommen sofort Antworten.</strong>
          <p class="uc-text">Dein KI-Chatbot ist rund um die Uhr da — auch wenn du es nicht bist.</p>
        </a>

        <a href="/ki-automatisierung" class="uc-card">
          <div class="uc-icon-wrap"><span class="uc-icon">⚙️</span></div>
          <strong class="uc-titel">Was sich wiederholt, läuft automatisch.</strong>
          <p class="uc-text">Angebote, Berichte, Ablage — KI übernimmt den Kleinkram.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 2 — LEISTUNGEN
  ══════════════════════════════════════ -->
  <section class="leistungen" id="leistungen">
    <div class="leistungen-inner">

      <div class="leistungen-header">
        <div>
          <span class="eyebrow-lk">Expertise</span>
          <h2>Dein KI-Team.</h2>
          <p class="leistungen-subtext">Sechs Rollen. Kein Gehalt. Kein Urlaub. Kein Krankenstand.</p>
        </div>
        <div class="leistungen-watermark" aria-hidden="true">SERVICES</div>
      </div>

      <div class="leistungen-grid-wrapper">
        <div class="leistungen-grid">

          <a href="/ki-fuer-unternehmen" class="lk">
            <span class="lk-icon">💬</span>
            <h3>KI-Chatbot</h3>
            <p class="lk-text">Dein Kundenbetreuer. Antwortet sofort, rund um die Uhr, auf jede Frage — ohne dass du dabei sein musst.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-telefonassistent" class="lk">
            <span class="lk-icon">📞</span>
            <h3>Telefonassistent</h3>
            <p class="lk-text">Deine Assistentin am Telefon. Nimmt an, klärt vor, leitet weiter. Du wirst nur informiert wenn es zählt.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-email" class="lk">
            <span class="lk-icon">📧</span>
            <h3>E-Mail-Automatisierung</h3>
            <p class="lk-text">Dein Büromanager. Liest alles, beantwortet Routinefragen, priorisiert was deine Aufmerksamkeit braucht.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">📱</span>
            <h3>Social Media mit KI</h3>
            <p class="lk-text">Dein Content-Team. Erstellt Posts, Texte und Pläne — du musst nur noch freigeben.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-automatisierung" class="lk">
            <span class="lk-icon">⚙️</span>
            <h3>Prozessautomatisierung</h3>
            <p class="lk-text">Dein Sachbearbeiter. Wiederkehrende Aufgaben laufen automatisch — ohne dass du daran denkst.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/webdesign-selbststaendige" class="lk">
            <span class="lk-icon">🌐</span>
            <h3>KI-Website</h3>
            <p class="lk-text">Dein Vertriebsmitarbeiter. Überzeugt Besucher, beantwortet Fragen, bringt Anfragen — 24/7.</p>
            <div class="lk-line"></div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 3 — KI-EFFEKTIVITÄT
  ══════════════════════════════════════ -->
  <section class="ki-effekt">
    <div class="ki-effekt-inner">

      <span class="ki-effekt-eyebrow">MEHR OUTPUT. WENIGER AUFWAND.</span>
      <h2 class="ki-effekt-h2">Was früher eine Woche dauerte,<br>schaffst du heute an einem Tag.</h2>

      <div class="ki-effekt-text">
        <p>Wer KI richtig einsetzt, schafft in einer Woche was andere in fünf schaffen. Das ist kein Versprechen — das ist Mathematik. Gleiche Zeit, fünffacher Output. Wer das nutzt, gewinnt.</p>
        <p>Wir bauen keine Standard-Software und lassen dich damit alleine. Wir optimieren deine Prozesse. Du sagst uns wie du arbeitest — wir geben der KI die Informationen die sie braucht um für dich bestmögliche Ergebnisse zu liefern. Mit deinem Wissen. Deiner Stimme. Deinem Design.</p>
        <p class="ki-effekt-highlight">Als kleines oder mittelständisches Unternehmen kannst du mit KI die Großen angreifen. Nicht irgendwann. Jetzt.</p>
      </div>

      <a
        href="https://calendly.com/onlinemaster711/new-meeting"
        class="ki-effekt-btn"
        target="_blank"
        rel="noopener noreferrer"
      >Sag uns wie du arbeitest — wir finden die Lösung</a>

      <div class="vergleich-boxen">

        <div class="vergleich-box">
          <span class="vergleich-label">TELEFON &amp; ANFRAGEN</span>
          <div class="vergleich-row">
            <span class="vergleich-vorher">3 Mitarbeiter</span>
            <span class="vergleich-pfeil">→</span>
            <span class="vergleich-nachher">1 Person + KI</span>
          </div>
        </div>

        <div class="vergleich-box">
          <span class="vergleich-label">WOCHENOUTPUT</span>
          <div class="vergleich-row">
            <span class="vergleich-vorher">1 Woche Arbeit</span>
            <span class="vergleich-pfeil">→</span>
            <span class="vergleich-nachher">1 Tag mit KI</span>
          </div>
        </div>

        <div class="vergleich-box">
          <span class="vergleich-label">SOCIAL MEDIA</span>
          <div class="vergleich-row">
            <span class="vergleich-vorher">5 Wochen</span>
            <span class="vergleich-pfeil">→</span>
            <span class="vergleich-nachher">1 Woche mit KI</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 4 — SOCIAL MEDIA MIT KI
  ══════════════════════════════════════ -->
  <section class="social-media-sek">
    <div class="social-media-inner">

      <div class="social-media-header">
        <span class="eyebrow-lk">SOCIAL MEDIA &amp; CONTENT MIT KI</span>
        <h2>Einmal erstellt. Überall verteilt.<br>Immer ausgewertet.</h2>
        <p class="social-media-subtext">Konstantes Design. Deine Stimme. Automatisch auf allen Plattformen.</p>
      </div>

      <div class="leistungen-grid-wrapper">
        <div class="leistungen-grid social-karten">

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">📹</span>
            <h3>Video-Distribution</h3>
            <p class="lk-text">Ein Video — automatisch aufbereitet und auf 6 Plattformen verteilt. Einmal hochladen, überall präsent.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">📊</span>
            <h3>Performance-Überwachung</h3>
            <p class="lk-text">Wir überwachen welcher Beitrag wie performt — und optimieren automatisch was nicht funktioniert.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">🎨</span>
            <h3>Konstantes Design</h3>
            <p class="lk-text">Jeder Post sieht aus wie du. KI hält dein Design konsistent — auf allen Kanälen, immer.</p>
            <div class="lk-line"></div>
          </a>

          <a href="/ki-social-media" class="lk">
            <span class="lk-icon">🧠</span>
            <h3>Dein Wissen als Inhalt</h3>
            <p class="lk-text">KI erstellt Inhalte die auf deinem Fachwissen basieren — mit deiner Stimme, deiner Haltung, deinem Stil.</p>
            <div class="lk-line"></div>
          </a>

        </div>
      </div>

      <div class="social-media-cta">
        <p class="social-media-cta-text">Wer eine Woche mit KI an Social Media arbeitet, ist so effektiv wie andere in fünf. Sprich mit uns — wir zeigen dir wie.</p>
        <a
          href="https://calendly.com/onlinemaster711/new-meeting"
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >Jetzt Gespräch buchen →</a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 5 — BRANCHEN
  ══════════════════════════════════════ -->
  <section class="branchen">
    <div class="branchen-inner">

      <h2 class="branchen-h2">Für welche Branchen wir bauen.</h2>
      <p class="branchen-subtitle">Branchen mit <span>Substanz</span></p>
      <div class="branchen-divider"></div>

      <div class="branchen-grid">

        <div class="branche-karte branche-handwerk">
          <img src="/branche-handwerk.webp" alt="KI für Handwerksbetriebe" class="branche-bg-img" loading="lazy" width="600" height="400" />
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Handwerksbetriebe</h3>
            <a href="/ki-handwerker">KI für Handwerker</a>
          </div>
        </div>

        <div class="branche-karte branche-aerzte">
          <img src="/branche-aerzte.webp" alt="KI für Arztpraxen" class="branche-bg-img" loading="lazy" width="600" height="400" />
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Arztpraxen</h3>
            <a href="/ki-aerzte">KI für Ärzte &amp; Praxen</a>
          </div>
        </div>

        <div class="branche-karte branche-restaurants">
          <img src="/branche-restaurant.webp" alt="KI für Restaurants" class="branche-bg-img" loading="lazy" width="600" height="400" />
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Restaurants</h3>
            <a href="/ki-restaurant">KI für Restaurants</a>
          </div>
        </div>

        <div class="branche-karte branche-kanzleien">
          <img src="/branche-kanzlei.webp" alt="KI für Kanzleien" class="branche-bg-img" loading="lazy" width="600" height="400" />
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Kanzleien</h3>
            <a href="/ki-kanzlei">KI für Kanzleien</a>
          </div>
        </div>

        <div class="branche-karte branche-immobilien">
          <img src="/branche-immobilien.webp" alt="KI für Immobilienmakler" class="branche-bg-img" loading="lazy" width="600" height="400" />
          <div class="branche-overlay"></div>
          <div class="branche-inhalt">
            <h3>Immobilien-<br>makler</h3>
            <a href="/ki-immobilienmakler">KI für Immobilienmakler</a>
          </div>
        </div>

      </div>

      <a href="/ki-fuer-unternehmen" class="branchen-mehr">
        Coaches, Selbstständige und weitere Branchen →
      </a>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 4 — BEWEIS
  ══════════════════════════════════════ -->
  <Beweis />

  <!-- ══════════════════════════════════════
       SEKTION 5 — CTA
  ══════════════════════════════════════ -->
  <Cta />

  <!-- ══════════════════════════════════════
       SEKTION 6 — FAQ
  ══════════════════════════════════════ -->
  <section class="faq">
    <div class="faq-inner">
      <h2>Häufige Fragen</h2>

      <div class="faq-item">
        <h3>Kann KI wirklich einen Unterschied machen — oder ist das Hype?</h3>
        <p>Wer KI richtig einsetzt, schafft heute in einer Woche was andere in fünf schaffen. Das ist kein Versprechen — das ist Mathematik. Gleiche Zeit, fünffacher Output. Wer das nutzt, gewinnt.</p>
      </div>

      <div class="faq-item">
        <h3>Was bringt mir das konkret in meinem Alltag?</h3>
        <p>Du hörst auf Dinge zu tun die sich wiederholen. KI übernimmt Telefon, E-Mails, Dokumente, Social Media. Du konzentrierst dich auf das was nur du kannst — und wirst darin besser als je zuvor.</p>
      </div>

      <div class="faq-item faq-highlight">
        <h3>Ich bin kein Technik-Experte. Kann ich das trotzdem nutzen?</h3>
        <p>Das ist genau der Punkt. Du musst kein Technik-Experte sein. Du sagst uns wie du arbeitest — wir geben der KI die Informationen die sie braucht um für dich zu arbeiten. Du nutzt das Ergebnis. Fertig.</p>
      </div>

      <div class="faq-item">
        <h3>Was unterscheidet MarkMade von anderen KI-Anbietern?</h3>
        <p>Wir verkaufen keine Software. Wir optimieren Prozesse. Der Unterschied: Software kannst du kaufen und trotzdem nichts damit anfangen. Wir sorgen dafür dass KI wirklich für deinen Betrieb arbeitet — mit deinem Wissen, deiner Stimme, deinem Design.</p>
      </div>

      <div class="faq-item">
        <h3>Was passiert wenn ich jetzt nichts tue?</h3>
        <p>Deine Konkurrenz die KI nutzt, wird in einem Jahr so viel mehr geschafft haben dass der Abstand kaum noch aufzuholen ist. Die Arbeitswelt befindet sich im größten Wandel ihrer Geschichte. Wer jetzt nicht anfängt, fängt zu spät an.</p>
      </div>

      <div class="faq-item faq-item--last">
        <h3>Wie schnell sehe ich Ergebnisse?</h3>
        <p>In 1–2 Wochen läuft deine erste KI-Lösung. Nicht ein Prototyp — eine echte Lösung die täglich arbeitet. Die meisten unserer Kunden sehen in der ersten Woche wie viel Zeit sie bisher verschenkt haben.</p>
      </div>

      <div class="faq-statement">
        <p>Wer als kleines oder mittelständisches Unternehmen KI richtig einsetzt, kann die Großen angreifen. Nicht irgendwann. Jetzt. Das ist der größte Wandel in der Geschichte der Arbeit — und du kannst auf der richtigen Seite davon stehen.</p>
        <a
          href="https://calendly.com/onlinemaster711/new-meeting"
          class="faq-statement-btn"
          target="_blank"
          rel="noopener noreferrer"
        >Jetzt auf der richtigen Seite stehen →</a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    background: var(--surface);
    padding: 160px 24px 120px;
    position: relative;
    overflow: hidden;
  }

  /* Subtiler radialer Hintergrund */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 70% 30%, rgba(223, 230, 201, 0.35) 0%, transparent 55%),
      radial-gradient(circle at 20% 80%, rgba(255, 178, 190, 0.12) 0%, transparent 45%);
  }

  .hero-inner {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .hero-left {
    grid-column: span 8;
  }

  .hero-right {
    grid-column: span 4;
    position: relative;
  }

  /* H1 */
  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  h1 em {
    color: var(--secondary);
    font-style: italic;
  }

  /* Subtitle */
  .subtitle {
    font-family: 'Noto Serif', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--on-surface-muted);
    margin-bottom: 1rem;
  }

  /* Subtext */
  .subtext {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--on-surface-muted);
    line-height: 1.7;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 0.375rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--primary-container);
  }

  .btn-ghost {
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--dust);
    padding: 1rem 2rem;
    border-radius: 0.375rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    background: var(--surface-low);
  }

  /* Rechte Spalte — Bild-Platzhalter */
  .hero-image-placeholder {
    aspect-ratio: 4 / 5;
    background: var(--surface-low);
    border-radius: 0.5rem;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Use-Case Sektion */
  .use-case-section {
    background: var(--surface);
    padding: 0 24px 80px;
  }

  .use-case-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .use-case-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .uc-card {
    background: transparent;
    border: 1px solid var(--dust);
    border-radius: 0.375rem;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .uc-card:hover {
    border-color: var(--secondary);
    transform: translateY(-4px);
  }

  .uc-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface-low);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .uc-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .uc-titel {
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface);
    display: block;
  }

  .uc-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  /* ─────────────────────────────────────────
     LEISTUNGEN
  ───────────────────────────────────────── */
  .leistungen {
    background: var(--surface-low);
    padding: 128px 24px;
  }

  .leistungen-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .leistungen-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 2rem;
  }

  .eyebrow-lk {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  .leistungen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--primary);
    margin: 0;
  }

  .leistungen-watermark {
    font-family: 'Manrope', sans-serif;
    font-size: 4rem;
    font-weight: 700;
    color: var(--on-surface);
