---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI-Agentur für KMU – Chatbots & Automatisierung | MarkMade"
  description="Chatbots, Telefonassistenten und KI-Automatisierung für KMU. Praktisch. Umsetzbar. Einmal bezahlt. Jetzt kostenloses Erstgespräch sichern."
>

  <!-- ══════════════════════════════════════
       SEKTION 1 — HERO
  ══════════════════════════════════════ -->
  <Hero
    eyebrow="KI Agentur · Stuttgart"
    heading="KI macht dich besser."
    subtext="Eine Person mit KI schlägt ein Team ohne."
    primaryCtaText="Kostenloses Erstgespräch buchen"
    primaryCtaHref="https://calendly.com/onlinemaster711/new-meeting"
  />

  <!-- ══════════════════════════════════════
       SEKTION 2 — KI-EFFEKTIVITÄT (Editorial Manifest)
  ══════════════════════════════════════ -->
  <section class="section sec-effektivitaet">
    <div class="section-inner">
      <div class="effekt-grid">

        <div class="effekt-head">
          <div class="section-eyebrow"><span>00 — Manifest</span></div>
          <h2 class="effekt-headline">Was früher eine Woche dauerte, schaffst du heute an einem Tag.</h2>
        </div>

        <div class="effekt-body">
          <p class="effekt-paragraph">Wer KI richtig einsetzt, schafft in einer Woche was andere in fünf schaffen. Das ist kein Versprechen — das ist Mathematik. Gleiche Zeit, fünffacher Output. Wer das nutzt, gewinnt.</p>
          <p class="effekt-paragraph">Wir bauen keine Standard-Software und lassen dich damit alleine. Wir optimieren deine Prozesse. Du sagst uns wie du arbeitest — wir geben der KI die Informationen die sie braucht um für dich bestmögliche Ergebnisse zu liefern. Mit deinem Wissen. Deiner Stimme. Deinem Design.</p>
          <p class="effekt-highlight">Als kleines oder mittelständisches Unternehmen kannst du mit KI die Großen angreifen. Nicht irgendwann. Jetzt.</p>

          <a
            href="https://calendly.com/onlinemaster711/new-meeting"
            class="btn-primary-outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>Sag uns wie du arbeitest — wir finden die Lösung</span>
            <span class="arrow">→</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 3 — SOCIAL MEDIA MIT KI
  ══════════════════════════════════════ -->
  <section class="section sec-social">
    <div class="section-inner">

      <div class="section-head-row">
        <div class="section-head-left">
          <div class="section-eyebrow">01 — Social Media &amp; Content mit KI</div>
          <h2 class="section-headline">Social Media mit KI.</h2>
        </div>
        <p class="section-aside">Wir übernehmen die Produktion, die Verteilung und die Auswertung — du lieferst den Inhalt.</p>
      </div>

      <div class="social-grid">

        <a href="/ki-social-media" class="social-card">
          <div class="card-num">01</div>
          <div class="card-icon" aria-hidden="true">📹</div>
          <h3 class="card-title">Ein Video. Sechs Plattformen.</h3>
          <p class="card-text">Du lädst einmal hoch. Wir bereiten es auf und verteilen es automatisch auf Instagram, TikTok, YouTube, LinkedIn und mehr.</p>
        </a>

        <a href="/ki-social-media" class="social-card">
          <div class="card-num">02</div>
          <div class="card-icon" aria-hidden="true">📊</div>
          <h3 class="card-title">Wir sehen was funktioniert.</h3>
          <p class="card-text">Wir haben eine eigene Software entwickelt die überwacht welcher Beitrag wie performt — und zeigt dir was du mehr davon machen solltest.</p>
        </a>

        <a href="/ki-social-media" class="social-card">
          <div class="card-num">03</div>
          <div class="card-icon" aria-hidden="true">🎨</div>
          <h3 class="card-title">Konstantes Design für deine Marke.</h3>
          <p class="card-text">Jeder Post sieht aus wie du. Farben, Schriften, Stil — immer konsistent, egal auf welcher Plattform.</p>
        </a>

        <a href="/ki-social-media" class="social-card">
          <div class="card-num">04</div>
          <div class="card-icon" aria-hidden="true">🧠</div>
          <h3 class="card-title">Dein Wissen wird Inhalt.</h3>
          <p class="card-text">Du sagst was du weißt — wir machen daraus Posts, Texte und Videos die nach dir klingen. Nicht nach einer Maschine.</p>
        </a>

      </div>

      <div class="section-footer">
        <p class="section-outro">Wer eine Woche mit KI an Social Media arbeitet, schafft was andere in fünf Wochen schaffen. Sprich mit uns.</p>
        <a
          href="https://calendly.com/onlinemaster711/new-meeting"
          class="btn-primary sec-social-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Jetzt Gespräch buchen</span>
          <span class="arrow">→</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 4 — BRANCHEN
  ══════════════════════════════════════ -->
  <section class="section sec-branchen">
    <div class="section-inner">

      <div class="section-head">
        <div class="section-eyebrow"><span>02 — Branchen</span></div>
        <h2 class="section-headline">Für welche Branchen wir bauen.</h2>
        <p class="section-lede">Branchen mit Substanz.</p>
      </div>

      <div class="branchen-grid">

        <div class="branche-card">
          <div class="branche-image">
            <img src="/branche-handwerk.webp" alt="KI für Handwerksbetriebe" loading="lazy" width="600" height="400" />
          </div>
          <div class="branche-content">
            <div class="branche-num">01</div>
            <h3 class="branche-title">Handwerksbetriebe</h3>
            <a href="/ki-handwerker" class="branche-subtitle">
              <span>KI für Handwerker</span>
              <span class="branche-arrow">→</span>
            </a>
            <a href="/webdesign-handwerker" class="branche-link-2">Website für Handwerker</a>
          </div>
        </div>

        <div class="branche-card">
          <div class="branche-image">
            <img src="/branche-aerzte.webp" alt="KI für Arztpraxen" loading="lazy" width="600" height="400" />
          </div>
          <div class="branche-content">
            <div class="branche-num">02</div>
            <h3 class="branche-title">Arztpraxen</h3>
            <a href="/ki-aerzte" class="branche-subtitle">
              <span>KI für Ärzte &amp; Praxen</span>
              <span class="branche-arrow">→</span>
            </a>
            <a href="/webdesign-aerzte" class="branche-link-2">Website für Ärzte</a>
          </div>
        </div>

        <div class="branche-card">
          <div class="branche-image">
            <img src="/branche-restaurant.webp" alt="KI für Restaurants" loading="lazy" width="600" height="400" />
          </div>
          <div class="branche-content">
            <div class="branche-num">03</div>
            <h3 class="branche-title">Restaurants</h3>
            <a href="/ki-restaurant" class="branche-subtitle">
              <span>KI für Restaurants</span>
              <span class="branche-arrow">→</span>
            </a>
          </div>
        </div>

        <div class="branche-card">
          <div class="branche-image">
            <img src="/branche-kanzlei.webp" alt="KI für Kanzleien" loading="lazy" width="600" height="400" />
          </div>
          <div class="branche-content">
            <div class="branche-num">04</div>
            <h3 class="branche-title">Kanzleien</h3>
            <a href="/ki-kanzlei" class="branche-subtitle">
              <span>KI für Kanzleien</span>
              <span class="branche-arrow">→</span>
            </a>
          </div>
        </div>

        <div class="branche-card">
          <div class="branche-image">
            <img src="/branche-immobilien.webp" alt="KI für Immobilienmakler" loading="lazy" width="600" height="400" />
          </div>
          <div class="branche-content">
            <div class="branche-num">05</div>
            <h3 class="branche-title">Immobilienmakler</h3>
            <a href="/ki-immobilienmakler" class="branche-subtitle">
              <span>KI für Immobilienmakler</span>
              <span class="branche-arrow">→</span>
            </a>
          </div>
        </div>

      </div>

      <p class="section-outro">
        <a href="/ki-fuer-unternehmen">Coaches, Selbstständige und weitere Branchen →</a>
      </p>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 5 — REFERENZ (Editorial)
  ══════════════════════════════════════ -->
  <section class="section sec-referenz">
    <div class="section-inner">
      <div class="referenz-grid">
        <div class="referenz-image">
          <img src="/elke-reinke-screenshot.webp" alt="Website von Elke Reinke – Osteopathin Stuttgart" />
        </div>
        <div class="referenz-content">
          <div class="section-eyebrow"><span>03 — Referenz</span></div>
          <blockquote class="referenz-quote">
            „Ich hatte vorher keine Seite die wirklich zu mir gepasst hat. Jetzt finden mich Patienten bei Google – und melden sich direkt."
          </blockquote>
          <div class="referenz-meta">
            <div class="referenz-name">Elke Reinke</div>
            <div class="referenz-role">Osteopathin · Stuttgart Degerloch</div>
          </div>
          <a href="https://osteopath-stuttgart.com" target="_blank" rel="noopener noreferrer" class="referenz-link">
            osteopath-stuttgart.com ansehen
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 6 — KI-TEAM (Editorial)
  ══════════════════════════════════════ -->
  <section class="section sec-kiteam" id="leistungen">
    <div class="section-inner">

      <div class="section-head">
        <div class="section-eyebrow"><span>04 — Expertise</span></div>
        <h2 class="section-headline">Dein KI-Team.</h2>
        <p class="section-lede">Sechs Rollen. Kein Gehalt. Kein Urlaub. Kein Krankenstand.</p>
      </div>

      <div class="kiteam-grid">

        <a href="/ki-fuer-unternehmen" class="kiteam-card">
          <div class="card-num">01</div>
          <div class="card-icon" aria-hidden="true">💬</div>
          <h3 class="card-title">KI-Chatbot</h3>
          <p class="card-text">Dein Kundenbetreuer. Antwortet sofort, rund um die Uhr, auf jede Frage — ohne dass du dabei sein musst.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/ki-telefonassistent" class="kiteam-card">
          <div class="card-num">02</div>
          <div class="card-icon" aria-hidden="true">📞</div>
          <h3 class="card-title">Telefonassistent</h3>
          <p class="card-text">Deine Assistentin am Telefon. Nimmt an, klärt vor, leitet weiter. Du wirst nur informiert wenn es zählt.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/ki-email" class="kiteam-card">
          <div class="card-num">03</div>
          <div class="card-icon" aria-hidden="true">📧</div>
          <h3 class="card-title">E-Mail-Automatisierung</h3>
          <p class="card-text">Dein Büromanager. Liest alles, beantwortet Routinefragen, priorisiert was deine Aufmerksamkeit braucht.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/ki-social-media" class="kiteam-card featured">
          <div class="card-num">04</div>
          <div class="card-icon" aria-hidden="true">📱</div>
          <h3 class="card-title">Social Media mit KI</h3>
          <p class="card-text">Dein Content-Team. Erstellt Posts, Texte und Pläne — du musst nur noch freigeben.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/ki-automatisierung" class="kiteam-card">
          <div class="card-num">05</div>
          <div class="card-icon" aria-hidden="true">⚙️</div>
          <h3 class="card-title">Prozessautomatisierung</h3>
          <p class="card-text">Dein Sachbearbeiter. Wiederkehrende Aufgaben laufen automatisch — ohne dass du daran denkst.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/webdesign-selbststaendige" class="kiteam-card">
          <div class="card-num">06</div>
          <div class="card-icon" aria-hidden="true">🌐</div>
          <h3 class="card-title">KI-Website</h3>
          <p class="card-text">Dein Vertriebsmitarbeiter. Überzeugt Besucher, beantwortet Fragen, bringt Anfragen — 24/7.</p>
          <span class="card-arrow" aria-hidden="true">→</span>
        </a>

      </div>

      <div class="section-footer">
        <a href="/ratgeber" class="ratgeber-link">Alle Ratgeber-Artikel lesen →</a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 7 — EIGENE PRODUKTE
  ══════════════════════════════════════ -->
  <section class="section sec-eigene-produkte">
    <div class="section-inner">
      <div class="produkte-grid">

        <div class="produkte-content">
          <div class="section-eyebrow"><span>05 — Eigene Produkte</span></div>
          <h2 class="produkte-headline">Wir reden nicht nur über KI.<br/>Wir bauen sie.</h2>

          <p class="produkte-paragraph">skriptgenerator.com ist unser eigenes KI-Produkt. Live. Mit Kunden. Mit Umsatz.</p>

          <p class="produkte-paragraph">Vier spezialisierte KIs arbeiten zusammen an jedem Skript — eine schreibt, eine liest aus Sicht deiner Zielgruppe, eine überarbeitet, eine prüft die Grammatik. Kein ChatGPT-Wrapper. Eigene Multi-Agent-Architektur.</p>

          <p class="produkte-highlight">Das ist der Beweis den wir bei jedem Kundenprojekt mitbringen: Wir wissen wie KI hält. Weil wir selbst eine betreiben.</p>

          <div class="produkte-cta-row">
            <a href="/projekte/skriptgenerator" class="btn-primary-outline">
              <span>Projekt ansehen</span>
              <span class="arrow">→</span>
            </a>
            <a href="https://www.skriptgenerator.com" class="produkte-external-link" target="_blank" rel="noopener noreferrer">
              <span>skriptgenerator.com besuchen</span>
              <span class="arrow">↗</span>
            </a>
          </div>
        </div>

        <div class="produkte-visual">
          <div class="skript-card">
            <div class="skript-card-header">
              <span class="skript-label">HOOK · 3 SEKUNDEN</span>
              <span class="skript-source">skriptgenerator.com</span>
            </div>

            <div class="skript-body">
              <p>Ich hab 6 Monate Reels gepostet.</p>
              <p>Kein neuer Follower.</p>
              <p class="skript-highlight">Bis ich gemerkt hab warum.</p>
            </div>

            <div class="skript-card-footer">
              <span class="skript-structure">Hook · Re-Hook · Body · Outro</span>
              <span class="skript-note">Nach Retention-Prinzipien strukturiert</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 8 — FAQ (Editorial)
  ══════════════════════════════════════ -->
  <section class="section sec-faq">
    <div class="section-inner">

      <div class="section-head">
        <div class="section-eyebrow"><span>06 — Häufige Fragen</span></div>
        <h2 class="section-headline">Häufige Fragen</h2>
      </div>

      <div class="faq-list">

        <article class="faq-item">
          <div class="faq-num">01</div>
          <div class="faq-body">
            <h3 class="faq-question">Kann KI wirklich einen Unterschied machen — oder ist das Hype?</h3>
            <p class="faq-answer">Wer KI richtig einsetzt, schafft heute in einer Woche was andere in fünf schaffen. Das ist kein Versprechen — das ist Mathematik. Gleiche Zeit, fünffacher Output. Wer das nutzt, gewinnt.</p>
          </div>
        </article>

        <article class="faq-item">
          <div class="faq-num">02</div>
          <div class="faq-body">
            <h3 class="faq-question">Was bringt mir das konkret in meinem Alltag?</h3>
            <p class="faq-answer">Du hörst auf Dinge zu tun die sich wiederholen. KI übernimmt Telefon, E-Mails, Dokumente, Social Media. Du konzentrierst dich auf das was nur du kannst — und wirst darin besser als je zuvor.</p>
          </div>
        </article>

        <article class="faq-item featured">
          <div class="faq-num">03</div>
          <div class="faq-body">
            <h3 class="faq-question">Ich bin kein Technik-Experte. Kann ich das trotzdem nutzen?</h3>
            <p class="faq-answer">Das ist genau der Punkt. Du musst kein Technik-Experte sein. Du sagst uns wie du arbeitest — wir geben der KI die Informationen die sie braucht um für dich zu arbeiten. Du nutzt das Ergebnis. Fertig.</p>
          </div>
        </article>

        <article class="faq-item">
          <div class="faq-num">04</div>
          <div class="faq-body">
            <h3 class="faq-question">Was unterscheidet MarkMade von anderen KI-Anbietern?</h3>
            <p class="faq-answer">Wir verkaufen keine Software. Wir optimieren Prozesse. Der Unterschied: Software kannst du kaufen und trotzdem nichts damit anfangen. Wir sorgen dafür dass KI wirklich für deinen Betrieb arbeitet — mit deinem Wissen, deiner Stimme, deinem Design.</p>
          </div>
        </article>

        <article class="faq-item">
          <div class="faq-num">05</div>
          <div class="faq-body">
            <h3 class="faq-question">Was passiert wenn ich jetzt nichts tue?</h3>
            <p class="faq-answer">Deine Konkurrenz die KI nutzt, wird in einem Jahr so viel mehr geschafft haben dass der Abstand kaum noch aufzuholen ist. Die Arbeitswelt befindet sich im größten Wandel ihrer Geschichte. Wer jetzt nicht anfängt, fängt zu spät an.</p>
          </div>
        </article>

        <article class="faq-item">
          <div class="faq-num">06</div>
          <div class="faq-body">
            <h3 class="faq-question">Wie schnell sehe ich Ergebnisse?</h3>
            <p class="faq-answer">In 1–2 Wochen läuft deine erste KI-Lösung. Nicht ein Prototyp — eine echte Lösung die täglich arbeitet. Die meisten unserer Kunden sehen in der ersten Woche wie viel Zeit sie bisher verschenkt haben.</p>
          </div>
        </article>

      </div>

      <div class="faq-outro">
        <p class="faq-outro-text">Wer als kleines oder mittelständisches Unternehmen KI richtig einsetzt, kann die Großen angreifen. Nicht irgendwann. Jetzt. Das ist der größte Wandel in der Geschichte der Arbeit — und du kannst auf der richtigen Seite davon stehen.</p>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       SEKTION 8 — CTA
  ══════════════════════════════════════ -->
  <Cta />

</BaseLayout>

<style>
  /* Hero wird durch Hero.astro Component gerendert (scoped styles dort) */

  .uc-titel {
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--on-surface);
    display: block;
  }

  .uc-text {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  /* ─────────────────────────────────────────
     KI-TEAM — Editorial
  ───────────────────────────────────────── */
  .sec-kiteam {
    background: var(--surface);
    padding: 6rem 2.5rem;
    position: relative;
  }

  .sec-kiteam .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Section-Eyebrow */
  .sec-kiteam .section-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .sec-kiteam .section-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--secondary);
  }

  /* Section-Head zentriert */
  .sec-kiteam .section-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 5rem;
  }

  .sec-kiteam .section-head .section-eyebrow {
    justify-content: center;
  }

  .sec-kiteam .section-headline {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    color: var(--on-surface);
    text-wrap: balance;
  }

  .sec-kiteam .section-lede {
    font-family: 'Manrope', sans-serif;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
    margin: 0;
  }

  /* KI-Team Grid — 3 Spalten */
  .sec-kiteam .kiteam-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .sec-kiteam .kiteam-card {
    position: relative;
    background: var(--surface-lowest);
    border-radius: 1.25rem;
    padding: 2.25rem 2rem 2.5rem;
    box-shadow: 0 20px 40px 0 rgba(27, 28, 26, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    min-height: 280px;
  }

  .sec-kiteam .kiteam-card:hover {
    box-shadow: 0 28px 56px 0 rgba(27, 28, 26, 0.12);
    transform: translateY(-6px);
  }

  /* Featured Card (Social Media) */
  .sec-kiteam .kiteam-card.featured {
    background: var(--primary-container);
    color: #fbf9f6;
  }

  .sec-kiteam .kiteam-card.featured .card-num { color: rgba(223, 230, 200, 0.55); }
  .sec-kiteam .kiteam-card.featured .card-title { color: #fbf9f6; }
  .sec-kiteam .kiteam-card.featured .card-text { color: var(--primary-fixed); }
  .sec-kiteam .kiteam-card.featured .card-arrow { color: #d4889a; }

  .sec-kiteam .card-num {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-style: italic;
    color: var(--on-surface-muted);
  }

  .sec-kiteam .card-icon {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .sec-kiteam .card-title {
