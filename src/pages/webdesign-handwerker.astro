---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import VierFragen from '../components/VierFragen.astro';
import Rechner from '../components/Rechner.astro';
import Angebot from '../components/Angebot.astro';
import Beweis from '../components/Beweis.astro';
import Prozess from '../components/Prozess.astro';
import Cta from '../components/Cta.astro';
import Faq from '../components/Faq.astro';
---

<BaseLayout
  title="Webdesign für Handwerker – Website & Chatbot | MarkMade"
  description="Professionelle Website für Handwerker ab 1.000 € inkl. MwSt. Mit Chatbot der Fragen beantwortet und Zeit spart. Entwurf zuerst, dann entscheiden."
>
  <Hero
    eyebrow="Webdesign · Chatbot · Zeitersparnis"
    heading="Webdesign für Handwerker – warum beantwortest du noch selbst?"
    subtext="Was machst du? Für wen? Was kostet es? Was nicht? – Deine Website sagt das klar. Dein Chatbot klärt den Rest. Automatisch. Bevor du auch nur ans Telefon gehst."
  />
  <VierFragen />
  <Rechner />
  <Angebot />
  <Beweis />
  <Prozess />
  <Cta />
  <Faq />
</BaseLayout>
