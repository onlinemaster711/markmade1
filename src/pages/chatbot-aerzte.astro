---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Rechner from '../components/Rechner.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="Chatbot für Arztpraxis – Patientenfragen automatisch beantworten | MarkMade"
  description="Ihr Chatbot beantwortet Patientenfragen rund um die Uhr. Öffnungszeiten, Termine, Kassenärztliche Zulassung – automatisch. Nur passende Anfragen landen bei Ihnen."
>
  <Hero
    eyebrow="Chatbot für Arztpraxen"
    heading="Ihr Chatbot beantwortet. Sie behandeln."
    subtext="Öffnungszeiten, Terminvergabe, Kassenärztliche Zulassung – Ihr Chatbot klärt das automatisch. Rund um die Uhr. Auch abends. Auch am Wochenende."
    desktopScreenshot="screenshot-arztpraxis-desktop.webp"
    mobileScreenshot="screenshot-arztpraxis-mobile.webp"
  />

  <!-- Problem Section -->
  <section class="problem-section">
    <div class="problem-inner">
      <h2>Rufen Patienten täglich für dieselben Fragen an?</h2>

      <div class="problem-pills">
        <div class="pill">Öffnungszeiten</div>
        <div class="pill">Kassenärztlich?</div>
        <div class="pill">Termine</div>
      </div>

      <p class="problem-text">Ihr Team verbringt wertvolle Zeit mit Fragen die eine gute Website bereits beantwortet hätte.</p>
    </div>
  </section>

  <!-- So sieht das in der Praxis aus -->
  <section class="demo-section">
    <div class="demo-inner">
      <h2>Ein Gespräch – automatisch geführt.</h2>
      <p class="demo-text">Ihr Chatbot kennt Ihre Praxis. Er beantwortet die Fragen die täglich kommen – bevor Ihr Team ans Telefon geht.</p>
      <ChatDemo
        title="So beantwortet Ihr Chatbot Patientenfragen"
        messages={[
          {role: 'user', text: 'Nehmen Sie Kassenpatienten an?'},
          {role: 'bot', text: 'Ja, wir sind kassenärztlich zugelassen – sowohl gesetzlich als auch privat versicherte Patienten sind herzlich willkommen.'},
          {role: 'user', text: 'Wie schnell bekomme ich einen Termin?'},
          {role: 'bot', text: 'Für Neupatienten meist innerhalb von 3–5 Tagen. Bei akuten Beschwerden versuchen wir Ihnen noch am selben Tag zu helfen.'},
          {role: 'user', text: 'Kann ich online buchen?'},
          {role: 'bot', text: 'Ja! Klicken Sie einfach auf "Termin buchen" oben rechts und wählen Sie einen freien Slot – das dauert nur 2 Minuten.'}
        ]}
      />
    </div>
  </section>

  <!-- Was der Chatbot macht -->
  <section class="leistungen-section">
    <div class="leistungen-inner">
      <h2>Was Ihr Chatbot macht</h2>

      <div class="leistungen-grid">
        <div class="leistungen-item">
          <div class="leistungen-icon">🕐</div>
          <h3>Rund um die Uhr</h3>
          <p>Auch wenn die Praxis geschlossen ist</p>
        </div>

        <div class="leistungen-item">
          <div class="leistungen-icon">❓</div>
          <h3>Fragen beantworten</h3>
          <p>Zulassung, Kosten, Ablauf, Sprechzeiten</p>
        </div>

        <div class="leistungen-item">
          <div class="leistungen-icon">✅</div>
          <h3>Vorqualifizieren</h3>
          <p>Nur passende Patienten kommen durch</p>
        </div>

        <div class="leistungen-item">
          <div class="leistungen-icon">📅</div>
          <h3>Termin vorbereiten</h3>
          <p>Anliegen geklärt bevor der Patient kommt</p>
        </div>
      </div>
    </div>
  </section>

  <Rechner />
  <Cta />
</BaseLayout>

<style>
  /* --- Problem Section --- */
  .problem-section {
    background: var(--primary);
    color: #fff;
    padding: 5rem 1.5rem;
  }

  .problem-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .problem-section h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.3;
    margin-bottom: 3rem;
    font-family: 'Noto Serif', serif;
    font-weight: 600;
  }

  .problem-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .pill {
    background: rgba(255, 255, 255, 0.15);
    padding: 0.75rem 1.5rem;
    border-radius: 100px;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .problem-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    opacity: 0.95;
    max-width: 65ch;
    margin: 0 auto;
  }

  /* --- Leistungen Section --- */
  .leistungen-section {
    background: var(--surface-low);
    padding: 5rem 1.5rem;
  }

  .leistungen-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .leistungen-section h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 3rem;
    text-align: center;
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .leistungen-item {
    text-align: center;
  }

  .leistungen-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
  }

  .leistungen-item h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.75rem;
  }

  .leistungen-item p {
    font-size: 0.95rem;
    color: var(--on-surface-muted);
    line-height: 1.6;
  }

  /* --- Demo Section --- */
  .demo-section {
    background: var(--surface-low);
    padding: 5rem 1.5rem;
  }

  .demo-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .demo-section h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .demo-text {
    font-size: 1.0625rem;
    color: var(--on-surface-muted);
    line-height: 1.7;
    margin-bottom: 3rem;
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- Responsive --- */
  @media (max-width: 767px) {
    .problem-section,
    .leistungen-section {
      padding: 3.5rem 1.5rem;
    }

    .problem-pills {
      gap: 0.75rem;
    }

    .pill {
      padding: 0.625rem 1.25rem;
      font-size: 0.875rem;
    }
  }
</style>
