---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Rechner from '../components/Rechner.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="Chatbot für Handwerker – Anfragen automatisch beantworten | MarkMade"
  description="Dein Chatbot beantwortet Kundenfragen rund um die Uhr. Öffnungszeiten, Preise, Ablauf – automatisch. Nur passende Anfragen landen bei dir."
>

  {/* --- HERO --- */}
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Chatbot für Handwerker</p>
      <h1>Chatbot für Handwerker – beantwortet Fragen, während du arbeitest</h1>
      <p class="hero-text">
        Öffnungszeiten, Preise, Ablauf – dein Chatbot klärt das automatisch. Rund um die Uhr. Auch nachts. Auch am Wochenende. Nur wer wirklich passt, landet bei dir.
      </p>
      <a href="https://markmade.de/#cta" class="btn-primary">Kostenlosen Entwurf sichern</a>
    </div>
  </section>

  {/* --- PROBLEM --- */}
  <section class="problem">
    <div class="problem-inner">
      <h2>Klingelt dein Telefon zu oft für Fragen die sich wiederholen?</h2>
      <div class="pills">
        <span class="pill">Öffnungszeiten</span>
        <span class="pill">Preise</span>
        <span class="pill">Ablauf</span>
      </div>
      <p class="problem-text">Das sind keine schlechten Kunden. Das ist eine schlechte Website. Eine gute Website beantwortet das bevor jemand anruft.</p>
    </div>
  </section>

  {/* --- DEMO --- */}
  <section class="demo-section">
    <div class="demo-inner">
      <h2>Ein Gespräch – automatisch geführt.</h2>
      <p class="demo-text">Dein Chatbot kennt deinen Betrieb. Er beantwortet die Fragen die täglich kommen – bevor dein Telefon klingelt.</p>
      <ChatDemo
        title="So beantwortet Ihr Chatbot Kundenfragen"
        messages={[
          {role: 'user', text: 'Machen Sie auch Notfall-Einsätze?'},
          {role: 'bot', text: 'Ja, für dringende Fälle sind wir auch am Wochenende oder abends erreichbar. Nennen Sie uns einfach die Situation.'},
          {role: 'user', text: 'Was kostet ein Erstbesuch ungefähr?'},
          {role: 'bot', text: 'Das hängt vom Aufwand ab. Geben Sie uns mehr Infos, dann können wir eine bessere Schätzung machen.'},
          {role: 'user', text: 'Arbeiten Sie auch am Wochenende?'},
          {role: 'bot', text: 'Für normale Aufträge unter der Woche, für Notfälle auch am Wochenende. Schreiben Sie uns, worum es geht.'}
        ]}
      />
    </div>
  </section>

  {/* --- WAS DER CHATBOT MACHT --- */}
  <section class="chatbot-features">
    <div class="inner">
      <h2>Was dein Chatbot für dich übernimmt</h2>
      <div class="features-list">
        <div class="feature-item fade-in">
          <span class="feature-icon">🕐</span>
          <div class="feature-body">
            <h3>Rund um die Uhr</h3>
            <p>Auch wenn du auf der Baustelle bist oder schläfst – der Chatbot ist da.</p>
          </div>
        </div>
        <div class="feature-item fade-in">
          <span class="feature-icon">❓</span>
          <div class="feature-body">
            <h3>Fragen beantworten</h3>
            <p>Was kostet das? Wie läuft das ab? Machst du das auch? Alles automatisch.</p>
          </div>
        </div>
        <div class="feature-item fade-in">
          <span class="feature-icon">✅</span>
          <div class="feature-body">
            <h3>Nur passende Anfragen</h3>
            <p>Wer nicht zu dir passt, merkt es selbst. Nur wer wirklich Interesse hat, kommt durch.</p>
          </div>
        </div>
        <div class="feature-item fade-in">
          <span class="feature-icon">📅</span>
          <div class="feature-body">
            <h3>Termin vorbereiten</h3>
            <p>Bevor ihr sprecht, ist das Wichtigste bereits geklärt. Du kommst vorbereitet ins Gespräch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* --- RECHNER --- */}
  <Rechner />

  {/* --- CTA --- */}
  <section class="cta-wrapper">
    <div class="cta-note">Der Chatbot kostet einmalig <strong>+500 €</strong> zum Website-Paket.</div>
    <Cta />
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 3rem;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.5rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.8125rem 1.5rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.88;
  }

  /* Problem */
  .problem {
    background: var(--primary);
    color: #fff;
    padding: 5rem 0;
    text-align: center;
  }

  .problem-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .problem h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.3;
    margin-bottom: 2rem;
  }

  .pills {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .pill {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  .problem-text {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* Demo Section */
  .demo-section {
    background: var(--surface-low);
    padding: 5rem 1.5rem;
  }

  .demo-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .demo-section h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .demo-text {
    font-size: 1.0625rem;
    color: var(--on-surface-muted);
    line-height: 1.7;
    margin-bottom: 3rem;
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* Features */
  .chatbot-features {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .chatbot-features h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 3rem;
    text-align: center;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .feature-item {
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--outline-variant);
    align-items: flex-start;
  }

  .feature-item:first-child {
    border-top: 1px solid var(--outline-variant);
  }

  .feature-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .feature-body {
    flex: 1;
  }

  .feature-body h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.375rem;
    color: var(--on-surface);
  }

  .feature-body p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* CTA Wrapper */
  .cta-wrapper {
    position: relative;
  }

  .cta-note {
    text-align: center;
    padding: 1.5rem;
    background: var(--surface-low);
    color: var(--on-surface-muted);
    font-size: 0.9375rem;
    border-top: 1px solid var(--outline-variant);
  }

  .cta-note strong {
    color: var(--secondary);
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
    }

    .pills {
      gap: 0.75rem;
    }

    .pill {
      font-size: 0.875rem;
      padding: 0.625rem 1rem;
    }
  }
</style>
