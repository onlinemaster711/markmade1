---
import BaseLayout from '../layouts/BaseLayout.astro';
import Rechner from '../components/Rechner.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI für Handwerker | MarkMade"
  description="KI spart Handwerkern Zeit – bei Anfragen, Terminbuchungen und Kundenkommunikation. Kein Technik-Wissen nötig."
>

  {/* --- HERO --- */}
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI für Handwerker – einfach erklärt</p>
      <h1>KI für Handwerker – Intelligenz die Zeit spart</h1>
      <h2 class="seo-subline">KI für Handwerker – Anfragen, Termine und Kommunikation automatisch erledigen</h2>
      <p class="hero-text">
        Künstliche Intelligenz klingt kompliziert. Ist es nicht. Für Handwerker bedeutet KI: Weniger Telefonate. Weniger Papierkram. Mehr Zeit für die Arbeit die du wirklich machst.
      </p>
    </div>
  </section>

  {/* --- WAS KI KONKRET MACHT --- */}
  <section class="ki-funktionen">
    <div class="uc-inner">
      <h2>Was KI für Handwerker konkret übernimmt</h2>
      <div class="uc-grid">

        <div class="uc-punkt fade-in">
          <span class="uc-icon">💬</span>
          <div>
            <h3>Anfragen automatisch beantworten</h3>
            <p>Öffnungszeiten, Preise, Ablauf – KI antwortet sofort. Auch nachts, auch am Wochenende.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📅</span>
          <div>
            <h3>Termine automatisch buchen</h3>
            <p>Kunden buchen direkt in deinen Kalender. Ohne Telefonat, ohne Hin-und-Her.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">✍️</span>
          <div>
            <h3>Angebote und Texte schreiben</h3>
            <p>KI erstellt Angebotsentwürfe, E-Mails und Beschreibungen auf Knopfdruck.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📞</span>
          <div>
            <h3>Anrufe entgegennehmen</h3>
            <p>KI-Telefonassistent nimmt an, klärt vor und bucht Termine. Du wirst nur informiert.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">⭐</span>
          <div>
            <h3>Bewertungen automatisch anfordern</h3>
            <p>Nach Abschluss automatisch um eine Google-Bewertung bitten.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">🔔</span>
          <div>
            <h3>Erinnerungen und Bestätigungen</h3>
            <p>Kunden bekommen automatisch Terminbestätigungen und Erinnerungen.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">📊</span>
          <div>
            <h3>Auswerten</h3>
            <p>Welche Anfragen kommen am häufigsten? KI liefert dir den Überblick.</p>
          </div>
        </div>

        <div class="uc-punkt fade-in">
          <span class="uc-icon">🔁</span>
          <div>
            <h3>Follow-up automatisieren</h3>
            <p>Offene Anfragen werden automatisch nachgefasst. Kein Kunde geht verloren.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* --- WAS KI NICHT KANN --- */}
  <section class="ki-grenzen">
    <div class="inner">
      <h2>Was KI nicht ersetzt.</h2>
      <p class="grenzen-text">
        KI kennt nicht deine Kunden. Nicht deine Branche. Nicht was du wirklich gut kannst. Sie macht gute Leute besser – aber sie macht niemanden gut der sich nicht auskennt. Deshalb steckt hinter jedem MarkMade-Projekt ein Mensch der Marketing versteht.
      </p>
    </div>
  </section>

  {/* --- RECHNER --- */}
  <Rechner />

  {/* --- CHATDEMO --- */}
  <section class="demo-section">
    <div class="demo-inner">
      <ChatDemo
        title="So beantwortet KI Anfragen deiner Kunden"
        messages={[
          {role: 'user', text: 'Was kostet eine neue Heizungsanlage bei euch?'},
          {role: 'bot', text: 'Das hängt von der Anlage ab. Für eine Standard-Gastherme rechnen Sie mit 3.000–5.000 € inkl. Einbau. Soll ich direkt einen kostenlosen Beratungstermin für Sie buchen?'},
          {role: 'user', text: 'Ja, gerne – wann habt ihr Zeit?'},
          {role: 'bot', text: 'Ich sehe freie Termine diese Woche: Mittwoch 14 Uhr oder Donnerstag 10 Uhr. Welcher passt Ihnen besser?'}
        ]}
      />
    </div>
  </section>

  {/* --- AUCH INTERESSANT --- */}
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-telefonassistent" class="ai-karte">
          <span class="ai-icon">📞</span>
          <span class="ai-titel">KI-Telefonassistent</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-email" class="ai-karte">
          <span class="ai-icon">✉️</span>
          <span class="ai-titel">E-Mail-Automatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ratgeber/ki-fuer-handwerker" class="ai-karte">
          <span class="ai-icon">📖</span>
          <span class="ai-titel">Ratgeber: KI für Handwerker</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  {/* --- CTA --- */}
  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.5rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
  }

  /* SEO Subline */
  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  /* KI Funktionen — 8-Punkte-Grid */
  .ki-funktionen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .uc-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-funktionen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 3rem;
    color: var(--on-surface);
  }

  .uc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .uc-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .uc-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .uc-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.35rem;
  }

  .uc-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Chat Demo */
  .demo-section {
    background: var(--surface);
    padding: 0;
  }

  .demo-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Auch interessant */
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
  }

  .ai-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ai-inner h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--on-surface);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    flex: 1;
    line-height: 1.3;
  }

  .ai-arrow {
    font-size: 1rem;
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .ai-karte:hover .ai-arrow {
    opacity: 1;
  }

  /* KI Grenzen */
  .ki-grenzen {
    background: var(--primary);
    color: #fff;
    padding: 5rem 0;
  }

  .ki-grenzen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 1.75rem;
    text-align: center;
  }

  .grenzen-text {
    max-width: 65ch;
    margin: 0 auto;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
    }

    .uc-grid {
      grid-template-columns: 1fr;
    }

    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
