---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatDemo from '../components/ChatDemo.astro';
import Cta from '../components/Cta.astro';
---

<BaseLayout
  title="KI-Telefonassistent für KMU | MarkMade"
  description="Dein KI-Empfang nimmt Anrufe rund um die Uhr entgegen, beantwortet Fragen und bucht Termine direkt in deinen Kalender. Kein verpasster Anruf mehr."
>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">KI-Telefonassistent &amp; Empfangsdienst</p>
      <h1>Kein Anruf bleibt unbeantwortet.<br />Auch nachts.</h1>
      <h2 class="seo-subline">KI-Telefonassistent für kleine Betriebe – kein Anruf bleibt unbeantwortet</h2>
      <p class="hero-text">
        Dein KI-Assistent nimmt Anrufe entgegen, beantwortet Fragen und bucht Termine – rund um die Uhr, auch am Wochenende. Du verpasst keinen potenziellen Kunden mehr.
      </p>
      <a href="https://calendly.com/onlinemaster711/new-meeting" class="btn-primary" target="_blank" rel="noopener noreferrer">Kostenloses Erstgespräch</a>
    </div>
  </section>

  <!-- 2. DAS PROBLEM -->
  <section class="problem">
    <div class="problem-inner">
      <h2>Wie viele Anrufe verpasst du täglich?</h2>
      <div class="pills">
        <span class="pill">Während der Arbeit</span>
        <span class="pill">Mittags</span>
        <span class="pill">Nach Feierabend</span>
      </div>
      <p class="problem-text">Jeder verpasste Anruf ist ein potenzieller Kunde der zur Konkurrenz geht. Ein KI-Empfang löst das – ohne Personalkosten.</p>
    </div>
  </section>

  <!-- 3. WAS DER ASSISTENT MACHT -->
  <section class="was-ki-macht">
    <div class="was-ki-inner">
      <h2>Was dein KI-Telefonassistent übernimmt.</h2>
      <div class="ki-grid">
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📞</span>
          <div>
            <h3>Anrufe entgegennehmen</h3>
            <p>24/7 erreichbar – auch wenn du auf der Baustelle bist, in der Behandlung oder einfach frei hast.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">❓</span>
          <div>
            <h3>Fragen beantworten</h3>
            <p>Öffnungszeiten, Preise, Ablauf – dein KI-Assistent kennt deinen Betrieb und antwortet korrekt.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📅</span>
          <div>
            <h3>Termine buchen</h3>
            <p>Direkt in deinen Kalender – ohne dein Zutun. Der Anrufer bekommt sofort eine Bestätigung.</p>
          </div>
        </div>
        <div class="ki-punkt fade-in">
          <span class="ki-icon">📋</span>
          <div>
            <h3>Weiterleiten</h3>
            <p>Dringende Anliegen kommen sofort zu dir – alles andere wird sauber dokumentiert und weitergeleitet.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. ZEITRECHNER -->
  <section class="zeitrechner">
    <div class="zr-inner">
      <div class="zr-content">
        <h2>Wie viele Anrufe verpasst du gerade wirklich?</h2>

        <div class="zr-slider-group">
          <label for="anrufe">
            Wie viele Anrufe bekommst du pro Tag?
            <span class="zr-val" id="anrufe-val">5</span>
          </label>
          <input type="range" id="anrufe" min="1" max="30" value="5" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>1</span><span>30</span></div>
        </div>

        <div class="zr-slider-group">
          <label for="minuten">
            Wie lange dauert ein durchschnittlicher Anruf?
            <span class="zr-val" id="minuten-val">6 Min</span>
          </label>
          <input type="range" id="minuten" min="2" max="15" value="6" step="1" class="zr-range" />
          <div class="zr-range-labels"><span>2 Min</span><span>15 Min</span></div>
        </div>
      </div>

      <div class="zr-ergebnis">
        <div class="zr-box">
          <p class="zr-label">Minuten pro Tag</p>
          <p class="zr-tag" id="zr-tag">30</p>
          <p class="zr-label">Stunden pro Monat</p>
          <p class="zr-monat" id="zr-monat">15</p>
          <p class="zr-label">Stunden pro Jahr</p>
          <p class="zr-jahr" id="zr-jahr">183</p>
          <p class="zr-frage" id="zr-frage">Was machst du mit 183 Stunden mehr im Jahr?</p>
          <p class="zr-hinweis">Das sind keine Versprechen. Das ist Mathematik.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. WAS KI NICHT KANN -->
  <section class="ki-nicht">
    <div class="kn-inner">
      <h2>Was KI nicht ersetzt.</h2>
      <p class="kn-text">KI kann nicht einschätzen ob ein Anrufer wirklich ernst meint. Sie kann nicht verhandeln und kein echtes Gespräch führen das Vertrauen aufbaut. Aber sie nimmt an, klärt vor und filtert – damit du nur noch die Anrufe bekommst die wirklich zählen.</p>
      <div class="kn-punkte">
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Beziehungen baust du auf</strong> – KI gibt dir mehr Zeit dafür</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Komplexe Anliegen löst du</strong> – KI leitet sie direkt zu dir weiter</p>
        </div>
        <div class="kn-punkt">
          <span class="kn-dash">—</span>
          <p><strong>Dein Betrieb klingt nach dir</strong> – KI wird auf deine Stimme und deinen Stil konfiguriert</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CHATDEMO -->
  <section class="demo-section">
    <div class="demo-inner">
      <ChatDemo
        title="So klingt dein KI-Empfang"
        messages={[
          {role: 'user', text: 'Guten Tag, ich würde gerne einen Termin vereinbaren.'},
          {role: 'bot', text: 'Guten Tag! Gerne. Wann passt es Ihnen – haben Sie einen bevorzugten Tag oder eine Uhrzeit?'},
          {role: 'user', text: 'Am besten Donnerstag Vormittag.'},
          {role: 'bot', text: 'Donnerstag um 10:00 Uhr wäre frei. Darf ich kurz Ihren Namen und Ihr Anliegen notieren?'}
        ]}
      />
    </div>
  </section>

  <!-- 5. FÜR WEN -->
  <section class="fuer-wen">
    <div class="fuer-wen-inner">
      <h2>Ideal für lokale Dienstleister die keine Anrufe verpassen wollen.</h2>
      <div class="fuer-wen-grid">
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">🦷</span>
          <p>Zahnarztpraxen &amp; MedSpas</p>
        </div>
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">🔧</span>
          <p>Klempner &amp; Handwerksbetriebe</p>
        </div>
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">💆</span>
          <p>Physiotherapeuten &amp; Praxen</p>
        </div>
        <div class="fuer-wen-karte fade-in">
          <span class="fw-icon">🏠</span>
          <p>Immobilienmakler &amp; Berater</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AUCH INTERESSANT -->
  <section class="auch-interessant">
    <div class="ai-inner">
      <h3>Das könnte dich auch interessieren</h3>
      <div class="ai-grid">
        <a href="/ki-fuer-unternehmen" class="ai-karte">
          <span class="ai-icon">💬</span>
          <span class="ai-titel">KI-Chatbot &amp; Übersicht</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-email" class="ai-karte">
          <span class="ai-icon">✉️</span>
          <span class="ai-titel">E-Mail-Automatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
        <a href="/ki-automatisierung" class="ai-karte">
          <span class="ai-icon">⚙️</span>
          <span class="ai-titel">Prozessautomatisierung</span>
          <span class="ai-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <Cta />

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--surface);
    padding-top: 9rem;
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 54ch;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  /* SEO Subline */
  .seo-subline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--on-surface-muted);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  /* Problem */
  .problem {
    background: var(--primary);
    padding: 5rem 0;
    text-align: center;
    color: white;
  }

  .problem-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .problem h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.375rem, 3vw, 2rem);
    line-height: 1.3;
    color: white;
    margin-bottom: 2rem;
  }

  .pills {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .pill {
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border-radius: 2rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .problem-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Was KI macht */
  .was-ki-macht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .was-ki-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .was-ki-macht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .ki-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ki-punkt {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .ki-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .ki-punkt h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .ki-punkt p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  /* Zeitrechner */
  .zeitrechner {
    background: var(--primary);
    padding: 5rem 0;
    color: white;
  }

  .zr-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .zr-content h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    color: white;
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }

  .zr-slider-group {
    margin-bottom: 2rem;
  }

  .zr-slider-group label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.75rem;
  }

  .zr-val {
    font-weight: 700;
    font-size: 1rem;
    color: var(--primary-fixed);
    flex-shrink: 0;
  }

  .zr-range {
    width: 100%;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.2);
    outline: none;
    cursor: pointer;
  }

  .zr-range::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-fixed);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .zr-range-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.35rem;
  }

  .zr-ergebnis {
    display: flex;
    justify-content: center;
  }

  .zr-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    text-align: center;
    width: 100%;
  }

  .zr-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.35rem;
  }

  .zr-tag {
    font-family: 'Noto Serif', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .zr-monat {
    font-family: 'Noto Serif', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-fixed);
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .zr-jahr {
    font-family: 'Noto Serif', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .zr-frage {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .zr-hinweis {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* KI nicht */
  .ki-nicht {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .kn-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ki-nicht h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: var(--on-surface);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .kn-text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
  }

  .kn-punkte {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kn-punkt {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .kn-dash {
    font-size: 1.25rem;
    color: var(--secondary);
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .kn-punkt p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--on-surface);
  }

  /* Auch interessant */
  .auch-interessant {
    background: var(--surface-low);
    padding: 3rem 0;
  }

  .ai-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ai-inner h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .ai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ai-karte {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--on-surface);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }

  .ai-karte:hover {
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .ai-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-titel {
    flex: 1;
    line-height: 1.3;
  }

  .ai-arrow {
    font-size: 1rem;
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .ai-karte:hover .ai-arrow {
    opacity: 1;
  }

  /* Demo */
  .demo-section {
    background: var(--surface);
    padding: 0;
  }

  .demo-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Für wen */
  .fuer-wen {
    background: var(--surface);
    padding: 5rem 0;
  }

  .fuer-wen-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .fuer-wen h2 {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin-bottom: 3rem;
    line-height: 1.3;
  }

  .fuer-wen-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .fuer-wen-karte {
    background: var(--surface-low);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .fw-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .fuer-wen-karte p {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--on-surface);
    line-height: 1.4;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero {
      padding-top: 6.5rem;
      padding-bottom: 3.5rem;
    }

    .ki-grid {
      grid-template-columns: 1fr;
    }

    .fuer-wen-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .zr-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function updateZeitrechner() {
    const anrufe = parseInt((document.getElementById('anrufe') as HTMLInputElement).value, 10);
    const minuten = parseInt((document.getElementById('minuten') as HTMLInputElement).value, 10);

    const min_tag = anrufe * minuten;
    const std_monat = Math.round((min_tag * 30) / 60 * 10) / 10;
    const std_jahr = Math.round((min_tag * 365) / 60 * 10) / 10;

    (document.getElementById('anrufe-val') as HTMLElement).textContent = String(anrufe);
    (document.getElementById('minuten-val') as HTMLElement).textContent = minuten + ' Min';
    (document.getElementById('zr-tag') as HTMLElement).textContent = String(min_tag);
    (document.getElementById('zr-monat') as HTMLElement).textContent = String(std_monat);
    (document.getElementById('zr-jahr') as HTMLElement).textContent = String(std_jahr);
    (document.getElementById('zr-frage') as HTMLElement).textContent =
      'Was machst du mit ' + std_jahr + ' Stunden mehr im Jahr?';
  }

  document.getElementById('anrufe')?.addEventListener('input', updateZeitrechner);
  document.getElementById('minuten')?.addEventListener('input', updateZeitrechner);
</script>
