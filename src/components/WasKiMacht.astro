---
const steps = [
  {
    nr: "01",
    answer: "Dein Kunde bekommt seinen Termin bestätigt — innerhalb von Minuten.",
    context: "Egal ob er um 9 Uhr morgens fragt oder um 23 Uhr abends.",
  },
  {
    nr: "02",
    answer: "Du beantwortest 8 Mails statt 40 — und triffst trotzdem alles Wichtige.",
    context: "Die KI sortiert vor, du entscheidest. Nichts geht verloren.",
  },
  {
    nr: "03",
    answer: "Drei Anrufer wurden empfangen — auch während du auf der Baustelle warst.",
    context: "Zwei sind qualifiziert. Einer wartet konkret auf deinen Rückruf.",
  },
];
---

<section class="was-ki-macht" aria-labelledby="was-ki-macht-headline">
  <div class="container">
    <header class="intro">
      <p class="eyebrow">02 — Was KI heute schon macht</p>
      <h2 id="was-ki-macht-headline" class="headline">
        Dein Kunde bekommt sofort<br />
        eine Antwort. Du in Ruhe.
      </h2>
    </header>

    <ol class="steps" role="list">
      {steps.map((step) => (
        <li class="step">
          <span class="step-number" aria-hidden="true">{step.nr}</span>
          <div class="step-content">
            <p class="step-answer">{step.answer}</p>
            <p class="step-context">{step.context}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .was-ki-macht {
    background: var(--surface-low, #f5f3f0);
    padding: var(--space-4xl, 6rem) 1.5rem;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .intro {
    max-width: 680px;
    margin: 0 0 var(--space-4xl, 6rem) 0;
  }
  .eyebrow {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-muted, #5c5d58);
    margin: 0 0 var(--space-md, 1rem) 0;
  }
  .headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--on-surface, #1b1c1a);
    margin: 0;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .step {
    display: grid;
    grid-template-columns: 110px 1fr;
    column-gap: var(--space-2xl, 3rem);
    align-items: start;
    padding: var(--space-2xl, 3rem) 0;
    border-top: 0.5px solid var(--dust, #d2d3cb);
  }
  .step:last-child {
    border-bottom: 0.5px solid var(--dust, #d2d3cb);
  }
  .step-number {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    color: var(--primary-fixed-dim, #c3caae);
    padding-top: 0.25rem;
  }
  .step-content {
    max-width: 560px;
  }
  .step-answer {
    font-family: 'Noto Serif', Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--on-surface, #1b1c1a);
    margin: 0 0 var(--space-md, 1rem) 0;
  }
  .step-context {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--on-surface-muted, #5c5d58);
    margin: 0;
  }
  @media (max-width: 768px) {
    .was-ki-macht {
      padding: var(--space-3xl, 4rem) 1.25rem;
    }
    .intro {
      margin-bottom: var(--space-3xl, 4rem);
    }
    .step {
      grid-template-columns: 64px 1fr;
      column-gap: var(--space-lg, 1.5rem);
      padding: var(--space-xl, 2rem) 0;
    }
    .step-number {
      font-size: 2rem;
      padding-top: 0.125rem;
    }
    .step-answer {
      font-size: 1.25rem;
      line-height: 1.35;
      margin-bottom: 0.625rem;
    }
    .step-context {
      font-size: 0.9375rem;
      line-height: 1.5;
    }
  }
  @media (max-width: 380px) {
    .step {
      grid-template-columns: 52px 1fr;
      column-gap: 1rem;
    }
    .step-number {
      font-size: 1.75rem;
    }
    .step-answer {
      font-size: 1.125rem;
    }
  }
</style>
