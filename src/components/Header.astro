---
---

<header class="site-header">
  <div class="header-inner">

    <a href="/" class="logo" aria-label="MarkMade – Startseite">
      mark<span>made</span>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">

      <div class="dropdown">
        <button class="nav-trigger" aria-haspopup="true">
          Leistungen
          <svg class="chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown-menu">
          <a href="/ki-fuer-unternehmen" class="dropdown-link">KI für Unternehmen – Übersicht</a>
          <a href="/webdesign-selbststaendige" class="dropdown-link">KI-Website &amp; Chatbot</a>
          <a href="/ki-telefonassistent" class="dropdown-link">KI-Telefonassistent</a>
          <a href="/ki-social-media" class="dropdown-link">Social Media mit KI</a>
          <a href="/ki-email" class="dropdown-link">E-Mail-Automatisierung</a>
          <a href="/ki-automatisierung" class="dropdown-link">Prozess-Automatisierung</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="nav-trigger" aria-haspopup="true">
          Branchen
          <svg class="chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown-menu dropdown-menu--wide">
          <p class="dropdown-category">Handwerk &amp; Gewerbe</p>
          <a href="/webdesign-handwerker" class="dropdown-link">Handwerker &amp; Betriebe</a>
          <p class="dropdown-category">Gesundheit</p>
          <a href="/webdesign-aerzte" class="dropdown-link">Ärzte &amp; Praxen</a>
          <p class="dropdown-category">Business &amp; Recht</p>
          <a href="/ki-kanzlei" class="dropdown-link">Kanzleien &amp; Steuerberater</a>
          <a href="/ki-immobilienmakler" class="dropdown-link">Immobilienmakler</a>
          <p class="dropdown-category">Gastronomie</p>
          <a href="/ki-restaurant" class="dropdown-link">Restaurants &amp; Cafés</a>
          <p class="dropdown-category">Selbstständige</p>
          <a href="/ki-fuer-unternehmen" class="dropdown-link">KI-Übersicht</a>
        </div>
      </div>

    </nav>

    <a href="https://calendly.com/onlinemaster711/new-meeting" class="cta-button" target="_blank" rel="noopener noreferrer">Gespräch buchen</a>

    <button class="burger" id="burger" aria-label="Menü öffnen">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-inner">
      <p class="mobile-section-label">Leistungen</p>
      <a href="/webdesign-selbststaendige" class="mobile-link">KI-Website &amp; Chatbot</a>
      <a href="/ki-telefonassistent" class="mobile-link">KI-Telefonassistent</a>
      <a href="/ki-social-media" class="mobile-link">Social Media mit KI</a>
      <a href="/ki-email" class="mobile-link">E-Mail-Automatisierung</a>
      <a href="/ki-automatisierung" class="mobile-link">Prozess-Automatisierung</a>

      <p class="mobile-section-label">Branchen</p>
      <a href="/webdesign-handwerker" class="mobile-link">Handwerker &amp; Betriebe</a>
      <a href="/webdesign-aerzte" class="mobile-link">Ärzte &amp; Praxen</a>
      <a href="/ki-kanzlei" class="mobile-link">Kanzleien &amp; Steuerberater</a>
      <a href="/ki-immobilienmakler" class="mobile-link">Immobilienmakler</a>
      <a href="/ki-restaurant" class="mobile-link">Restaurants &amp; Cafés</a>
      <a href="/webdesign-selbststaendige" class="mobile-link">Coaches &amp; Berater</a>

      <a href="https://calendly.com/onlinemaster711/new-meeting" class="mobile-cta" target="_blank" rel="noopener noreferrer">Gespräch buchen</a>
    </div>
  </div>

</header>

<script>
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });
  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--outline-variant);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--on-surface);
    flex-shrink: 0;
  }

  .logo span {
    color: var(--secondary);
  }

  /* Nav */
  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  /* Dropdown trigger */
  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .nav-trigger:hover {
    color: var(--on-surface);
    background: var(--surface-low);
  }

  .chevron {
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: white;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.04);
    padding: 0.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: translateY(-4px);
    min-width: 220px;
    z-index: 100;
  }

  .dropdown-menu--wide {
    min-width: 240px;
  }

  .dropdown:hover .dropdown-menu {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
  }

  .dropdown-category {
    font-size: 11px;
    font-weight: 600;
    color: var(--on-surface-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 0.75rem 0.25rem;
    margin: 0;
  }

  .dropdown-category:not(:first-child) {
    margin-top: 0.25rem;
    border-top: 1px solid var(--outline-variant);
    padding-top: 0.625rem;
  }

  .dropdown-link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 14px;
    color: var(--on-surface);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: background 0.15s, color 0.15s;
  }

  .dropdown-link:hover {
    background: var(--surface-low);
    color: var(--secondary);
  }

  /* CTA Button */
  .cta-button {
    flex-shrink: 0;
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .cta-button:hover {
    opacity: 0.88;
  }

  /* Burger */
  .burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--on-surface);
    flex-shrink: 0;
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    background: white;
    border-top: 1px solid var(--outline-variant);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .mobile-menu.open {
    display: block;
    max-height: 100vh;
  }

  .mobile-menu-inner {
    padding: 1.25rem 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--on-surface-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.75rem 0 0.25rem;
    margin: 0;
  }

  .mobile-section-label:not(:first-child) {
    margin-top: 0.5rem;
    border-top: 1px solid var(--outline-variant);
    padding-top: 1rem;
  }

  .mobile-link {
    display: block;
    padding: 0.5rem 0.25rem;
    font-size: 0.9375rem;
    color: var(--on-surface);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: color 0.15s;
  }

  .mobile-link:hover {
    color: var(--secondary);
  }

  .mobile-cta {
    display: block;
    margin-top: 1.25rem;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: white;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    text-align: center;
    transition: opacity 0.2s;
  }

  .mobile-cta:hover {
    opacity: 0.88;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .nav {
      display: none;
    }

    .cta-button {
      display: none;
    }

    .burger {
      display: block;
      margin-left: auto;
    }
  }
</style>
