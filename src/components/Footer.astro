<style>
  .site-footer {
    background: var(--primary);
    color: rgba(255, 255, 255, 0.55);
    padding-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.25fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  /* Brand column */
  .footer-col--brand .footer-logo {
    display: inline-block;
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    margin-bottom: 0.875rem;
  }

  .footer-col--brand .footer-logo span {
    color: var(--secondary);
  }

  .footer-tagline {
    font-family: 'Noto Serif', serif;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.4;
    margin-bottom: 0.625rem;
  }

  .footer-sub {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.45);
  }

  /* Generic column */
  .footer-col-title {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9375rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #fff;
  }

  /* Divider between ratgeber and legal links */
  .footer-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin: 0.5rem 0;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    gap: 1rem;
  }

  .footer-bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-bottom a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
  }

  .footer-bottom a:hover {
    color: #fff;
  }

  @media (max-width: 1023px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
    }

    .footer-col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-col--brand {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-bottom-links {
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
