<script>
  document.querySelectorAll('.acc-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.acc-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        body.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        icon.textContent = '+';
      } else {
        body.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        icon.textContent = '−';
      }
    });
  });
</script>

<style>
  .site-footer {
    background: var(--surface-low);
    color: var(--on-surface);
  }

  /* ── HAUPTBEREICH ── */
  .footer-main {
    padding: 48px 24px 32px;
  }

  .footer-main-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
  }

  /* Brand */
  .footer-brand {
    flex-shrink: 0;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }

  .footer-logo-svg {
    height: 28px;
    width: auto;
    display: block;
  }

  .footer-logo-text {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 160px;
    font-weight: 700;
    letter-spacing: -5.6px;
  }

  .footer-logo-text-mark { fill: #1b1c1a; }
  .footer-logo-text-made { fill: #b80049; }

  .footer-tagline {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: var(--on-surface-muted);
    line-height: 1.5;
    max-width: 18ch;
  }

  .footer-own-projects {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-own-projects a {
    color: var(--on-surface-muted);
    text-decoration: none;
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .footer-own-projects a:hover {
    color: var(--on-surface);
  }

  /* Desktop 4 Spalten */
  .footer-cols {
    display: flex;
    gap: 48px;
    flex-shrink: 0;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
  }

  .footer-col-title {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--on-surface);
    margin-bottom: 12px;
  }

  .footer-col a {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: var(--on-surface-muted);
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--on-surface);
  }

  /* Mobile Akkordeon — standardmäßig versteckt */
  .footer-accordion {
    display: none;
  }

  /* ── BOTTOM BAR ── */
  .footer-bottom {
    border-top: 1px solid var(--dust);
    padding: 20px 24px;
  }

  .footer-bottom-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
  }

  .footer-copy {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-muted);
  }

  .footer-legal a {
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-legal a:hover {
    color: var(--on-surface);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-social a {
    color: var(--on-surface-muted);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: var(--on-surface);
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {

    .footer-main {
      padding: 0;
    }

    .footer-main-inner {
      flex-direction: column;
      gap: 0;
    }

    .footer-brand {
      padding: 32px 24px 16px;
    }

    .footer-tagline {
      max-width: none;
    }

    /* Desktop-Spalten ausblenden */
    .footer-cols {
      display: none;
    }

    /* Akkordeon einblenden */
    .footer-accordion {
      display: block;
      width: 100%;
    }

    .acc-block {
      border-top: 1px solid var(--dust);
    }

    .acc-header {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      background: none;
      border: none;
      cursor: pointer;
      font-family: 'Manrope', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--on-surface);
    }

    .acc-icon {
      color: var(--on-surface-muted);
      font-size: 1.25rem;
      line-height: 1;
    }

    .acc-body {
      padding: 0 24px 16px;
      flex-direction: column;
    }

    .acc-body:not([hidden]) {
      display: flex;
    }

    .acc-body a {
      font-family: 'Manrope', sans-serif;
      font-size: 0.85rem;
      color: var(--on-surface-muted);
      text-decoration: none;
      display: block;
      margin-bottom: 8px;
      transition: color 0.15s;
    }

    .acc-body a:hover {
      color: var(--on-surface);
    }

  }
</style>
