---
interface Message {
  role: 'user' | 'bot';
  text: string;
}

interface Props {
  messages: Message[];
  title?: string;
}

const { messages, title = 'So funktioniert Ihr Chatbot' } = Astro.props;
---

<div class="chat-demo-wrapper">
  <div class="chat-label">Beispiel</div>
  <h3 class="chat-title">{title}</h3>

  <div class="chat-container">
    <!-- Header -->
    <div class="chat-header">
      <span class="online-indicator">● Online</span>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chat-messages">
      <!-- Messages will be inserted here by JavaScript -->
    </div>
  </div>
</div>

<script define:vars={{ messages }}>
  const chatMessagesContainer = document.getElementById('chat-messages');

  function createUserMessage(text) {
    const div = document.createElement('div');
    div.className = 'chat-demo-msg user';
    div.style.opacity = '0';
    div.style.transition = 'opacity 0.3s ease';
    div.innerHTML = `<div class="chat-demo-bubble user">${text}</div>`;
    return div;
  }

  function createBotMessage(text) {
    const div = document.createElement('div');
    div.className = 'chat-demo-msg bot';
    div.style.opacity = '0';
    div.style.transition = 'opacity 0.3s ease';
    div.innerHTML = `
      <div class="chat-demo-bot-av">M</div>
      <div class="chat-demo-bubble bot">${text}</div>
    `;
    return div;
  }

  function createTypingIndicator() {
    const div = document.createElement('div');
    div.className = 'chat-demo-msg bot';
    div.innerHTML = `
      <div class="chat-demo-bot-av">M</div>
      <div class="chat-demo-typing">
        <span></span><span></span><span></span>
      </div>
    `;
    return div;
  }

  async function showMessage(element) {
    chatMessagesContainer.appendChild(element);
    // Trigger reflow to ensure transition works
    element.offsetHeight;
    element.style.opacity = '1';
    await new Promise(resolve => setTimeout(resolve, 300));
  }

  async function playConversation() {
    for (let i = 0; i < messages.length; i++) {
      const message = messages[i];

      if (message.role === 'user') {
        const userMsg = createUserMessage(message.text);
        await showMessage(userMsg);
        await new Promise(resolve => setTimeout(resolve, 800));
      } else {
        // Show typing indicator
        const typingMsg = createTypingIndicator();
        chatMessagesContainer.appendChild(typingMsg);
        await new Promise(resolve => setTimeout(resolve, 1500));
        chatMessagesContainer.removeChild(typingMsg);

        // Show bot message
        const botMsg = createBotMessage(message.text);
        await showMessage(botMsg);
        await new Promise(resolve => setTimeout(resolve, 800));
      }

      // Scroll to latest message
      chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
    }
  }

  async function loop() {
    while (true) {
      await playConversation();
      // Pause before restarting
      await new Promise(resolve => setTimeout(resolve, 3000));
      // Clear messages
      chatMessagesContainer.innerHTML = '';
    }
  }

  // Start the loop
  loop();
</script>

<style is:global>
  .chat-demo-wrapper {
    padding: 3rem 1.5rem;
  }

  .chat-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .chat-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0 0 2rem 0;
    line-height: 1.3;
  }

  .chat-container {
    max-width: 480px;
    margin: 0 auto;
    background: #f5f3f0;
    border-radius: 1.2rem;
    box-shadow: 0 8px 32px rgba(27, 28, 26, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 420px;
  }

  /* Header */
  .chat-header {
    background: var(--primary);
    padding: 1rem 1.25rem;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .online-indicator {
    font-size: 0.9rem;
    letter-spacing: 0.5px;
  }

  /* Messages */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .chat-demo-msg {
    display: flex;
    margin-bottom: 12px;
  }

  .chat-demo-msg.user {
    justify-content: flex-end;
  }

  .chat-demo-msg.bot {
    justify-content: flex-start;
    align-items: flex-end;
    gap: 8px;
  }

  /* Bot Avatar */
  .chat-demo-bot-av {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--primary);
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Bubbles */
  .chat-demo-bubble {
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.4;
    max-width: 75%;
    word-wrap: break-word;
  }

  .chat-demo-bubble.user {
    background: #b80049;
    color: white;
    border-radius: 18px 18px 4px 18px;
  }

  .chat-demo-bubble.bot {
    background: white;
    color: #1b1c1a;
    border-radius: 18px 18px 18px 4px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  /* Typing Indicator */
  .chat-demo-typing {
    background: white;
    padding: 10px 14px;
    border-radius: 18px 18px 18px 4px;
    display: flex;
    gap: 4px;
    align-items: center;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .chat-demo-typing span {
    width: 7px;
    height: 7px;
    background: #999;
    border-radius: 50%;
    animation: bounce 1.2s infinite;
  }

  .chat-demo-typing span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .chat-demo-typing span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes bounce {
    0%, 60%, 100% {
      transform: translateY(0);
    }
    30% {
      transform: translateY(-6px);
    }
  }

  /* Scrollbar */
  .chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(63, 69, 48, 0.15);
    border-radius: 2px;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .chat-container {
      height: 400px;
    }

    .chat-demo-bubble {
      max-width: 85%;
      font-size: 13px;
    }

    .chat-title {
      font-size: 1.25rem;
    }
  }
</style>
