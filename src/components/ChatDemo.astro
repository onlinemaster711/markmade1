---
interface Message {
  role: 'user' | 'bot';
  text: string;
}

interface Props {
  messages: Message[];
  title?: string;
}

const { messages, title = 'So funktioniert Ihr Chatbot' } = Astro.props;
---

<div class="chat-demo">
  <div class="chat-container">
    <div class="chat-header">
      <h3>{title}</h3>
    </div>

    <div class="chat-messages" id="chat-messages">
      <!-- Messages will be inserted here by JavaScript -->
    </div>
  </div>
</div>

<script define:vars={{ messages }}>
  const chatMessagesContainer = document.getElementById('chat-messages');
  let currentIndex = 0;

  function createUserMessage(text) {
    const div = document.createElement('div');
    div.className = 'message-wrapper user-wrapper';
    div.innerHTML = `<div class="message user-message">${text}</div>`;
    return div;
  }

  function createBotMessage(text) {
    const div = document.createElement('div');
    div.className = 'message-wrapper bot-wrapper';
    div.innerHTML = `<div class="message bot-message">${text}</div>`;
    return div;
  }

  function createTypingIndicator() {
    const div = document.createElement('div');
    div.className = 'message-wrapper bot-wrapper';
    div.innerHTML = `<div class="message bot-message typing">
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
    </div>`;
    return div;
  }

  async function playConversation() {
    for (let i = 0; i < messages.length; i++) {
      const message = messages[i];

      if (message.role === 'user') {
        const userMsg = createUserMessage(message.text);
        chatMessagesContainer.appendChild(userMsg);
        await new Promise(resolve => setTimeout(resolve, 1500));
      } else {
        // Show typing indicator
        const typingMsg = createTypingIndicator();
        chatMessagesContainer.appendChild(typingMsg);
        await new Promise(resolve => setTimeout(resolve, 800));
        chatMessagesContainer.removeChild(typingMsg);

        // Show bot message
        const botMsg = createBotMessage(message.text);
        chatMessagesContainer.appendChild(botMsg);
        await new Promise(resolve => setTimeout(resolve, 1500));
      }

      // Scroll to latest message
      chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
    }
  }

  async function loop() {
    while (true) {
      await playConversation();
      // Pause before restarting
      await new Promise(resolve => setTimeout(resolve, 2000));
      // Clear messages
      chatMessagesContainer.innerHTML = '';
    }
  }

  // Start the loop
  loop();
</script>

<style>
  .chat-demo {
    padding: 3rem 1.5rem;
  }

  .chat-container {
    max-width: 600px;
    margin: 0 auto;
    background: var(--surface-lowest);
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 24px 48px rgba(27, 28, 26, 0.12);
    display: flex;
    flex-direction: column;
    height: 500px;
  }

  .chat-header {
    background: var(--primary);
    padding: 1.5rem;
    color: white;
  }

  .chat-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .message-wrapper {
    display: flex;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .message {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 80%;
    word-wrap: break-word;
  }

  .user-wrapper {
    justify-content: flex-end;
  }

  .user-message {
    background: var(--secondary);
    color: white;
    border-radius: 0.75rem 0.25rem 0.75rem 0.75rem;
  }

  .bot-wrapper {
    justify-content: flex-start;
  }

  .bot-message {
    background: var(--surface-low);
    color: var(--on-surface);
    border-radius: 0.25rem 0.75rem 0.75rem 0.75rem;
  }

  /* Typing indicator */
  .typing {
    display: flex;
    gap: 0.35rem;
    padding: 0.75rem 1rem;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--on-surface-muted);
    animation: bounce 1.4s infinite;
  }

  .dot:nth-child(1) {
    animation-delay: 0s;
  }

  .dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes bounce {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    30% {
      transform: translateY(-6px);
      opacity: 1;
    }
  }

  /* Scrollbar styling */
  .chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(63, 69, 48, 0.2);
    border-radius: 4px;
  }

  @media (max-width: 767px) {
    .chat-container {
      height: 400px;
    }

    .message {
      max-width: 90%;
      font-size: 0.875rem;
    }

    .chat-header h3 {
      font-size: 0.95rem;
    }
  }
</style>
