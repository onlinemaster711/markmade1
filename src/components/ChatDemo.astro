---
interface Message {
  role: 'user' | 'bot';
  text: string;
}

interface Props {
  messages: Message[];
}

const { messages } = Astro.props;
---

<div class="chat-demo">
  <div class="chat-container">
    <!-- Header -->
    <div class="chat-header">
      <div class="header-content">
        <div class="avatar">M</div>
        <div class="header-info">
          <h3>MarkMade Assistent</h3>
          <div class="online-status">
            <span class="online-dot"></span>
            <span class="online-text">Online</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chat-messages">
      <!-- Messages will be inserted here by JavaScript -->
    </div>
  </div>
</div>

<script define:vars={{ messages }}>
  const chatMessagesContainer = document.getElementById('chat-messages');

  function createUserMessage(text) {
    const div = document.createElement('div');
    div.className = 'message-group user-group';
    div.innerHTML = `<div class="bubble user-bubble">${text}</div>`;
    return div;
  }

  function createBotMessage(text) {
    const div = document.createElement('div');
    div.className = 'message-group bot-group';
    div.innerHTML = `
      <div class="avatar-small">M</div>
      <div class="bubble bot-bubble">${text}</div>
    `;
    return div;
  }

  function createTypingIndicator() {
    const div = document.createElement('div');
    div.className = 'message-group bot-group';
    div.innerHTML = `
      <div class="avatar-small">M</div>
      <div class="bubble bot-bubble typing">
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
      </div>
    `;
    return div;
  }

  async function playConversation() {
    for (let i = 0; i < messages.length; i++) {
      const message = messages[i];

      if (message.role === 'user') {
        const userMsg = createUserMessage(message.text);
        chatMessagesContainer.appendChild(userMsg);
        await new Promise(resolve => setTimeout(resolve, 1200));
      } else {
        // Show typing indicator
        const typingMsg = createTypingIndicator();
        chatMessagesContainer.appendChild(typingMsg);
        await new Promise(resolve => setTimeout(resolve, 1000));
        chatMessagesContainer.removeChild(typingMsg);

        // Show bot message
        const botMsg = createBotMessage(message.text);
        chatMessagesContainer.appendChild(botMsg);
        await new Promise(resolve => setTimeout(resolve, 1200));
      }

      // Scroll to latest message
      chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
    }
  }

  async function loop() {
    while (true) {
      await playConversation();
      // Pause before restarting
      await new Promise(resolve => setTimeout(resolve, 2500));
      // Clear messages
      chatMessagesContainer.innerHTML = '';
    }
  }

  // Start the loop
  loop();
</script>

<style>
  .chat-demo {
    padding: 3rem 1.5rem;
  }

  .chat-container {
    max-width: 500px;
    margin: 0 auto;
    background: white;
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 24px 48px rgba(27, 28, 26, 0.12);
    display: flex;
    flex-direction: column;
    height: 420px;
  }

  /* Header */
  .chat-header {
    background: var(--primary);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
  }

  .header-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .header-info {
    flex: 1;
  }

  .header-info h3 {
    margin: 0;
    color: white;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .online-status {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.15rem;
  }

  .online-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: #34d399;
  }

  .online-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.75rem;
  }

  /* Messages */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    background: #f5f3f0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .message-group {
    display: flex;
    animation: messageSlideIn 0.3s ease;
  }

  @keyframes messageSlideIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .user-group {
    justify-content: flex-end;
  }

  .bot-group {
    justify-content: flex-start;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .avatar-small {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  /* Bubbles */
  .bubble {
    padding: 0.625rem 0.875rem;
    border-radius: 18px;
    font-size: 0.9375rem;
    line-height: 1.4;
    max-width: 75%;
    word-wrap: break-word;
    animation: bubbleFadeIn 0.2s ease 0.05s both;
  }

  @keyframes bubbleFadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .user-bubble {
    background: var(--secondary);
    color: white;
    border-radius: 18px 18px 4px 18px;
  }

  .bot-bubble {
    background: white;
    color: var(--on-surface);
    border-radius: 18px 18px 18px 4px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  /* Typing Indicator */
  .typing {
    display: flex;
    gap: 0.3rem;
    padding: 0.625rem 0.875rem;
    min-width: 50px;
  }

  .typing-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #999;
    animation: typingBounce 1.4s infinite;
  }

  .typing-dot:nth-child(1) {
    animation-delay: 0s;
  }

  .typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typingBounce {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    30% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }

  /* Scrollbar */
  .chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(63, 69, 48, 0.15);
    border-radius: 2px;
  }

  .chat-messages::-webkit-scrollbar-thumb:hover {
    background: rgba(63, 69, 48, 0.25);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .chat-container {
      height: 400px;
      max-width: 100%;
      border-radius: 0.8rem;
    }

    .bubble {
      max-width: 85%;
      font-size: 0.875rem;
    }

    .chat-header {
      padding: 0.875rem 1rem;
    }

    .header-info h3 {
      font-size: 0.9rem;
    }

    .avatar {
      width: 36px;
      height: 36px;
    }
  }
</style>
