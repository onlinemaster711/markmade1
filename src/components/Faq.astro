---
const fragen = [
  {
    frage: 'Was kostet das?',
    antwort: 'Die Website kostet 1.000 € inkl. MwSt. – Festpreis, alles inklusive. Der Chatbot optional dazu für 500 € einmalig. Der Entwurf ist kostenlos.',
  },
  {
    frage: 'Ich habe keine Zeit dafür.',
    antwort: 'Genau 10 Minuten Gespräch – das ist alles. Den Rest übernehmen wir vollständig.',
  },
  {
    frage: 'Was wenn mir der Entwurf nicht gefällt?',
    antwort: 'Dann zahlst du nichts. Kein Vertrag, keine Rechnung. Du entscheidest erst wenn du siehst was du bekommst.',
  },
  {
    frage: 'Unsere Seite ist doch eigentlich okay.',
    antwort: 'Möglich. Der kostenlose Entwurf zeigt dir konkret was möglich wäre. Unverbindlich.',
  },
  {
    frage: 'Wie könnt ihr das für 1.000 € anbieten?',
    antwort: 'Wir arbeiten effizienter als klassische Agenturen – durch KI erledigen wir in Stunden was andere Wochen brauchen. Den Vorteil geben wir weiter.',
  },
  {
    frage: 'Wenn KI so viel kann – warum brauche ich noch jemanden?',
    antwort: 'KI macht gute Leute besser. Aber sie macht niemanden gut der sich nicht auskennt. Marketing ist unser Handwerk – KI ist unser Werkzeug.',
  },
];
---

<section class="faq" id="faq">
  <div class="inner">

    <div class="section-head">
      <h2>Was dich vielleicht noch beschäftigt.</h2>
    </div>

    <div class="faq-grid">
      {fragen.map((f) => (
        <div class="faq-item fade-in">
          <h3>{f.frage}</h3>
          <p>{f.antwort}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .faq {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .faq-item {
    padding: 2rem;
    border-bottom: 1px solid var(--outline-variant);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .faq-item:nth-child(odd) {
    border-right: 1px solid var(--outline-variant);
  }

  h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--on-surface);
  }

  p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--on-surface-muted);
  }

  @media (max-width: 767px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }

    .faq-item:nth-child(odd) {
      border-right: none;
    }

    .faq-item {
      padding: 1.5rem 0;
    }
  }
</style>
