---
const punkte = [
  {
    nr: '01',
    icon: '🎯',
    label: 'Was du machst',
    titel: 'Wer kommt, weiß warum er kommt',
    text: 'Wer sofort versteht was du anbietest, ruft nicht aus Versehen an.',
  },
  {
    nr: '02',
    icon: '👥',
    label: 'Für wen du es machst',
    titel: 'Die Falschen filtern sich selbst raus',
    text: 'Wer nicht zu dir passt, merkt es selbst – bevor er dich anruft.',
  },
  {
    nr: '03',
    icon: '⚙️',
    label: 'Wie du arbeitest',
    titel: 'Vertrauen entsteht bevor du sprichst',
    text: 'Wer deinen Ablauf kennt, kommt mit Entscheidung.',
  },
  {
    nr: '04',
    icon: '🚫',
    label: 'Was du nicht machst',
    titel: 'Keine Zeit mehr für falsche Anfragen',
    text: 'Klare Grenzen ziehen die richtigen Kunden an.',
  },
];
---

<section class="sec-vierfragen">
  <div class="vierfragen-inner">

    <div class="section-head">
      <div class="section-eyebrow"><span>Warum klare Websites mehr Kunden bringen</span></div>
      <h2 class="section-headline">Die meisten Websites lassen zu viele Fragen offen.</h2>
      <p class="section-lede">Deshalb rufen die Falschen an. Deshalb dauern Gespräche zu lang. Deshalb zögern Kunden.</p>
    </div>

    <div class="fragen-grid">
      {punkte.map((p) => (
        <article class="frage fade-in">
          <div class="frage-num" aria-hidden="true">{p.nr}</div>
          <div class="frage-body">
            <div class="frage-meta">
              <span class="frage-icon" aria-hidden="true">{p.icon}</span>
              <span class="frage-label">{p.label}</span>
            </div>
            <h3 class="frage-title">{p.titel}</h3>
            <p class="frage-text">{p.text}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="section-outro fade-in">
      <em>Das klärt dein Chatbot automatisch – bevor du ins Gespräch gehst.</em>
    </p>

  </div>
</section>

<style>
  .sec-vierfragen {
    background: var(--surface-low);
    padding: 6rem 2.5rem;
    position: relative;
  }

  .vierfragen-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* Section Head */
  .section-head {
    max-width: 760px;
    margin: 0 auto 4.5rem;
    text-align: center;
  }

  .section-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .section-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--secondary);
  }

  .section-headline {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--on-surface);
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .section-lede {
    font-family: 'Manrope', sans-serif;
    font-weight: 300;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.7;
    color: var(--on-surface-muted);
    max-width: 620px;
    margin: 0 auto;
  }

  /* Fragen Grid */
  .fragen-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .frage {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 3rem;
    align-items: start;
    padding: 2.75rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .frage:last-child {
    border-bottom: 1px solid var(--outline-variant);
  }

  .frage-num {
    font-family: 'Noto Serif', serif;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    color: var(--secondary);
    opacity: 0.35;
    text-align: right;
    letter-spacing: -0.02em;
  }

  .frage-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .frage-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .frage-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .frage-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--secondary);
  }

  .frage-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.375rem, 2vw, 1.625rem);
    font-weight: 600;
    line-height: 1.25;
    color: var(--on-surface);
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }

  .frage-text {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--on-surface-muted);
    margin: 0;
    max-width: 56ch;
  }

  /* Outro */
  .section-outro {
    margin: 5rem auto 0;
    max-width: 720px;
    text-align: center;
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.125rem, 1.8vw, 1.25rem);
    line-height: 1.5;
    color: var(--on-surface);
    letter-spacing: -0.005em;
  }

  .section-outro em {
    font-style: italic;
    color: var(--on-surface);
  }

  /* Mobile */
  @media (max-width: 860px) {
    .sec-vierfragen {
      padding: 4rem 1.5rem;
    }

    .section-head {
      margin-bottom: 3rem;
    }

    .frage {
      grid-template-columns: 60px 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
    }

    .frage-num {
      font-size: 2rem;
    }

    .frage-title {
      font-size: 1.25rem;
    }

    .section-outro {
      margin-top: 3.5rem;
    }
  }
</style>
