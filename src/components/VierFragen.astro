---
const punkte = [
  {
    icon: '🎯',
    label: 'Was du machst',
    titel: 'Wer kommt, weiß warum er kommt',
    text: 'Wer sofort versteht was du anbietest, ruft nicht aus Versehen an.',
  },
  {
    icon: '👥',
    label: 'Für wen du es machst',
    titel: 'Die Falschen filtern sich selbst raus',
    text: 'Wer nicht zu dir passt, merkt es selbst – bevor er dich anruft.',
  },
  {
    icon: '⚙️',
    label: 'Wie du arbeitest',
    titel: 'Vertrauen entsteht bevor du sprichst',
    text: 'Wer deinen Ablauf kennt, kommt mit Entscheidung.',
  },
  {
    icon: '🚫',
    label: 'Was du nicht machst',
    titel: 'Keine Zeit mehr für falsche Anfragen',
    text: 'Klare Grenzen ziehen die richtigen Kunden an.',
  },
];
---

<section class="vier-fragen">
  <div class="inner">

    <div class="section-head">
      <p class="eyebrow">Warum klare Websites mehr Kunden bringen</p>
      <h2>Die meisten Websites lassen zu viele Fragen offen.</h2>
      <p class="subtext">Deshalb rufen die Falschen an. Deshalb dauern Gespräche zu lang. Deshalb zögern Kunden.</p>
    </div>

    <div class="punkte-liste">
      {punkte.map((p) => (
        <div class="punkt fade-in">
          <span class="punkt-icon" aria-hidden="true">{p.icon}</span>
          <div class="punkt-body">
            <span class="punkt-label">{p.label}</span>
            <h3>{p.titel}</h3>
            <p>{p.text}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="abschluss fade-in">
      <em>Das klärt dein Chatbot automatisch – bevor du ins Gespräch gehst.</em>
    </p>

  </div>
</section>

<style>
  .vier-fragen {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 0.875rem;
  }

  .subtext {
    font-size: 1.0625rem;
    color: var(--on-surface-muted);
    line-height: 1.6;
  }

  .punkte-liste {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .punkt {
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--outline-variant);
    align-items: flex-start;
  }

  .punkt:first-child {
    border-top: 1px solid var(--outline-variant);
  }

  .punkt-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
    line-height: 1;
  }

  .punkt-body {
    flex: 1;
  }

  .punkt-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.375rem;
  }

  .punkt-body h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.375rem;
    color: var(--on-surface);
  }

  .punkt-body p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  .abschluss {
    margin-top: 2.5rem;
    font-size: 1.0625rem;
    color: var(--on-surface-muted);
    line-height: 1.6;
    padding-left: 0.25rem;
    border-left: 3px solid var(--secondary);
    padding-left: 1rem;
  }
</style>
