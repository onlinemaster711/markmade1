---
interface Props {
  title?: string;
}

const { title = 'So funktioniert die Online-Terminbuchung' } = Astro.props;
---

<div class="chat-cal-wrapper">
  <div class="chat-cal-label">Beispiel</div>
  <h3 class="chat-cal-title">{title}</h3>

  <div class="chat-cal-demo">

    <!-- LEFT: Chat -->
    <div class="chat-cal-chat-panel">
      <div class="chat-cal-chat-header">
        <div class="chat-cal-avatar">M</div>
        <div class="chat-cal-header-info">
          <span class="chat-cal-bot-name">Terminassistent</span>
          <div class="chat-cal-status">
            <span class="chat-cal-online-dot"></span>
            <span class="chat-cal-online-text">Online</span>
          </div>
        </div>
      </div>
      <div class="chat-cal-messages" id="cal-messages"></div>
    </div>

    <!-- RIGHT: Calendar -->
    <div class="chat-cal-calendar">
      <div class="chat-cal-cal-header">April 2026</div>
      <div class="chat-cal-cal-body">
        <div class="chat-cal-cal-grid">
          <!-- Day headers -->
          <div class="chat-cal-day-header">Mo 14.</div>
          <div class="chat-cal-day-header">Di 15.</div>
          <div class="chat-cal-day-header">Mi 16.</div>
          <div class="chat-cal-day-header">Do 17.</div>
          <div class="chat-cal-day-header">Fr 18.</div>

          <!-- 09:00 row -->
          <div class="chat-cal-slot frei" id="slot-mo-09">09:00</div>
          <div class="chat-cal-slot frei" id="slot-di-09">09:00</div>
          <div class="chat-cal-slot frei" id="slot-mi-09">09:00</div>
          <div class="chat-cal-slot belegt" id="slot-do-09">09:00</div>
          <div class="chat-cal-slot frei" id="slot-fr-09">09:00</div>

          <!-- 10:00 row -->
          <div class="chat-cal-slot frei" id="slot-mo-10">10:00</div>
          <div class="chat-cal-slot belegt" id="slot-di-10">10:00</div>
          <div class="chat-cal-slot belegt" id="slot-mi-10">10:00</div>
          <div class="chat-cal-slot frei" id="slot-do-10">10:00</div>
          <div class="chat-cal-slot frei" id="slot-fr-10">10:00</div>

          <!-- 11:00 row -->
          <div class="chat-cal-slot belegt" id="slot-mo-11">11:00</div>
          <div class="chat-cal-slot frei" id="slot-di-11">11:00</div>
          <div class="chat-cal-slot frei" id="slot-mi-11">11:00</div>
          <div class="chat-cal-slot frei" id="slot-do-11">11:00</div>
          <div class="chat-cal-slot belegt" id="slot-fr-11">11:00</div>
        </div>

        <!-- Legend -->
        <div class="chat-cal-legend">
          <div class="chat-cal-legend-item">
            <div class="chat-cal-legend-dot frei"></div>
            <span>Frei</span>
          </div>
          <div class="chat-cal-legend-item">
            <div class="chat-cal-legend-dot belegt"></div>
            <span>Belegt</span>
          </div>
          <div class="chat-cal-legend-item">
            <div class="chat-cal-legend-dot vorschlag"></div>
            <span>Vorschlag</span>
          </div>
          <div class="chat-cal-legend-item">
            <div class="chat-cal-legend-dot gebucht"></div>
            <span>Gebucht</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  const messagesEl = document.getElementById('cal-messages')!;

  function delay(ms: number) {
    return new Promise(res => setTimeout(res, ms));
  }

  function setSlot(id: string, state: string) {
    const el = document.getElementById(id);
    if (el) el.className = `chat-cal-slot ${state}`;
  }

  function resetSlots() {
    setSlot('slot-mo-09', 'frei');
    setSlot('slot-di-09', 'frei');
    setSlot('slot-mi-09', 'frei');
    setSlot('slot-mo-10', 'frei');
  }

  function createUserMsg(text: string) {
    const div = document.createElement('div');
    div.className = 'chat-cal-msg user';
    div.style.opacity = '0';
    div.style.transition = 'opacity 0.3s ease';
    div.innerHTML = `<div class="chat-cal-bubble user">${text}</div>`;
    return div;
  }

  function createBotMsg(text: string) {
    const div = document.createElement('div');
    div.className = 'chat-cal-msg bot';
    div.style.opacity = '0';
    div.style.transition = 'opacity 0.3s ease';
    div.innerHTML = `
      <div class="chat-cal-bot-av">M</div>
      <div class="chat-cal-bubble bot">${text}</div>
    `;
    return div;
  }

  function createTyping() {
    const div = document.createElement('div');
    div.className = 'chat-cal-msg bot';
    div.innerHTML = `
      <div class="chat-cal-bot-av">M</div>
      <div class="chat-cal-typing">
        <span></span><span></span><span></span>
      </div>
    `;
    return div;
  }

  async function show(el: HTMLElement) {
    messagesEl.appendChild(el);
    el.offsetHeight; // trigger reflow
    el.style.opacity = '1';
    messagesEl.scrollTop = messagesEl.scrollHeight;
    await delay(300);
  }

  async function typing(ms: number) {
    const t = createTyping();
    messagesEl.appendChild(t);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    await delay(ms);
    messagesEl.removeChild(t);
  }

  async function run() {
    while (true) {
      messagesEl.innerHTML = '';
      resetSlots();
      await delay(800);

      // User asks
      await show(createUserMsg('Ich brauche einen Termin diese Woche, ca. 30 Min.'));
      await delay(700);

      // Bot typing → first response
      await typing(1400);
      await show(createBotMsg('Ich schaue welche freien Slots passen...'));
      await delay(500);

      // Calendar: mark 3 suggestions
      setSlot('slot-mo-10', 'vorschlag');
      setSlot('slot-di-09', 'vorschlag');
      setSlot('slot-mi-09', 'vorschlag');
      await delay(700);

      // Bot names the slots
      await show(createBotMsg('Ich habe 3 passende Termine: Mo 10:00, Di 09:00 oder Mi 09:00.'));
      await delay(1000);

      // User picks
      await show(createUserMsg('Mi 09:00 passt mir gut.'));
      await delay(700);

      // Bot typing → confirms
      await typing(1400);
      await show(createBotMsg('Perfekt – Mi 16. April um 09:00 gebucht!'));
      await delay(500);

      // Calendar: Mo + Di back to frei, Mi booked
      setSlot('slot-mo-10', 'frei');
      setSlot('slot-di-09', 'frei');
      setSlot('slot-mi-09', 'gebucht');

      // Pause before loop
      await delay(4000);
    }
  }

  run();
</script>

<style is:global>
  .chat-cal-wrapper {
    padding: 3rem 1.5rem;
  }

  .chat-cal-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .chat-cal-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--on-surface);
    margin: 0 0 2rem 0;
    line-height: 1.3;
  }

  /* ── Two-column demo container ── */
  .chat-cal-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    max-width: 900px;
    margin: 0 auto;
    align-items: start;
  }

  /* ── Chat panel ── */
  .chat-cal-chat-panel {
    display: flex;
    flex-direction: column;
    height: 400px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(27, 28, 26, 0.1);
  }

  .chat-cal-chat-header {
    background: #3f4530;
    padding: 0.875rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .chat-cal-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat-cal-header-info {
    display: flex;
    flex-direction: column;
  }

  .chat-cal-bot-name {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .chat-cal-status {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .chat-cal-online-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
  }

  .chat-cal-online-text {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.7rem;
  }

  .chat-cal-messages {
    flex: 1;
    overflow-y: auto;
    padding: 0.875rem;
    background: #f5f3f0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chat-cal-messages::-webkit-scrollbar {
    width: 3px;
  }

  .chat-cal-messages::-webkit-scrollbar-thumb {
    background: rgba(63, 69, 48, 0.15);
    border-radius: 2px;
  }

  /* ── Bubbles ── */
  .chat-cal-msg {
    display: flex;
    margin-bottom: 8px;
  }

  .chat-cal-msg.user {
    justify-content: flex-end;
  }

  .chat-cal-msg.bot {
    justify-content: flex-start;
    align-items: flex-end;
    gap: 6px;
  }

  .chat-cal-bot-av {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #3f4530;
    color: white;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat-cal-bubble {
    padding: 8px 12px;
    font-size: 13px;
    line-height: 1.4;
    max-width: 78%;
    word-wrap: break-word;
  }

  .chat-cal-bubble.user {
    background: #b80049;
    color: white;
    border-radius: 16px 16px 4px 16px;
  }

  .chat-cal-bubble.bot {
    background: white;
    color: #1b1c1a;
    border-radius: 16px 16px 16px 4px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  /* ── Typing indicator ── */
  .chat-cal-typing {
    background: white;
    padding: 8px 12px;
    border-radius: 16px 16px 16px 4px;
    display: flex;
    gap: 4px;
    align-items: center;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .chat-cal-typing span {
    width: 6px;
    height: 6px;
    background: #999;
    border-radius: 50%;
    animation: chat-cal-bounce 1.2s infinite;
  }

  .chat-cal-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-cal-typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes chat-cal-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); }
  }

  /* ── Calendar panel ── */
  .chat-cal-calendar {
    display: flex;
    flex-direction: column;
    height: 400px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(27, 28, 26, 0.1);
  }

  .chat-cal-cal-header {
    background: #3f4530;
    color: white;
    text-align: center;
    padding: 0.875rem 1rem;
    font-weight: 600;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .chat-cal-cal-body {
    flex: 1;
    background: white;
    padding: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: hidden;
  }

  /* ── Calendar grid ── */
  .chat-cal-cal-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
    flex: 1;
  }

  .chat-cal-day-header {
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    color: #3f4530;
    padding: 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .chat-cal-slot {
    text-align: center;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.5rem 0.25rem;
    border-radius: 6px;
    transition: background 0.4s ease, color 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chat-cal-slot.frei {
    background: #dfe6c8;
    color: #3f4530;
  }

  .chat-cal-slot.belegt {
    background: #e8e8e8;
    color: #999;
    text-decoration: line-through;
  }

  .chat-cal-slot.vorschlag {
    background: #faeeda;
    color: #7a5a2a;
  }

  .chat-cal-slot.gebucht {
    background: #b80049;
    color: white;
    font-weight: 700;
  }

  /* ── Legend ── */
  .chat-cal-legend {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .chat-cal-legend-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.65rem;
    color: #666;
  }

  .chat-cal-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
  }

  .chat-cal-legend-dot.frei     { background: #dfe6c8; }
  .chat-cal-legend-dot.belegt   { background: #e8e8e8; }
  .chat-cal-legend-dot.vorschlag { background: #faeeda; }
  .chat-cal-legend-dot.gebucht  { background: #b80049; }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .chat-cal-demo {
      grid-template-columns: 1fr;
    }

    .chat-cal-chat-panel,
    .chat-cal-calendar {
      height: 340px;
    }

    .chat-cal-title {
      font-size: 1.25rem;
    }

    .chat-cal-slot,
    .chat-cal-day-header {
      font-size: 0.6rem;
    }
  }
</style>
