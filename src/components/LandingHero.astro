<section class="hero">
  <div class="hero-grid">
    <div class="hero-meta reveal">
      <hr>
      <span class="tag"><span class="pin"></span>KI Agentur · Stuttgart</span>
      <hr>
    </div>

    <h1 class="hero-h1 reveal">
      KI macht<br>
      dich <span class="em">besser.</span>
    </h1>

    <div class="hero-sub reveal">
      <hr>
      <p>Eine Person mit KI schlägt ein Team ohne.</p>
      <hr>
    </div>

    <div class="hero-cta reveal">
      <a class="btn btn-lg" href="#cta">Kostenloses Erstgespräch buchen <span class="arrow">→</span></a>
      <a class="btn btn-ghost btn-lg" href="#waski">Was KI heute schon macht</a>
    </div>

    <div class="hero-stats reveal">
      <div class="stat">
        <div class="num">24<span class="unit">/ 7</span></div>
        <div class="lbl">Erreichbarkeit</div>
      </div>
      <div class="stat">
        <div class="num">8<span class="unit">statt 40</span></div>
        <div class="lbl">Mails am Tag</div>
      </div>
      <div class="stat">
        <div class="num">&lt; 5<span class="unit">Min.</span></div>
        <div class="lbl">Bis zur Bestätigung</div>
      </div>
      <div class="stat">
        <div class="num">1×<span class="unit">bezahlt</span></div>
        <div class="lbl">Kein Abo</div>
      </div>
    </div>
  </div>
</section>
