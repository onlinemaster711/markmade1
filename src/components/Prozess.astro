---
const schritte = [
  {
    nr: '1',
    titel: '10 Minuten Gespräch',
    text: 'Du erzählst was du machst, für wen – und was dich unterscheidet.',
  },
  {
    nr: '2',
    titel: 'Wir bauen deinen Entwurf',
    text: 'Kostenlos. Mit Texten, Struktur und Design. Kein Template.',
  },
  {
    nr: '3',
    titel: 'Du entscheidest – ohne Risiko',
    text: 'Gefällt er dir, geht deine Seite für 1.000 € inkl. MwSt. online. Gefällt er nicht – kein Cent fällig.',
  },
];
---

<section class="prozess">
  <div class="inner">

    <div class="section-head">
      <h2>3 Schritte – du machst fast nichts.</h2>
    </div>

    <div class="schritte">
      {schritte.map((s) => (
        <div class="schritt fade-in">
          <div class="schritt-nr" aria-hidden="true">{s.nr}</div>
          <h3>{s.titel}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .prozess {
    background: var(--surface);
    padding: 5rem 0;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
  }

  .schritte {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 760px;
    margin: 0 auto;
  }

  .schritt {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 3rem;
    align-items: start;
    padding: 2.5rem 0;
    border-top: 1px solid var(--outline-variant);
  }

  .schritt:last-child {
    border-bottom: 1px solid var(--outline-variant);
  }

  .schritt-nr {
    font-family: 'Noto Serif', serif;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    color: var(--secondary);
    opacity: 0.35;
    text-align: right;
  }

  h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--on-surface);
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  @media (max-width: 767px) {
    .schritt {
      grid-template-columns: 60px 1fr;
      gap: 1.5rem;
    }

    .schritt-nr {
      font-size: 2rem;
    }
  }
</style>
