---
const schritte = [
  {
    nr: '1',
    titel: '10 Minuten Gespräch',
    text: 'Du erzählst was du machst, für wen – und was dich unterscheidet.',
  },
  {
    nr: '2',
    titel: 'Wir bauen deinen Entwurf',
    text: 'Kostenlos. Mit Texten, Struktur und Design. Kein Template.',
  },
  {
    nr: '3',
    titel: 'Du entscheidest – ohne Risiko',
    text: 'Gefällt er dir, geht deine Seite für 1.000 € inkl. MwSt. online. Gefällt er nicht – kein Cent fällig.',
  },
];
---

<section class="prozess">
  <div class="inner">

    <div class="section-head">
      <h2>3 Schritte – du machst fast nichts.</h2>
    </div>

    <div class="schritte">
      {schritte.map((s) => (
        <div class="schritt fade-in">
          <div class="schritt-nr" aria-hidden="true">{s.nr}</div>
          <h3>{s.titel}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .prozess {
    background: var(--surface);
    padding: 5rem 0;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.25;
  }

  .schritte {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    position: relative;
  }

  .schritte::before {
    content: '';
    position: absolute;
    top: 2rem;
    left: calc(16.67% + 1.25rem);
    right: calc(16.67% + 1.25rem);
    height: 1px;
    background: var(--outline-variant);
    z-index: 0;
  }

  .schritt {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .schritt-nr {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-family: 'Noto Serif', serif;
    font-size: 1.375rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(184, 0, 73, 0.25);
  }

  h3 {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--on-surface);
  }

  p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--on-surface-muted);
  }

  @media (max-width: 767px) {
    .schritte {
      grid-template-columns: 1fr;
    }

    .schritte::before {
      display: none;
    }
  }
</style>
