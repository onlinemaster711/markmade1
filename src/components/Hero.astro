---
interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  desktopScreenshot?: string;
  mobileScreenshot?: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
  primaryCtaExternal?: boolean;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  metaItems?: string[];
}

const {
  eyebrow = 'Webdesign · Chatbot · Zeitersparnis',
  heading = 'Deine Website erklärt was du machst. Dein Chatbot klärt den Rest.',
  subtext = 'Wir bauen dir eine Website die klar zeigt was du anbietest – und einen Chatbot der Kundenfragen automatisch beantwortet. Das Ergebnis: Weniger Telefonate, bessere Anfragen.',
  primaryCtaText = 'Kostenlosen Entwurf sichern',
  primaryCtaHref = 'https://calendly.com/onlinemaster711/new-meeting',
  primaryCtaExternal = true,
  secondaryCtaText = 'Zeitersparnis berechnen',
  secondaryCtaHref = '/#rechner',
  metaItems = ['Kein Auftrag nötig', '10 Minuten genügen', 'Entwurf zuerst – dann entscheiden'],
} = Astro.props;
---

<section class="hero">
  <div class="orbit-glow"></div>
  <div class="hero-grain"></div>
  <div class="hero-inner">
    <div class="eyebrow"><span>{eyebrow}</span></div>
    <h1 class="hero-headline">{heading}</h1>
    <p class="hero-lede">{subtext}</p>
    <div class="cta-row">
      {primaryCtaExternal ? (
        <a href={primaryCtaHref} class="btn-primary" target="_blank" rel="noopener noreferrer">
          <span>{primaryCtaText}</span>
          <span class="arrow">→</span>
        </a>
      ) : (
        <a href={primaryCtaHref} class="btn-primary">
          <span>{primaryCtaText}</span>
          <span class="arrow">→</span>
        </a>
      )}
      <a href={secondaryCtaHref} class="btn-secondary">{secondaryCtaText}</a>
    </div>
    <div class="meta-row">
      {metaItems.map((item) => <span>{item}</span>)}
    </div>
  </div>
  <div class="scroll-cue" aria-hidden="true"><span>Scroll</span><span class="scroll-line"></span></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background: radial-gradient(ellipse at 60% 40%, #3f4530 0%, #292f1b 100%);
    color: #fbf9f6;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 9rem 2.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /* Grain Textur */
  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='200' height='200' filter='url(%23n)' opacity='0.5'/></svg>");
    z-index: 1;
  }

  /* Orbital Glow */
  .orbit-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 640px;
    height: 640px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at center, rgba(212, 136, 154, 0.18) 0%, rgba(212, 136, 154, 0) 60%);
    pointer-events: none;
    filter: blur(40px);
    animation: orbitPulse 8s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes orbitPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.85; }
    50%      { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
  }

  /* Eyebrow */
  .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #c3caae;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: #b80049;
  }

  /* Headline */
  .hero-headline {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: clamp(3rem, 7vw, 5.75rem);
    letter-spacing: -0.025em;
    line-height: 1.02;
    margin: 0 0 2.5rem;
    max-width: 900px;
    text-wrap: balance;
    color: #fbf9f6;
  }

  /* Lede */
  .hero-lede {
    font-family: 'Manrope', sans-serif;
    font-weight: 300;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.7;
    color: rgba(223, 230, 200, 0.80);
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  /* Button Row */
  .cta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, #b80049 0%, #8c0037 100%);
    color: #ffffff;
    border-radius: 1rem;
    padding: 1rem 1.75rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    box-shadow: 0 12px 28px rgba(184, 0, 73, 0.35);
    transform: translateY(-1px);
  }

  .btn-primary .arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .btn-primary:hover .arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: transparent;
    color: #fbf9f6;
    border: 1px solid rgba(251, 249, 246, 0.22);
    border-radius: 1rem;
    padding: 1rem 1.5rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(251, 249, 246, 0.05);
    border-color: rgba(251, 249, 246, 0.4);
  }

  /* Meta Row */
  .meta-row {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
    color: #c3caae;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-family: 'Manrope', sans-serif;
  }

  .meta-row span {
    position: relative;
  }

  .meta-row span + span::before {
    content: "";
    position: absolute;
    left: -1.5rem;
    top: 50%;
    width: 4px;
    height: 4px;
    background: #b80049;
    border-radius: 50%;
    transform: translateY(-50%);
  }

  /* Scroll Cue */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(223, 230, 200, 0.55);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 2;
  }

  .scroll-line {
    display: inline-block;
    width: 1px;
    height: 24px;
    background: linear-gradient(to bottom, rgba(223, 230, 200, 0.6), rgba(223, 230, 200, 0));
    animation: scrollPulse 2.2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.35; transform: translateY(0); }
    50%      { opacity: 1; transform: translateY(4px); }
  }

  /* Mobile */
  @media (max-width: 860px) {
    .hero-inner { padding: 7rem 1.5rem 5rem; }
    .meta-row { gap: 2rem; }
    .meta-row span + span::before { left: -1rem; }
  }
</style>
