---
interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  desktopScreenshot?: string;
  mobileScreenshot?: string;
}

const {
  eyebrow = 'Webdesign · Chatbot · Zeitersparnis',
  heading = 'Deine Website erklärt was du machst. Dein Chatbot klärt den Rest.',
  subtext = 'Wir bauen dir eine Website die klar zeigt was du anbietest – und einen Chatbot der Kundenfragen automatisch beantwortet. Das Ergebnis: Weniger Telefonate, bessere Anfragen.',
  desktopScreenshot = 'screenshot-desktop.webp',
  mobileScreenshot = 'screenshot-mobile.webp',
} = Astro.props;
---

<section class="hero">
  <div class="hero-inner">

    <div class="hero-top">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="subtext">{subtext}</p>
    </div>

    <div class="hero-visual">
      <div class="mockup-laptop">
        <div class="laptop-screen">
          <img src="/screenshot-desktop.webp" alt="Website Vorschau Desktop" loading="eager" />
        </div>
        <div class="laptop-base"></div>
      </div>
      <div class="mockup-phone">
        <div class="phone-screen">
          <img src="/screenshot-mobile.webp" alt="Website Vorschau Mobile" loading="eager" />
        </div>
      </div>
    </div>

    <div class="hero-bottom">
      <div class="hero-buttons">
        <a href="/#cta" class="btn-primary">Kostenlosen Entwurf sichern</a>
        <a href="/#rechner" class="btn-ghost">Zeitersparnis berechnen →</a>
      </div>

      <ul class="trust-list">
        <li><span class="check">✓</span> Kein Auftrag nötig</li>
        <li><span class="check">✓</span> 10 Minuten genügen</li>
        <li><span class="check">✓</span> Entwurf zuerst – dann entscheiden</li>
      </ul>
    </div>

  </div>
</section>

<style>
  .hero {
    background: var(--surface);
    padding-top: 5rem;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .hero-top {
    grid-column: 1;
  }

  .hero-bottom {
    grid-column: 1;
  }

  .hero-visual {
    grid-column: 2;
    grid-row: 1 / 3;
  }

  /* --- Text --- */
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.2;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .subtext {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--on-surface-muted);
    margin-bottom: 2rem;
    max-width: 52ch;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.8125rem 1.5rem;
    background: linear-gradient(135deg, var(--secondary), var(--secondary-container));
    color: var(--on-secondary);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.8125rem 1.25rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-ghost:hover { color: var(--on-surface); }

  .trust-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .trust-list li {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .check {
    color: var(--secondary);
    font-weight: 700;
  }

  /* --- Visual --- */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .mockup-laptop {
    width: 100%;
    max-width: 460px;
    position: relative;
    z-index: 1;
  }

  .laptop-screen {
    background: var(--primary);
    border-radius: 0.75rem 0.75rem 0 0;
    border: 8px solid var(--primary);
    overflow: hidden;
    aspect-ratio: 16/10;
  }

  .laptop-screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .laptop-base {
    height: 14px;
    background: var(--primary-container);
    border-radius: 0 0 0.5rem 0.5rem;
    margin: 0 -8px;
  }

  .mockup-phone {
    position: absolute;
    bottom: -1rem;
    right: -1.5rem;
    width: 28%;
    max-width: 130px;
    z-index: 2;
    background: var(--primary);
    border-radius: 1rem;
    border: 5px solid var(--primary);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(27, 28, 26, 0.25);
    aspect-ratio: 9/19;
  }

  .mockup-phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* --- Responsive --- */
  @media (max-width: 767px) {
    .hero-inner {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      padding-top: 6rem;
    }

    .hero-top {
      order: 1;
    }

    .hero-visual {
      order: 2;
    }

    .hero-bottom {
      order: 3;
    }

    .mockup-phone {
      right: 0;
    }
  }
</style>
