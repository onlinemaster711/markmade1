---
interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
  primaryCtaExternal?: boolean;
}

const {
  eyebrow = 'Webdesign · Chatbot · Zeitersparnis',
  heading = 'Deine Website erklärt was du machst. Dein Chatbot klärt den Rest.',
  subtext = 'Wir bauen dir eine Website die klar zeigt was du anbietest – und einen Chatbot der Kundenfragen automatisch beantwortet.',
  primaryCtaText = 'Kostenlosen Entwurf sichern',
  primaryCtaHref = 'https://calendly.com/onlinemaster711/new-meeting',
  primaryCtaExternal = true,
} = Astro.props;
---

<section class="hero">
  <div class="orbit-glow"></div>
  <div class="hero-grain"></div>
  <div class="hero-inner">
    <div class="eyebrow"><span>{eyebrow}</span></div>
    <h1 class="hero-headline">{heading}</h1>
    <p class="hero-lede">{subtext}</p>
    {primaryCtaExternal ? (
      <a href={primaryCtaHref} class="btn-primary" target="_blank" rel="noopener noreferrer">
        <span>{primaryCtaText}</span>
        <span class="arrow">→</span>
      </a>
    ) : (
      <a href={primaryCtaHref} class="btn-primary">
        <span>{primaryCtaText}</span>
        <span class="arrow">→</span>
      </a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background: var(--surface);
    color: var(--on-surface);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 9rem 2.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /* Grain Textur */
  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.03;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='200' height='200' filter='url(%23n)' opacity='0.5'/></svg>");
    z-index: 1;
  }

  /* Orbital Glow */
  .orbit-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 640px;
    height: 640px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at center, rgba(212, 136, 154, 0.12) 0%, rgba(212, 136, 154, 0) 60%);
    pointer-events: none;
    filter: blur(40px);
    animation: orbitPulse 8s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes orbitPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.85; }
    50%      { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
  }

  /* Eyebrow */
  .eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--on-surface-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: #b80049;
  }

  /* Headline */
  .hero-headline {
    font-family: 'Noto Serif', serif;
    font-weight: 700;
    font-size: clamp(3rem, 7vw, 5.75rem);
    letter-spacing: -0.025em;
    line-height: 1.02;
    margin: 0 0 1.5rem;
    max-width: 900px;
    text-wrap: balance;
    color: var(--on-surface);
  }

  .hero-headline::after {
    content: '';
    display: block;
    width: 80px;
    height: 3px;
    background: var(--primary);
    margin: 1.5rem auto 0;
  }

  /* Lede */
  .hero-lede {
    font-family: 'Manrope', sans-serif;
    font-weight: 300;
    font-size: 1.3125rem;
    line-height: 1.5;
    color: var(--on-surface-muted);
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, #b80049 0%, #8c0037 100%);
    color: #ffffff;
    border-radius: 1rem;
    padding: 1rem 1.75rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    box-shadow: 0 12px 28px rgba(184, 0, 73, 0.35);
    transform: translateY(-1px);
  }

  .btn-primary .arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .btn-primary:hover .arrow {
    transform: translateX(4px);
  }

  /* Mobile */
  @media (max-width: 860px) {
    .hero-inner { padding: 7rem 1.5rem 5rem; }
  }
</style>
