---

<section class="beweis">
  <div class="inner">

    <div class="beweis-text fade-in">
      <p class="eyebrow">Echte Referenz</p>
      <p class="stars" aria-label="5 von 5 Sternen">★★★★★</p>
      <blockquote>
        <p>"Ich hatte vorher keine Seite die wirklich zu mir gepasst hat. Jetzt finden mich Patienten bei Google – und melden sich direkt."</p>
      </blockquote>
      <p class="name">Elke Reinke · Osteopathin · Stuttgart Degerloch</p>
      <a href="https://osteopath-stuttgart.com" target="_blank" rel="noopener" class="ref-link">
        osteopath-stuttgart.com ansehen →
      </a>
    </div>

    <div class="beweis-screenshot fade-in">
      <img
        src="/screenshot-desktop.png"
        alt="Screenshot osteopath-stuttgart.com"
        loading="lazy"
        width="640"
        height="400"
      />
    </div>

  </div>
</section>

<style>
  .beweis {
    background: var(--surface-low);
    padding: 5rem 0;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .stars {
    color: #f5a623;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  blockquote p {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-style: italic;
    line-height: 1.5;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .name {
    font-size: 0.9375rem;
    color: var(--on-surface-muted);
    margin-bottom: 1rem;
  }

  .ref-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--secondary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ref-link:hover { opacity: 0.75; }

  .beweis-screenshot img {
    width: 100%;
    height: auto;
    border-radius: 1.2rem;
    box-shadow: 0px 24px 64px rgba(27, 28, 26, 0.15);
    display: block;
  }

  @media (max-width: 767px) {
    .inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
