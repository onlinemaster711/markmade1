---
---

<div id="cookie-banner" class="cookie-banner" aria-live="polite" aria-label="Cookie-Hinweis" hidden>
  <div class="cookie-inner">
    <div class="cookie-text">
      <p>Diese Website verwendet technisch notwendige Cookies. Keine Tracking-Cookies.</p>
      <a href="/datenschutz" class="cookie-link">Datenschutzerklärung lesen →</a>
    </div>
    <div class="cookie-actions">
      <button id="cookie-reject" class="btn-reject">Ablehnen</button>
      <button id="cookie-accept" class="btn-accept">Akzeptieren</button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner') as HTMLElement;
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  function hideBanner() {
    banner.setAttribute('hidden', '');
  }

  if (!localStorage.getItem('cookies_accepted')) {
    banner.removeAttribute('hidden');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookies_accepted', 'true');
    hideBanner();
    window.dispatchEvent(new CustomEvent('cookiesAccepted'));
  });

  rejectBtn?.addEventListener('click', () => {
    localStorage.setItem('cookies_accepted', 'false');
    hideBanner();
  });
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--ink, var(--primary));
    color: #fff;
    border-radius: 1rem 1rem 0 0;
  }

  .cookie-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 5%;
  }

  .cookie-text p {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin-bottom: 0.375rem;
  }

  .cookie-link {
    font-size: 0.8125rem;
    color: var(--bordeaux, rgba(255, 255, 255, 0.65));
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .cookie-link:hover {
    color: var(--bordeaux-deep, #fff);
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .btn-reject,
  .btn-accept {
    cursor: pointer;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: 1rem;
    transition: opacity 0.2s;
  }

  .btn-reject {
    background: transparent;
    border: 1px solid var(--rule-2, rgba(255, 255, 255, 0.3));
    color: #fff;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-reject:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--rule-2, rgba(255, 255, 255, 0.6));
  }

  .btn-accept {
    background: var(--bordeaux, linear-gradient(135deg, var(--secondary), var(--secondary-container)));
    border: none;
    color: #fff;
    transition: background 0.2s, opacity 0.2s;
  }

  .btn-accept:hover {
    background: var(--bordeaux-deep, var(--secondary-container));
    opacity: 0.95;
  }

  @media (max-width: 767px) {
    .cookie-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
    }

    .cookie-actions {
      flex-direction: column;
    }

    .btn-reject,
    .btn-accept {
      width: 100%;
      text-align: center;
    }
  }
</style>
